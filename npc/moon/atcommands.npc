			close;
		}
		donpcevent "TarotEvent::OnStart";
	}
	end;
}

-	script	#tarot	-1,{
OnInit:
	bindatcmd("tarot",strnpcinfo(0)+"::OnCommand",0,99);
	end;

OnCommand:
	if( $eventtarot ) {
		do {
			.@y = rand(94,106);
			.@x = rand(94,106);
		} while( .@y >= 98 && .@y <= 102 && .@x >= 98 && .@y <= 102 );

		for( .@i = 0; .@i < getarraysize($@tarotplayers$); .@i++ ) {
			if( $@tarotplayers$[.@i] == strcharinfo(0) ) {
				mes "[La mort ou tchitchi]";
				mes "Wow ça va pas la peine de spam la commande XD.";
				close2;
				warp "force_1-1",.@x,.@y;
				end;
			}
		}
		mes "[La mort ou tchitchi]";
		mes "Tu es ŕ présent inscrit et vas ętre téléporté sur place.";
		$@tarotplayers$[getarraysize($@tarotplayers$)] = strcharinfo(0);
		close2;
		areamonster "force_1-1",95,95,105,105,"Porcs aux ribs dorées",1840,1;
		warp "force_1-1",.@x,.@y;
		end;
	}
	else {
		mes "[La mort ou tchitchi]";
		mes "Aucun event tarot n'est actif :o";
		close;
	}
	end;
}

-	script	#loupgarou	-1,{
OnInit:
	bindatcmd("loupgarou",strnpcinfo(0)+"::OnCommand",99,99);
	end;

OnCommand:
	if( $eventloup ) {
		if( getarraysize($@loupgarou$) >= 10 ) {
			mes "[Loup Garou]";
			mes "Navré pour le moment le format de l'event est ŕ 10 joueurs !";
			close;
		}

		for( .@i = 0; .@i < getarraysize($@loupgarou$); .@i++ ) {
			if( $@loupgarou$[.@i] == strcharinfo(0) ) {
				mes "[Loup Garou]";
				mes "Wow ça va pas la peine de spam la commande XD.";
				close2;
				warp "region_8", rand(46,53), rand(46,53);
				end;
			}
		}

		mes "[Loup Garou]";
		mes "Tu es ŕ présent inscrit et vas ętre téléporté sur place.";
		$@loupgarou$[getarraysize($@loupgarou$)] = strcharinfo(0);
		close2;
		warp "region_8", rand(46,53), rand(46,53);
		end;
	}
	else {
		mes "[Loup Garou]";
		mes "Aucun event lou garou n'est actif :o";
		close;
	}
	end;
}

-	script	#eventexp	-1,{
OnInit:
	bindatcmd("eventexp",strnpcinfo(0)+"::OnCommand",80,99);
	end;

OnTimer900000:
	if( eventexp() )
		callfunc "announce2","Il reste 15min d'event exp !!",bc_all;
	end;

OnTimer1200000:
	if( eventexp() )
		Announce "Il reste 10min d'event exp !!",bc_all;
	end;

OnTimer1500000:
	if( eventexp() )
		Announce "Il reste 5min d'event exp !!",bc_all;
	end;

OnTimer1740000:
	if( eventexp() )
		Announce "Il reste 1min d'event exp !!",bc_all;
	end;

OnCommand:
	if( !eventexp() ) {
		$eventexp = gettimetick(2) + 1800;
		$eventexprate = cap_value(200, atoi(.@atcmd_parameters$[0]), 400);
		setBattleFlag "mult_eventexp", $eventexprate;
		starteventexp();
		setBattleFlag "party_even_share_bonus", 35;
		setBattleFlag "aoe_teleport_acd", 2000;
		callfunc "announce2","Attention rates augmentées pour 30min, base & job "+(1000*(getBattleFlag("mult_eventexp")/100))+" et bonus party share 35%!",bc_all;
		initnpctimer;
		end;
	}
OnTimer1800000:
	if( eventexp() ) {
		$eventexprate = 200;
		stopeventexp();
		setBattleFlag "mult_eventexp", 200;
		setBattleFlag "party_even_share_bonus", 10;
		setBattleFlag "aoe_teleport_acd", 300;
		callfunc "announce2","Retour ŕ la normale! Base & Job rate ŕ 1000 et bonus party share 10%!",bc_all;
		stopnpctimer;
	}
	$eventexp = 0;
	end;
}

-	script	#eventdrop	-1,{
OnInit:
	bindatcmd("eventdrop",strnpcinfo(0)+"::OnCommand",80,99);
	end;

OnTimer900000:
	if( eventdrop() )
		callfunc "announce2","Il reste 15min d'event drop !!",bc_all;
	end;

OnTimer1200000:
	if( eventdrop() )
		Announce "Il reste 10min d'event drop !!",bc_all;
	end;

OnTimer1500000:
	if( eventdrop() )
		Announce "Il reste 5min d'event drop !!",bc_all;
	end;

OnTimer1740000:
	if( eventdrop() )
		Announce "Il reste 1min d'event drop !!",bc_all;
	end;

OnCommand:
	if( !eventdrop() ) {
		$@qtyedropper = 0;
		$eventdrop = gettimetick(2) + 1800;
		starteventdrop();
		callfunc "announce2","Attention chance de drop cards, item communs et equippements multipliés par "+(getBattleFlag("mult_eventdrop")/100)+" pour 30min !!!",bc_all;
		initnpctimer;
		end;
	}
OnTimer1800000:
	if( eventdrop() ) {
		$eventdrop = 0;
		stopeventdrop();
		callfunc "announce2","Fin d'event drop ! Retour ŕ la normale.",bc_all;
		stopnpctimer;
	}
	end;
}

-	script	#alootid2	-1,{

OnInit:
	.enable_login_autoload = 1;
	.max_alootid_group = 10;
	.max_alootid_item = 50;
	bindatcmd("alootid2", strnpcinfo(3)+"::OnCommand");
	end;

OnCommand:
	.@cid = getcharid(0);
	.@alootid_group = atoi(.@atcmd_parameters$[1]);

	if (!.@atcmd_numparameters) {
		dispbottom "Usage: "+.@atcmd_command$+" list";
		dispbottom "Usage: "+.@atcmd_command$+" load <#>";
		dispbottom "Usage: "+.@atcmd_command$+" save <#> <item1> ... <item"+.max_alootid_item+">";
		dispbottom "Usage: "+.@atcmd_command$+" set <#> name <name>";
		if (.enable_login_autoload)
			dispbottom "Usage: "+.@atcmd_command$+" set <#> autoload <1/0>";
	}
	else if (.@atcmd_parameters$[0] == "save") {
		if (!.@alootid_group || .@alootid_group <= 0 || .@alootid_group > .max_alootid_group) {
			dispbottom "Usage: "+.@atcmd_command$+" save <"+.@alootid_group+"> - invalid no "+.@alootid_group+". (min: 1, max: "+.max_alootid_group+")";
		}
		else {
			for (.@i = 2; .@i < .@atcmd_numparameters; .@i++) {
				.@nameid = atoi(.@atcmd_parameters$[.@i]);
				if (getitemname(.@nameid) != "null")
					.@sql$ = .@sql$ + ((.@i >= 3) ? ", ":"") + "("+.@cid+", "+.@alootid_group+", "+.@nameid+")";
			}
			if (.@sql$ == "") {
				dispbottom "Usage: "+.@atcmd_command$+" save <"+.@alootid_group+"> - save failed.";
			}
			else {
				query_sql("DELETE FROM `alootid` WHERE `cid` = "+.@cid+" AND `no` = "+.@alootid_group);
				query_sql("INSERT INTO `alootid` (`cid`,`no`, `nameid`) VALUES " + .@sql$);
				dispbottom "Usage: "+.@atcmd_command$+" save <"+.@alootid_group+"> - save successfully.";
			}
		}
	}
	else if (.@atcmd_parameters$[0] == "load") {
		if (!.@alootid_group || .@alootid_group <= 0 || .@alootid_group > .max_alootid_group) {
			dispbottom "Usage: "+.@atcmd_command$+" load <"+.@alootid_group+"> - invalid no "+.@alootid_group+".";
		}
		else {
			.@size = query_sql("SELECT `nameid` FROM `alootid` WHERE `cid` = "+.@cid+" AND `no` = "+.@alootid_group+" LIMIT "+.max_alootid_item, .@nameid);
			if (!.@size) {
				dispbottom "Usage: "+.@atcmd_command$+" load <"+.@alootid_group+"> - settings not found.";
			}
			else {
				atcommand("@alootid reset");
				for (.@i = 0; .@i < .@size; .@i++)
					atcommand("@alootid +"+.@nameid[.@i]);
				dispbottom "Usage: "+.@atcmd_command$+" load <"+.@alootid_group+"> - loaded successfully.";
			}
		}
	}
	else if (.@atcmd_parameters$[0] == "list") {
		.@size = query_sql("SELECT `no`, `name`, `auto`, GROUP_CONCAT(nameid SEPARATOR ', ') FROM `alootid` WHERE `cid` = "+.@cid+" GROUP BY `name`, `no` LIMIT "+.max_alootid_group, .@no, .@name$, .@auto, .@nameid_list$);
		for (.@i = 0; .@i < .@size; .@i++) {
			dispbottom "Group <"+.@no[.@i]+"> "+.@name$[.@i]+" - "+.@nameid_list$[.@i] + (.enable_login_autoload && .@auto[.@i]? " (autoload)":"");
		}
		dispbottom "Usage: "+.@atcmd_command$+" list - found "+.@size+" settings.";
	}
	else if (.@atcmd_parameters$[0] == "set") {
		if (!.@alootid_group || .@alootid_group <= 0 || .@alootid_group > .max_alootid_group) {
			dispbottom "Usage: "+.@atcmd_command$+" set <"+.@alootid_group+"> - invalid no "+.@alootid_group+".";
		}
		else if (.@atcmd_parameters$[2] == "name") {
			query_sql("UPDATE `alootid` SET `name` = '"+escape_sql(.@atcmd_parameters$[3])+"' WHERE `cid` = "+.@cid+" AND `no` = "+.@alootid_group);
			dispbottom "Usage: "+.@atcmd_command$+" set <"+.@alootid_group+"> name '"+.@atcmd_parameters$[3]+"' successfully.";
		}
		else if (.enable_login_autoload && .@atcmd_parameters$[2] == "autoload") {
			query_sql("UPDATE `alootid` SET `auto` = CASE WHEN `no` = "+.@alootid_group+" THEN "+(atoi(.@atcmd_parameters$[3]) > 0)+" ELSE 0 END WHERE `cid` = "+.@cid);
			dispbottom "Usage: "+.@atcmd_command$+" set <"+.@alootid_group+"> autoload '"+((atoi(.@atcmd_parameters$[3]) > 0) ? "enabled":"disabled")+"' successfully.";
		}
		else {
			dispbottom "Usage: "+.@atcmd_command$+" set <"+.@alootid_group+"> invalid options.";
			dispbottom "Usage: "+.@atcmd_command$+" set <"+.@alootid_group+"> name <name>";
			if (.enable_login_autoload)
				dispbottom "Usage: "+.@atcmd_command$+" set <"+.@alootid_group+"> autoload <1/0>";
		}
	}
	else {
		dispbottom "Usage: "+.@atcmd_command$+" invalid options.";
	}
	end;

OnPCLoginEvent:
	if (.enable_login_autoload) {
		sleep2 1000;
		.@size = query_sql("SELECT `no`, `nameid` FROM `alootid` WHERE `cid` = "+getcharid(0)+" AND `auto` = 1 LIMIT "+.max_alootid_item, .@alootid_group, .@nameid);
		if (.@size) {
			atcommand("@alootid reset");
			for (.@i = 0; .@i < .@size; .@i++)
				atcommand("@alootid +"+.@nameid[.@i]);
			dispbottom "Usage: @alootid2 load <"+.@alootid_group+"> - loaded successfully.";
		}
	}
	end;
}
