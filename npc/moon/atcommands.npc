	close;
}

-	script	#pvp	-1,{
OnInit:
	bindatcmd("pvp",strnpcinfo(0)+"::OnCommand",0,99);
	end;

OnCommand:
	switch(select("Player Ranking:PvP Statistic:Announcer Setting")){
		case 1: //Player Ranking
			mes "[Top "+getvariableofnpc(.Top, "Versus")+" PvP Players]";
			mes "^0000FFKill^000000 | ^FF0000Death^000000 | ^FF22FFKDR^000000 | ^00FF00SK^000000 | ^666666MK^000000";
			query_sql "SELECT `char`, `kill`, `death`, `kdr`, `killingstreak`, `multikill` FROM `pvp_rank` ORDER BY `pvp_rank`.`kill` DESC LIMIT "+getvariableofnpc(.Top, "Versus")+"", .@char$, .@kill, .@death, .@kdr$, .@sk, .@mk;
			for(set .@i, 0; .@i < getarraysize(.@char$); set .@i, .@i + 1){
				mes .@i+1+". "+.@char$[.@i]+" ^0000FF"+.@kill[.@i]+"^000000 ^FF0000"+.@death[.@i]+"^000000 ^FF22FF"+.@kdr$[.@i]+"^000000 ^00FF00"+.@sk[.@i]+"^000000 ^666666"+.@mk[.@i]+"^000000 ";
			}
			close;

		case 2: //PvP Statistic
			mes strcharinfo(0)+"'s PvP Statistic";
			mes "^666666Kill:^000000 "+Kill+" ^666666Death:^000000 "+Death+" ^666666KDR:^000000 "+callfunc("KDR_Calc", Kill, Death)+"^000000";
			mes "^666666Killing Streak:^000000 "+KillingStreak+" ^666666Multi-Kills:^000000 "+MultiKill+"";
			switch(select("Killing Streak:Multi-Kill Streak:Nemesis Streak:"+(getvariableofnpc(.Reset, "Versus")?"Reset":"")+"")){
			case 1: //Killing Streak
				next;
				setarray .LSDotA$[0], ""+KillingSpree+"", ""+Dominating+"", ""+MegaKill+"", ""+Unstoppable+"", ""+WickedSick+"", ""+MonsterKill+"", ""+Godlike+"", ""+BeyondGodlike+"";
				mes "Killing Streak Stats";
				switch(#Announcer){
				case 0:
					for(set .@i, 0; .@i < getarraysize(.LSDotA$); set .@i, .@i + 1){
						mes "^666666"+getvariableofnpc(.ESDotA$[.@i], "Versus")+"^000000: "+ .LSDotA$[.@i];
					 }
					close;
				default:
					for(set .@i, 0; .@i < getarraysize(.LSDotA$); set .@i, .@i + 1){
						mes "^666666"+getvariableofnpc(.ESHoN$[.@i], "Versus")+"^000000: "+ .LSDotA$[.@i];
					 }
					close;
				}
				close;
			case 2: //Multi-Kill
				next;
				setarray .LMDotA$[0], ""+DoubleKill+"", ""+TripleKill+"", ""+UltraKill+"", ""+Rampage+"", ""+Ownage+"";
				mes "Multi-Kill Stats";
				switch(#Announcer){
				case 0:
					for(set .@i, 0; .@i < getarraysize(.LMDotA$); set .@i, .@i + 1){
						mes "^666666"+getvariableofnpc(.EMDotA$[.@i], "Versus")+"^000000: "+ .LMDotA$[.@i];
					 }
					close;
				default:
					for(set .@i, 0; .@i < getarraysize(.LMDotA$); set .@i, .@i + 1){
						mes "^666666"+getvariableofnpc(.EMHoN$[.@i], "Versus")+"^000000: "+ .LMDotA$[.@i];
					 }
					close;
				}
			case 3:	//Nemesis
				next;
				mes "Nemesis Stat";
				mes "^666666Nemesis Kill^000000: "+NemesisKill;
				mes "^666666Feed Count^000000: "+FeedCount;
				close;
			case 4: //Reset Stat
				next;
				set .Reset, getvariableofnpc(.Reset, "Versus");
				set .ZenyFee, getvariableofnpc(.ZenyFee, "Versus");
				set .CashFee, getvariableofnpc(.CashFee, "Versus");
				set .SkullFee, getvariableofnpc(.SkullFee, "Versus");
				mes "[Loki]"; mes "Are you sure you want to reset your PvP Statistics?";
				if(.Reset == 1){ mes "^FF0000Reset Fee:^000000 "+.ZenyFee+" Zeny"; }
				if(.Reset == 2){ mes "^FF0000Reset Fee:^000000 "+.CashFee+" Kill Point"; }
				if(.Reset == 3){ mes "^FF0000Reset Fee:^000000 "+.SkullFee+" Skull"; }
				switch(select("No:Yes")){
					case 1: close;
					case 2:
					switch(.Reset){
						case 0: break;
						case 1:
							if(Zeny < .ZenyFee){ next; mes "You don't have enough Zeny."; close; }
							set Zeny, Zeny - .ZenyFee; break;
						case 2:
							if(#CASHPOINTS < .CashFee){ next; mes "You don't have enough Kill Point."; close; }
							set #CASHPOINTS, #CASHPOINTS - .CashFee; break;
						case 3:
							if(countitem(7420) < .SkullFee){ next; mes "You don't have enough Skull."; close; }
							delitem 7420, .SkullFee; break;
						default: break;
					}
				query_sql "DELETE FROM `pvp_rank` WHERE `pvp_rank`.`char_id` = "+getcharid(0)+"";
				callsub OnPvPReset; announce "Your PvP Statistic has been reset.",bc_self,0xFF0000; close;
				}
				close;
			}
		close;
		case 3: //Announcer Setting
			mes "What kind of announcer you want to use?";
			if(getvariableofnpc(.AnnouncerFee, "Versus")){ set .AnnouncerFee, getvariableofnpc(.AnnouncerFee, "Versus"); }
			L_Announce:
			switch(select(""+((#Announcer == 0)?"^FF0000DotA^000000":"DotA")+":"+((#Announcer == 1)?"^FF0000HoN^000000":"HoN")+":"+((#Announcer == 2)?"^FF0000Ms. Pudding^000000":"Ms. Pudding")+":"+((#Announcer == 3)?"^FF0000Flamboyant^000000":"Flamboyant")+":"+((#Announcer == 4)?"^FF0000English^000000":"English")+":"+((#Announcer == 5)?"^FF0000Balls of Steel^000000":"Balls of Steel")+":"+((#Announcer == 6)?"^FF0000BreakyCPK^000000":"BreakyCPK")+":Désactiver")) {
				case 1: //DotA
					if(#Announcer == 0){ goto L_Announce; }
					//soundeffect "0_KS1.wav", 0;
					set #Announcer, 0;
					announce "DotA announcer has been configured to your account.",bc_self,0xFF0000;
					close;
				case 2: //HoN
					if(#Announcer == 1){ goto L_Announce; }
					if((.AnnouncerFee) && (!#Hon)){
					next; mes "Do you want to purchase HoN announcer for "+.AnnouncerFee+" Kill Point?";
					switch(select("No:Yes")){
						case 1: close;
						case 2: 
						if(#CASHPOINTS < .AnnouncerFee){ next; mes "You don't have enough Kill Point."; close; }
						set #CASHPOINTS, #CASHPOINTS - .AnnouncerFee;
						set #Hon, 1;
					 }
					}
					//soundeffect "1_KS1.wav", 0;
					set #Announcer, 1;
					announce "HoN announcer has been configured to your account.",bc_self,0xFF0000;
					close;
				case 3: //Ms. Pudding
					if(#Announcer == 2){ goto L_Announce; }
					if((.AnnouncerFee) && (!#MsPudding)){
					next; mes "Do you want to purchase Ms. Pudding announcer for "+.AnnouncerFee+" Kill Point?";
					switch(select("No:Yes")){
						case 1: close;
						case 2: 
						if(#CASHPOINTS < .AnnouncerFee){ next; mes "You don't have enough Kill Point."; close; }
						set #CASHPOINTS, #CASHPOINTS - .AnnouncerFee;
						set #MsPudding, 1;
					 }
					}
					//soundeffect "2_KS1.wav", 0;
					set #Announcer, 2;
					announce "Ms. Pudding announcer has been configured to your account.",bc_self,0xFF0000;
					close;		
				case 4: //Flamboyant
					if(#Announcer == 3){ goto L_Announce; }
					if((.AnnouncerFee) && (!#Flamboyant)){
					next; mes "Do you want to purchase Flamboyant announcer for "+.AnnouncerFee+" Kill Point?";
					switch(select("No:Yes")){
						case 1: close;
						case 2: 
						if(#CASHPOINTS < .AnnouncerFee){ next; mes "You don't have enough Kill Point."; close; }
						set #CASHPOINTS, #CASHPOINTS - .AnnouncerFee;
						set #Flamboyant, 1;
					 }
					}
					//soundeffect "3_KS1.wav", 0;
					set #Announcer, 3;
					announce "Flamboyant announcer has been configured to your account.",bc_self,0xFF0000;
					close;			
				case 5: //English
					if(#Announcer == 4){ goto L_Announce; }
					if((.AnnouncerFee) && (!#English)){
					next; mes "Do you want to purchase English announcer for "+.AnnouncerFee+" Kill Point?";
					switch(select("No:Yes")){
						case 1: close;
						case 2: 
						if(#CASHPOINTS < .AnnouncerFee){ next; mes "You don't have enough Kill Point."; close; }
						set #CASHPOINTS, #CASHPOINTS - .AnnouncerFee;
						set #English, 1;
					 }
					}
					//soundeffect "4_KS1.wav", 0;
					set #Announcer, 4;
					announce "English announcer has been configured to your account.",bc_self,0xFF0000;
					close;
				case 6: //Balls of Steel
					if(#Announcer == 5){ goto L_Announce; }
					if((.AnnouncerFee) && (!#BallsofSteel)){
					next; mes "Do you want to purchase Balls of Steel announcer for "+.AnnouncerFee+" Kill Point?";
					switch(select("No:Yes")){
						case 1: close;
						case 2: 
						if(#CASHPOINTS < .AnnouncerFee){ next; mes "You don't have enough Kill Point."; close; }
						set #CASHPOINTS, #CASHPOINTS - .AnnouncerFee;
						set #BallsofSteel, 1;
					 }
					}
					//soundeffect "5_KS1.wav", 0;
					set #Announcer, 5;
					announce "Balls of Steel announcer has been configured to your account.",bc_self,0xFF0000;
					close;
				case 7: //BreakyCPK
					if(#Announcer == 6){ goto L_Announce; }
					if((.AnnouncerFee) && (!#BreakyCPK)){
					next; mes "Do you want to purchase BreakyCPK announcer for "+.AnnouncerFee+" Kill Point?";
					switch(select("No:Yes")){
						case 1: close;
						case 2: 
						if(#CASHPOINTS < .AnnouncerFee){ next; mes "You don't have enough Kill Point."; close; }
						set #CASHPOINTS, #CASHPOINTS - .AnnouncerFee;
						set #BreakyCPK, 1;
					 }
					}
					//soundeffect "6_KS1.wav", 0;
					set #Announcer, 6;
					announce "BreakyCPK announcer has been configured to your account.",bc_self,0xFF0000;
					close;
				case 8: //BreakyCPK
					set #Announcer, 7;
					announce "Annoncer désactivé.",bc_self,0xFF0000;
					close;
			default: close;
			}
		end;
	 }
	close;
}

-	script	#testcostume	-1,{
OnInit:
	bindatcmd("testcostume",strnpcinfo(0)+"::OnCommand",0,99);
	end;

OnCommand:
    switch( select( "Nouveautés Invasion", "Nouveautés Vot'shop", "Costumes Vot'shop" ) ) {
        case 1:
            setarray .@array1[0],20219,20297,31251,20026,19857,
                                 19959,20103,31106,31107,
                                 20075,20433,19521,19514,20259,
                                 31518,20183;
            setarray .@array2[0],0;
                                 break;
        case 2:
            setarray .@array1[0],
                                 20132,19661,31455,20381,20085,
                                 31172,31027,20379,31512,20083,
                                 31300,20448,31803,31798,
                                 31731,31719,31616,31454,20135,
                                 31299,31600,19823,31452,20081,
                                 20089,20036,20319,20232,
                                 20101,20404,31186,20234,
                                 31437,20086,20088,20087,20380,
                                 31693,20430,31549,20300,
                                 20270,31614,20349,19985;
            setarray .@array2[0],20285,HAT_EF_BLOSSOM_FLUTTERING,
                                 20209,HAT_EF_MERMAID_LONGING,
                                 20154,HAT_EF_MAPLE_FALLS,
                                 20099,HAT_EF_LJOSALFAR;
                                 break;
        case 3:
            setarray .@array1[0],
                                 20587,20576,20577,20578,20582,
                                 20579,20574,20572,20570,20543,
                                 20530,20528,20527,20588,20826,
                                 20586,20594,29996,29997,20575,
                                 20571,29998,20589,20521,20513,
                                 29999,20955,20940,
                                 20842,20526,20525,20516,
                                 20514,20512,20518,20510,20509,
                                 20507,20504,20502,20500,20511,
                                 20593,20597,20596,20727,20737,
                                 20517,20505,
                                 20590,29995,20592,20546,20764,
                                 20763,20762,20761,20746,19381;
            setarray .@array2[0],20457,HAT_EF_FEATHER_FLUTTERING,
                                 20487,HAT_EF_FLORAL_WALTZ,
                                 20515,HAT_EF_MAGICCIRCLE,
                                 20519,HAT_EF_FULL_BLOOMCHERRY_TREE,
                                 31056,HAT_EF_DOUBLEGUMGANG,
                                 31091,HAT_EF_GOLD_SHOWER;
                                 break;
    }

	setpcblock PCBLOCK_COMMANDS,true;
		.@menu$ = "";
    if( getarraysize(.@array1) > 0 )
        for( .@i = 0; .@i < getarraysize(.@array1); .@i++ )
            .@menu$ = .@menu$ + getitemname(.@array1[.@i]) + " [" + .@array1[.@i] + "]:";
    if( getarraysize(.@array2) > 1 )
        for( .@i = 0; .@i < getarraysize(.@array2); .@i += 2 )
            .@menu$ = .@menu$ + getitemname(.@array2[.@i]) + " [" + .@array2[.@i] + "]:";
	.@menu$ = .@menu$ + "Quitter";
	.@id = getequipid(EQI_COSTUME_GARMENT);
	@lookrobe = 0;
	@lookrobe = getlook(LOOK_ROBE);
	@looktop = 0;
	@looktop = getlook(LOOK_HEAD_TOP);
	@lookmid = 0;
	@lookmid = getlook(LOOK_HEAD_MID);
	@lookbot = 0;
	@lookbot = getlook(LOOK_HEAD_BOTTOM);
	if( .@id > 0 )
		unequip EQI_COSTUME_GARMENT;
	while( 1 ) {
		@menu = prompt( .@menu$ );
		@menu1 = getarraysize(.@array1);
		if( .@effid > 0 ) {
			hateffect(.@effid,false);
			.@effid = 0;
		}
		if( @menu > (@menu1+(getarraysize(.@array2) / 2)) ) {
			if( .@id > 0 )
				equip .@id;
			changelook LOOK_ROBE,@lookrobe;
			changelook LOOK_HEAD_TOP,@looktop;
			changelook LOOK_HEAD_MID,@lookmid;
			changelook LOOK_HEAD_BOTTOM,@lookbot;
			setpcblock PCBLOCK_COMMANDS,false;
			break;
		}
		if( @menu > @menu1 ) {
			.@idx = (@menu - @menu1) * 2;
			.@effid = .@array2[.@idx - 1];
			// dispbottom ""+@menu+" - "+@menu1+" - "+.@idx+" - "+.@effid;
			hateffect(.@effid,true);
		}
		else {
			if( .@array1[@menu-1] == 20571 ) {
				.@effid = HAT_EF_C_VALKYRIE_WING;
				hateffect(.@effid,true);
			}
			if( getiteminfo(.@array1[@menu-1],5) & 8192 )
                changelook LOOK_ROBE,getiteminfo(.@array1[@menu-1], 11);
			if( getiteminfo(.@array1[@menu-1],5) & 1024 ) {
                changelook LOOK_HEAD_MID,@lookmid;
                changelook LOOK_HEAD_BOTTOM,@lookbot;
                changelook LOOK_HEAD_TOP,getiteminfo(.@array1[@menu-1], 11);
            }
			if( getiteminfo(.@array1[@menu-1],5) & 2048 ) {
                changelook LOOK_HEAD_TOP,@looktop;
                changelook LOOK_HEAD_BOTTOM,@lookbot;
                changelook LOOK_HEAD_MID,getiteminfo(.@array1[@menu-1], 11);
            }
			if( getiteminfo(.@array1[@menu-1],5) & 4096 ) {
                changelook LOOK_HEAD_TOP,@looktop;
                changelook LOOK_HEAD_MID,@lookmid;
                changelook LOOK_HEAD_BOTTOM,getiteminfo(.@array1[@menu-1], 11);
            }
		}
	}
	end;
}

-	script	#stfutictac	-1,{
OnInit:
	bindatcmd("stfutictac",strnpcinfo(0)+"::OnCommand",0,99);
