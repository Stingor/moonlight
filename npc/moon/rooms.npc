 -	script	rooms_waiting_dyna	-1,{
	end;
OnInit:
	while( 1 ) {
		if( .@i > 2 )
			.@i = 0; 
		if( $@TierraBG1 || $@TierraBG2 )
			.@TierraBG$ = "Tierra en cours.";
		else
			.@TierraBG$ = "";

		if( $@FlaviusBG1 || $@FlaviusBG2 )
			.@FlaviusBG$ = "Flavius en cours.";
		else
			.@FlaviusBG$ = "";

		if( $@KvM01BG >= 5 )
			.@KvM01BG$ = "KVM dťbut "+($@KvM01BG > 0?$@KvM01BG+"s ":"")+"["+getmapusers("bat_c01")+"]";
		else if( $@KvM01BG == 2 )
			.@KvM01BG$ = "KVM actif "+($@KvM01BGTimer < 60?$@KvM01BGTimer+"s":($@KvM01BGTimer/60)+"mn")+" ["+getmapusers("bat_c01")+"]";
		else if( $@KvM01BG == 3 )
			.@KvM01BG$ = "KVM finit "+($@KvM01BGTimer > 0?$@KvM01BGTimer+"s ":"")+"["+getmapusers("bat_c01")+"]";
		else
			.@KvM01BG$ = "";

		setarray .@bgs$[0],.@TierraBG$,.@FlaviusBG$,.@KvM01BG$;
		if( .@bgs$[0] != "" || .@bgs$[1] != "" || .@bgs$[2] != "" ) {
			if( .@bgs$[.@i] == "" ) .@i++;
			if( .@bgs$[.@i] == "" ) .@i++;
			if( .@i > 2 )
				.@i = 0; 
			.@bgnote$ = .@bgs$[.@i];
		}
		else
			.@bgnote$ = "Aucun BG actif";
		
		setwaitingroomtitle(.@bgnote$),"BatRecruit";
		sleep 2500;
		.@i++;
	}
	end;
}

// Warper out
-	script	room_warper	4_F_KAFRA3,{
	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	mes "Bon,vous Ítes ťpuisť?";
	if( select("Non,pas du tout!","Oui,je veux partir!") == 1 ) close;
	close2;
	warp "SavePoint",0,0;
	end;
}
