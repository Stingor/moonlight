// MVP SWIPER
-	script	death_bbroom	4_M_DEATH,{
	deletearray .@array[0],getarraysize(.@array);
	getmapxy(.@mapname$, .@mapx, .@mapy, BL_NPC, strnpcinfo(3));
	getareaunits(BL_MOB, .@mapname$, .@mapx - 6, .@mapy - 6, .@mapx + 6, .@mapy + 6, .@array[0]);
	for( .@i = 0; .@i < getarraysize(.@array); .@i++ )
	{
		if( unitexists(.@array[.@i]) )
			unitkill .@array[.@i];
		else continue;
	}
	end;
}

