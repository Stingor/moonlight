//===== Moonlight-Destiny ==================================
//= Script pour Dead Branch Room.
//===== Par: =================================================
//= Yaro / Moonlight-Destiny Dev Team
//===== Version courrante: ===================================
//= 2.0
//===== Description: =========================================
//= Permet aux joueur d'acheter des Dead Branch
//= afin de les craquer dans la salle adequate.
//===== Commentaires: ========================================
//= 1.0 Crťation
//= 1.1a Rťcodage,nettoyage [Stingor]
//= 1.1b Correction input (min/max) [Stingor]
//= 1.1c Passage de varriable "@" ŗ ".@" [Stingor]
//= 1.2 Ajout couleurs [Kamitsu]
//= 1.3 Ajout de uniquenames [Stingor]
//= 1.4 Optimisation [Stingor]
//= 2.0 rAthena update & tweaks [Stingor]
//============================================================
gonryun,161,130,5	script	Rooms::room_gonryun	4_M_JOB_HUNTER,{
	if( #BlockMoonNpc & 16 ) {
		dispbottom "Vous bloquez le npc avec @npcblock 5 !";
		end;
	}
	if( .init == 0 ) {
		waitingroom(getmapusers("pvp_n_1-1")?"DB Room: "+getmapusers("pvp_n_1-1")+" joueur"+(getmapusers("pvp_n_1-1")==1?"":"s"):"Personne en DB"),0;
		.init = 1;
	}
	if( @instanceBB == 1 ) {
		.@room1$ = "Instance BB ROOM";
		.@room2$ = "Acceder ŗ la BB Room";
		.@room3$ = "Acceder ŗ la DB Room";
		.@room4$ = "Acceder ŗ la Test Room";
	}
	else if( lastm_warpa$ == "pvp_n_3-1" ) {
		.@room1$ = "Acceder ŗ la BB Room";
		.@room2$ = "Acceder ŗ la DB Room";
		.@room3$ = "Acceder ŗ la Test Room";
		.@room4$ = "Instance BB ROOM";
	}
	else if( lastm_warpa$ == "pvp_n_5-5" ) {
		.@room1$ = "Acceder ŗ la Test Room";
		.@room2$ = "Acceder ŗ la BB Room";
		.@room3$ = "Acceder ŗ la DB Room";
		.@room4$ = "Instance BB ROOM";
	}
	else {
		.@room1$ = "Acceder ŗ la DB Room";
		.@room2$ = "Acceder ŗ la BB Room";
		.@room3$ = "Acceder ŗ la Test Room";
		.@room4$ = "Instance BB ROOM";
	}
	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	mes "Il y a actuellement :";
	mes "- ^FF0000"+getmapusers("pvp_n_1-1")+"^000000 personne(s) dans la DB Room.";
	mes "- ^FF0000"+getmapusers("pvp_n_3-1")+"^000000 personne(s) dans la BB Room.";
	mes "- ^FF0000"+getmapusers("pvp_n_5-5")+"^000000 personne(s) dans la Test Room.";
	switch( select(.@room1$,.@room2$,.@room3$,.@room4$,"Quitter.") ) {
		case 1:
			if( .@room1$ == "Instance BB ROOM" ) {
				clear;
				goto L_enter;
			}
			if( .@room1$ == "Acceder ŗ la BB Room" ) {
				@instanceBB = 0;
				callfunc "warp_fct","pvp_n_3-1",104,71;
				end;
			}
			if( .@room1$ == "Acceder ŗ la Test Room" ) {
				@instanceBB = 0;
				callfunc "warp_fct","pvp_n_5-5",0,0;
				end;
			}
			callfunc "warp_fct","pvp_n_1-1",104,71;
			break;
		case 2:
			if( .@room2$ == "Acceder ŗ la BB Room" ) {
				@instanceBB = 0;
				callfunc "warp_fct","pvp_n_3-1",104,71;
				end;
			}
			callfunc "warp_fct","pvp_n_1-1",104,71;
			break;
		case 3:
			if( .@room3$ == "Acceder ŗ la DB Room" ) {
				@instanceBB = 0;
				callfunc "warp_fct","pvp_n_1-1",104,71;
				end;
			}
			callfunc "warp_fct","pvp_n_5-5",0,0;
			break;
		case 4:
			{
				if( .@room4$ == "Acceder ŗ la BB Room" ) {
					@instanceBB = 0;
					callfunc "warp_fct","pvp_n_3-1",104,71;
					end;
				}
				if( .@room4$ == "Acceder ŗ la Test Room" ) {
					@instanceBB = 0;
					callfunc "warp_fct","pvp_n_5-5",0,0;
					end;
				}
				clear;
L_enter:
				set .@party_id,getcharid(1);
				set .@md_name$,"Bloody Branch Cave";
				if (!.@party_id) {
					mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
					mes "Vous devez avoir une party, celŗ fais partie de la mechanique d'instance.";
					close;
				}
				switch( instance_enter(.@md_name$) ) {
					case IE_OTHER:
						mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
						mes "La ^0000ff"+.@md_name$+"^000000 ne s'ouvre pas?!";
						mes "Essayez de refaire une nouvelle party.";
						close;
					case IE_NOINSTANCE:
					case IE_NOMEMBER:
						goto L_create;
						end;
					case IE_OK:
						@instanceBB = 1;
						end;
					default:
						mes "- Vous ne pouvez entrer, demandez ŗ l'admin pourquoi XD. -";
						close;
				}
L_create:
				if( is_party_leader() == true ) {
					mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
					mes "Vous pouvez inviter des membre dans le groupe et l'instance.";
					next;
					if( instance_create(.@md_name$) < 0 ) {
						mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
						mes "Party: "+getpartyname(.@party_id)+".";
						mes "Leader: "+strcharinfo(0);
						mes "La ^0000ff"+.@md_name$+"^000000 ne s'ouvre pas?!";
						mes "Essayez de refaire une nouvelle party.";
						close;
					}
					mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
					mes "L'instance ^0000ff"+.@md_name$+"^000000 est ouverte.";
					mes "Gogogo farm.";
					close2;
					goto L_enter;
					end;
				}
				else {
					mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
					mes "Laissez le leader prendre les commandes.";
					close;
				}
			}
			break;
		default:
			mes "["+strnpcinfo(0)+"]";
			mes "Q+";
			close;
	}
	end;

OnInit:
	waitingroom(getmapusers("pvp_n_1-1")?"DB Room: "+getmapusers("pvp_n_1-1")+" joueur"+(getmapusers("pvp_n_1-1")==1?"":"s"):"Personne en DB"),0;
	.init = 1;
	end;
}

// Refresh des bulles de rooms PVP DB BB
 -	script	rooms_waiting	-1,{
	end;
OnInit:
	while( 1 ) {
		// PVP
		setwaitingroomtitle((getmapusers("pvp_n_3-5")||getmapusers("pvp_n_2-1")||getmapusers("pvp_n_4-1")||getmapusers("pvp_n_5-1"))?(getmapusers("pvp_n_3-5")+getmapusers("pvp_n_2-1")+getmapusers("pvp_n_4-1")+getmapusers("pvp_n_5-1"))+" joueur"+((getmapusers("pvp_n_3-5")+getmapusers("pvp_n_2-1")+getmapusers("pvp_n_4-1")+getmapusers("pvp_n_5-1"))==1?"":"s")+" en PVP":"Personne en PVP"),"pvpwarper_gon";
		// DB BB
		if( getmapusers("pvp_n_1-1") == 0 && getmapusers("pvp_n_3-1") )
			setwaitingroomtitle((getmapusers("pvp_n_3-1")>=1)?"BB Room: "+getmapusers("pvp_n_3-1")+" joueur"+(getmapusers("pvp_n_3-1")==1?"":"s"):"Personne :["),"room_gonryun";
		else
			setwaitingroomtitle(getmapusers("pvp_n_1-1")?"DB Room: "+getmapusers("pvp_n_1-1")+" joueur"+(getmapusers("pvp_n_1-1")==1?"":"s"):"Personne en DB"),"room_gonryun";

		sleep 5000;
	}
	end;
}

