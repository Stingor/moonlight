gonryun,46,260,3	script	Event#028	86,{

	if( #Event_Moon & 2 )
	{
		mes "["+strnpcinfo(1)+"]";
		mes "Fin d'event !";
		close;
	}
	
	if( #Event_02 < 64 )
	{
		mes "["+strnpcinfo(1)+"]";
		mes "Bein alors ?? Tu pensais griller des étapes ? :P";
		close2;
		warp getsavepoint(0),getsavepoint(1),getsavepoint(2);
		end;
	}

	if( #Event_02 != 128 ) {
		mes "["+strnpcinfo(1)+"]";
		mes "Bravo tu m'as trouvé !";
		mes "Je suis le dernier Npc.";
		next;
		mes "["+strnpcinfo(1)+"]";
		mes "Voilà les items qu'il faut me rapporter pour terminer l'event et avoir tes gains !";
		next;
	}
	mes "["+strnpcinfo(1)+"]";
	mes "- 250 Coral Reef";			// 7013
	mes "- 10 Loki's Whispers";			// 7019
	mes "- 250 Ice Cubic";				// 7066
	mes "- 250 Burning Hair";			// 7122
	mes "- 50 Slingshot";				// 7195
	mes "- 250 Tangled Chains";		// 7221
	set #Event_02,128;
	next;
	mes "["+strnpcinfo(1)+"]";
	mes "As-tu les items que je veux ?";
	next;
	if( select("Non:Oui") == 1 )
	{
		mes "["+strnpcinfo(1)+"]";
		mes "À toute à l'heure alors !";
		close;
	}
	if( countitem(7013) < 250 || countitem(7019) < 10 || countitem(7066) < 250 || countitem(7122) < 250 || countitem(7221) < 250 || countitem(7195) < 50 )
	{
		mes "["+strnpcinfo(1)+"]";
		mes "Tu n'as pas les items qu'il me faut !! Retourne les chercher !!";
		close;
	}
	mes "["+strnpcinfo(1)+"]";
	mes "Très bien tu as tous les objets !!";
	mes "Voici ce que tu gagne !!!";
	next;
	mes "["+strnpcinfo(1)+"]";
	mes "De l'experience !";
	mes "20M de zeny";
	mes "50 Speed Potions";	// 12016
	mes "30 Obb";	// 603
	mes "20 Opb";	// 617
	mes "50 Lucky Candy";	// 570
	mes "50 Gift Box";	// 644
	mes "2 Mystical Album";	// 14533
	mes "2 Starter Pack";	//13895
	mes "10 Convex mirror";	// 12132
	next;
	set #Event_02,0;
	set #Event_Moon,#Event_Moon | 2;
	mes "["+strnpcinfo(1)+"]";
	mes " \" GG ! \" ";
	delitem 7013,250;
	delitem 7019,10;
	delitem 7066,250;
	delitem 7122,250;
	delitem 7221,250;
	delitem 7195,50;
	getexp 200000,50000;
	set Zeny,Zeny + 20000000;
	getitem 12016,50;
	getitem 603,30;
	getitem 617,20;
	getitem 570,50;
	getitem 644,50;
	getitem 14533,2;
	getitem 12246,2;
	getitem 13895,2;
	getitem 12214,10;
	mapannounce "gonryun","Fin de quête pour "+strcharinfo(0)+" !",1,0xFAB145;
	close;
}
