gonryun,160,110,3	script	Event#021	86,{

	if( #Event_Moon & 2 )
	{
		mes "["+strnpcinfo(1)+"]";
		mes "Fin d'event !";
		close;
	}
	
	if( #Event_02 > 1 )
	{
		mes "["+strnpcinfo(1)+"]";
		mes "Tu as déjà trouvé le npc après moi...";
		close;
	}

	if( !#Event_02 )
	{
		mes "["+strnpcinfo(1)+"]";
		mes "Je suis le premier d'une série de 7 autres NPCs qui vont vous guider à travers Midgard dans une petite quête.";
		next;
		mes "["+strnpcinfo(1)+"]";
		mes "Chaques Npc donnerons des indices pour trouver les suivants...";
		mes "À la fin un NPC vous demandera quelques items pour clore la quête.";
		next;
		mes "["+strnpcinfo(1)+"]";
		mes "Je suis, comme tu dois t'en douter, le premier NPC qui lance la quête.";
		mes "Dans la page suivante, je vais te donner les indices pour trouver mon compère.";
		next;
	}
	mes "["+strnpcinfo(1)+"]";
	mes "^ff0000Premiers indices^000000 :";
	mes "- Au mileu de petits monstres portant des masques.";
	mes "- Perché dans un arbre.";
	mes "- D'ici je peux voir la Tour de Geffen.";
	next;
	set #Event_02, 1;
	mes "["+strnpcinfo(1)+"]";
	mes "Voilà les seuls indices que je donne, bonne chance (chasse ^^).";
	close;
}

gef_fild11,283,103,3	script	Event#022	86,{

	if( #Event_Moon & 2 )
	{
		mes "["+strnpcinfo(1)+"]";
		mes "Fin d'event !";
		close;
	}
	
	if( !#Event_02 )
	{
		mes "["+strnpcinfo(1)+"]";
		mes "Bein alors ?? Tu pensais griller des étapes ? :P";
		close2;
		warp getsavepoint(0),getsavepoint(1),getsavepoint(2);
		end;
	}

	if( #Event_02 > 2 )
	{
		mes "["+strnpcinfo(1)+"]";
		mes "Tu as déjà trouvé le npc après moi...";
		close;
	}

	if( #Event_02 != 2 )
	{
		mes "["+strnpcinfo(1)+"]";
		mes "Bravo tu m'as trouvé !";
		mes "Je suis le second Npc.";
		next;
		mes "["+strnpcinfo(1)+"]";
		mes "Voilà les prochains indices !";
		next;
	}
	mes "["+strnpcinfo(1)+"]";
	mes "^ff0000Seconds indices^000000 :";
	mes "- Des monstres demi-humain m'entourent.";
	mes "- Leur meneur est un hero de bataille.";
	mes "- On le distingue par son grand Chapeau à plumes(hat).";
	next;
	mes "["+strnpcinfo(1)+"]";
	mes "Voilà les seuls indices que je donne, bonne chance (chasse ^^).";
	set #Event_02, 2;
	close;
}

