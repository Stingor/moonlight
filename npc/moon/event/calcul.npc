//========================================================================================================
// Multiplication :
//========================================================================================================



multiplication:
		if ( $waitevent == 1 )
		{
			mes "C'est parti !";
			set @timeminute,gettime(2);
			set @timeseconde,gettime(1);
		}
		else
		{
			callfunc ("K_decompte");
		}

		callfunc ("K_multiplication");
		callfunc ("K_totaltime");

		if (@round >= 20)
		{
			if (@totaltimeminute < $recordtimeminute_m) goto newrecord_m;
			if (@totaltimeminute <= $recordtimeminute_m && @totaltimeseconde < $recordtimeseconde_m)
			{
				newrecord_m:
				callfunc ("K_resultattimerecord");

				set $recordtimeminute_m,@totaltimeminute;
				set $recordtimeseconde_m,@totaltimeseconde;
				set $recordman_m$,strcharinfo(0);

				goto recompense;
			}
		}



//========================================================================================================
// Récompense :
//========================================================================================================



	recompense_sans_record:
	callfunc ("K_resultattime");
	set $@addsousmu,0;
	set $@addsous,0;
	set $@multiplication,0;
	set $@addition,0;
	set $@soustraction,0;
	if ($waitevent == 1 )
	{
		callfunc ("K_position");
	}
	if (@faux == 0)
	{
		if  (@round >= 20)
		{
			mes .@npc$;
			mes "Voici ta récompense pour un sans faute.";
			getitem 969,1;
		}

		mes .@npc$;
		mes "Tu as fait "+@faux+" faute, pas mal du tout !";
		getitem 512,1;
	}
	else
	{
		mes .@npc$;
		mes "Tu as fait "+@faux+" faute(s) mais voila pour toi, il paraît que c'est bon pour la mémoire...";
		getitem 515,1;
	}
	close;



	recompense:
	set $@addsousmu,0;
	set $@addsous,0;
	set $@multiplication,0;
	set $@addition,0;
	set $@soustraction,0;
	mes .@npc$;
	mes "Voici ta récompense pour ce nouveau record.";
	getitem 969,5;
	if ($waitevent == 1 )
	{
		callfunc ("K_position");
	}
	if (@faux == 0)
	{
		mes .@npc$;
		mes "Tu as fait "+@faux+" faute, pas mal du tout !";

		if  (@round >= 20)
		{
			mes "Voici ta récompense pour un sans faute.";
			getitem 12103,1;
		}
	}
	else
	{
		mes .@npc$;
		mes "Tu as fait "+@faux+" faute(s) mais voila pour toi, il paraît que c'est bon pour la mémoire...";
		getitem 515,20;
	}
	close;



//========================================================================================================
// Record :
//========================================================================================================



record:
next;
menu "- Addition/Soustraction/Multiplication",record_addsousmu,"- Addition/Soustraction",record_addsous,"- Addition",record_addition,"- Soustraction",record_soustraction,"- Multiplication",record_multiplication;

	record_addsousmu:
		menu "- Facile",record_asm_facile,"- Normal",record_asm_normal,"- Difficile",record_asm_difficile,"- Trčs Difficile",record_asm_tdifficile;

			record_asm_facile:
				mes "Le record est détenu par ^0000FF"+$recordman_asm_facile$+"^000000 en ^FF0000"+$recordtimeminute_asm_facile+"^000000 minute(s) et ^FF0000"+$recordtimeseconde_asm_facile+"^000000 seconde(s)";
				goto record;

			record_asm_normal:
				mes "Le record est détenu par ^0000FF"+$recordman_asm_normal$+"^000000 en ^FF0000"+$recordtimeminute_asm_normal+"^000000 minute(s) et ^FF0000"+$recordtimeseconde_asm_normal+"^000000 seconde(s)";
				goto record;

			record_asm_difficile:
				mes "Le record est détenu par ^0000FF"+$recordman_asm_difficile$+"^000000 en ^FF0000"+$recordtimeminute_asm_difficile+"^000000 minute(s) et ^FF0000"+$recordtimeseconde_asm_difficile+"^000000 seconde(s)";
				goto record;

			record_asm_tdifficile:
				mes "Le record est détenu par ^0000FF"+$recordman_asm_tdifficile$+"^000000 en ^FF0000"+$recordtimeminute_asm_tdifficile+"^000000 minute(s) et ^FF0000"+$recordtimeseconde_asm_tdifficile+"^000000 seconde(s)";
				goto record;


	record_addsous:
		menu "- Facile",record_as_facile,"- Normal",record_as_normal,"- Difficile",record_as_difficile,"- Trčs Difficile",record_as_tdifficile;

			record_as_facile:
				mes "Le record est détenu par ^0000FF"+$recordman_as_facile$+"^000000 en ^FF0000"+$recordtimeminute_as_facile+"^000000 minute(s) et ^FF0000"+$recordtimeseconde_as_facile+"^000000 seconde(s)";
				goto record;

