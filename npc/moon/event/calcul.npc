			if (@totaltimeminute < $recordtimeminute_as_tdifficile) goto newrecord_as_tdifficile;
			if (@totaltimeminute <= $recordtimeminute_as_tdifficile && @totaltimeseconde < $recordtimeseconde_as_tdifficile)
			{
				newrecord_as_tdifficile:
				callfunc ("K_resultattimerecord");

				set $recordtimeminute_as_tdifficile,@totaltimeminute;
				set $recordtimeseconde_as_tdifficile,@totaltimeseconde;
				set $recordman_as_tdifficile$,strcharinfo(0);

				goto recompense;
			}
		}
		goto recompense_sans_record;



//========================================================================================================
