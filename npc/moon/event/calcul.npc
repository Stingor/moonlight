				mes "Le record est détenu par ^0000FF"+$recordman_as_normal$+"^000000 en ^FF0000"+$recordtimeminute_as_normal+"^000000 minute(s) et ^FF0000"+$recordtimeseconde_as_normal+"^000000 seconde(s)";
				goto record;

			record_as_difficile:
				mes "Le record est détenu par ^0000FF"+$recordman_as_difficile$+"^000000 en ^FF0000"+$recordtimeminute_as_difficile+"^000000 minute(s) et ^FF0000"+$recordtimeseconde_as_difficile+"^000000 seconde(s)";
				goto record;

			record_as_tdifficile:
