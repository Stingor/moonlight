soustraction:
		if ( $waitevent == 1 )
		{
			mes "C'est parti !";
			set @timeminute,gettime(2);
			set @timeseconde,gettime(1);
		}
		else
		{
			callfunc ("K_decompte");
		}

		callfunc ("K_soustraction");
		callfunc ("K_totaltime");

		if (@round >= 20 && @nb_max == 20)
		{
