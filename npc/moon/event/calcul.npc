function	script	K_totaltime	{
			set @timeminute2,gettime(2);
			set @timeseconde2,gettime(1);
			if (@timeminute2 < @timeminute) set @timeminute2,@timeminute2 + 60;
			if (@timeseconde2 < @timeseconde) 
			{
				set @timeseconde2,@timeseconde2 + 60;
				set @totaltimeminute,@timeminute2 - @timeminute - 1;
				goto K_totaltimee;
			}
			if (@timeminute2 == @timeminute) {set @totaltimeminute,0;goto K_totaltimee;}
			set @totaltimeminute,@timeminute2 - @timeminute;
			K_totaltimee:
			set @totaltimeseconde,@timeseconde2 - @timeseconde;
			return;
}

function	script	K_resultattime	{

//			mes "@timeminute = "+@timeminute+"";
//			mes "@timeminute2 = "+@timeminute2+"";
//			mes "@timeseconde = "+@timeseconde+"";
//			mes "@timeseconde2 = "+@timeseconde2+"";

			mes "Tu as mis ^FF0000"+@totaltimeminute+"^000000 minute(s) et ^FF0000"+@totaltimeseconde+"^000000 seconde(s)";
			return;
}

function	script	K_resultattimerecord	{
			next;
			mes "^FF0000Nouveau Record !^000000";
			mes "Tu as mis ^FF0000"+@totaltimeminute+"^000000 minute(s) et ^FF0000"+@totaltimeseconde+"^000000 seconde(s)";
			return;
}

function	script	K_menu	{
	mes .@npc$;
	mes "Combien de calcul veux tu prédéfinir ?";
	input @round;
	if (@round == 0) close;
	next;
	mes .@npc$;
	mes "Quelle difficultée ?";
	mes " ";
	mes "Entrez le chiffre 20, 50, 100 ou 1000.";
	mes " ";
	mes "Facile : chiffre entre 0 et 20";
	mes "Normal : chiffre entre 0 et 50";
	mes "Difficile : chiffre entre 0 et 100";
	mes "Trčs Difficile : chiffre entre 0 et 1000";
	input .@difficulte;
	if (.@difficulte == 0) close;
	if (.@difficulte == 20) {set @nb_max,20; goto onrepart2;}
	if (.@difficulte == 50) {set @nb_max,50; goto onrepart2;}
	if (.@difficulte == 100) {set @nb_max,100; goto onrepart2;}
	if (.@difficulte == 1000) {set @nb_max,1000; goto onrepart2;}
	else close;
	onrepart2:
	if (.@difficulte == 20) set @difficulte$,"Facile";
	if (.@difficulte == 50) set @difficulte$,"Normal";
	if (.@difficulte == 100) set @difficulte$,"Difficile";
	if (.@difficulte == 1000) set @difficulte$,"Trčs Difficile";
	return;
}

function	script	K_menuevent	{
	mes .@npc$;
	mes "Combien de calcul veux tu prédéfinir ?";
	input $round;
	if ($round == 0) close;
	next;
	mes .@npc$;
	mes "Quelle difficultée ?";
	mes " ";
	mes "Facile : chiffre entre 0 et 20";
	mes "Normal : chiffre entre 0 et 50";
	mes "Difficile : chiffre entre 0 et 100";
	mes "Trčs Difficile : chiffre entre 0 et 1000";
	mes " ";
	mes "Entrez le chiffre 20, 50, 100 ou 1000.";
	input .@difficulte;
	if (.@difficulte == 0) close;
	if (.@difficulte == 20) {set $nb_max,20; goto onrepart2;}
	if (.@difficulte == 50) {set $nb_max,50; goto onrepart2;}
	if (.@difficulte == 100) {set $nb_max,100; goto onrepart2;}
	if (.@difficulte == 1000) {set $nb_max,1000; goto onrepart2;}
	else close;
	onrepart2:
	if (.@difficulte == 20) set @difficulte$,"Facile";
	if (.@difficulte == 50) set @difficulte$,"Normal";
	if (.@difficulte == 100) set @difficulte$,"Difficile";
	if (.@difficulte == 1000) set @difficulte$,"Trčs Difficile";
	return;
}

function	script	K_npctalk	{
	npctalk "C'est parti, fait de ton mieux "+strcharinfo(0)+"!!!";
	return;
}

function	script	K_position	{
	mapannounce ""+$K_mapname$+"", "[Position "+$@kposition+"] : "+strcharinfo(0)+" avec "+@faux+" faute(s) !",bc_map,0xff0000;
	if ( $@kposition == $@participant ) {set $waitevent,0;set $@participant,0;}
	if ( $@kposition == 1 ) {}
	if ( $@kposition == 2 ) {}
	if ( $@kposition == 3 ) {}
	if ( $@kposition == 4 ) {}
	if ( $@kposition == 5 ) {}
	if ( $@kposition == 6 || $@kposition == 7 || $@kposition == 8 || $@kposition == 9 ) {}
	if ( $@kposition == 10 ) {}

	return;
}

function	script	K_decompte_event	{
	set $@kposition,0;
	set $waitevent,2;
	npctalk "L'Event commencera dans 3 minutes ...";
	Sleep2 60000;
	npctalk "Il reste 2 minutes d'attente ...";
	Sleep2 60000;
	npctalk "1 minute d'attente ...";
	Sleep2 50000;
	npctalk "Tenez vous pręt ... 10 secondes !";
	Sleep2 5000;
	npctalk "5";
	Sleep2 1000;
	npctalk "4";
	Sleep2 1000;
	npctalk "3";
	Sleep2 1000;
	npctalk "2";
	Sleep2 1000;
	npctalk "1";
	Sleep2 1000;
	set $waitevent,1;
	npctalk "PARTEZ !!!";
	return;
}
