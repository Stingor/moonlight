				goto record;


	record_addition:
		menu "- Facile",record_a_facile,"- Normal",record_a_normal,"- Difficile",record_a_difficile,"- Trčs Difficile",record_a_tdifficile;

			record_a_facile:
				mes "Le record est détenu par ^0000FF"+$recordman_a_facile$+"^000000 en ^FF0000"+$recordtimeminute_a_facile+"^000000 minute(s) et ^FF0000"+$recordtimeseconde_a_facile+"^000000 seconde(s)";
