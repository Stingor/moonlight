function	script	K_decompte	{
		next; /* Si le NPC bug aprčs un Next, il faut désactiver CE Next. Normalement il n'y a aucun problčme */
		mes "3 ...";
		Sleep2 1000;
		mes "2 ..";
		Sleep2 1000;
		mes "1 .";
		Sleep2 1000;
		mes "PARTEZ !";
		set @timeminute,gettime(2);
		set @timeseconde,gettime(1);
		return;
}



function	script	K_addsousmu	{
		if ($waitevent == 1)
		{
			for (set .@r, 1; .@r <= $round; set .@r, .@r + 1)
			{
				next;
				set .@hasard, rand(0,5);
				if (.@hasard == 0 || .@hasard == 1) goto addsousmu_addevent;	
				if (.@hasard == 2 || .@hasard == 3) goto addsousmu_muevent;	

				addsousmu_sousevent:
				set .@nombre1, rand(0,$nb_max);
				set .@nombre2, rand(0,$nb_max);
				if (.@nombre1 < .@nombre2) goto addsousmu_sousevent;
				set .@nombre3, .@nombre1 - .@nombre2;
				mes ""+.@r+"°) " + .@nombre1 + " - " + .@nombre2 + " =";
				input @nombreplayer;
			
				if (@nombreplayer == .@nombre3)
				{
					set .@vrai,.@vrai + 1;
				}
				else
				{
					while (@nombreplayer != .@nombre3)
					{
						mes "FAUX : " + .@nombre1 + " - " + .@nombre2 + " = ";
						input @nombreplayer;
						set @faux,@faux + 1;
					}
				}
				goto finn;

				addsousmu_muevent:
				set .@nombre1, rand(0,10);
				set .@nombre2, rand(0,10);
				set .@nombre3, .@nombre1 * .@nombre2;
				mes ""+.@r+"°) " + .@nombre1 + " x " + .@nombre2 + " = ";
				input @nombreplayer;
		
				if (@nombreplayer == .@nombre3)
				{
					set .@vrai,.@vrai + 1;
					}
				else
				{
						while (@nombreplayer != .@nombre3)
					{
						mes "FAUX : " + .@nombre1 + " x " + .@nombre2 + " = ";
							input @nombreplayer;
						set @faux,@faux + 1;
					}
				}
				goto finn;
	

				addsousmu_addevent:
				set .@nombre1, rand(0,$nb_max);
				set .@nombre2, rand(0,$nb_max);
				set .@nombre3, .@nombre1 + .@nombre2;
				mes ""+.@r+"°) " + .@nombre1 + " + " + .@nombre2 + " = ";
				input @nombreplayer;
			
				if (@nombreplayer == .@nombre3)
				{
					set .@vrai,.@vrai + 1;
				}
				else
				{
					while (@nombreplayer != .@nombre3)
					{
						mes "FAUX : " + .@nombre1 + " + " + .@nombre2 + " = ";
						input @nombreplayer;
						set @faux,@faux + 1;
					}
				}
				finn:
			}
			set $@kposition,$@kposition + 1;
		}
		else
		{
			for (set .@r, 1; .@r <= @round; set .@r, .@r + 1)
			{
				next;
				set .@hasard, rand(0,5);
				if (.@hasard == 0 || .@hasard == 1) goto addsousmu_add;	
				if (.@hasard == 2 || .@hasard == 3) goto addsousmu_mu;	

				addsousmu_sous:
				set .@nombre1, rand(0,@nb_max);
				set .@nombre2, rand(0,@nb_max);
				if (.@nombre1 < .@nombre2) goto addsousmu_sous;
				set .@nombre3, .@nombre1 - .@nombre2;
				mes ""+.@r+"°) " + .@nombre1 + " - " + .@nombre2 + " =";
				input @nombreplayer;
			
				if (@nombreplayer == .@nombre3)
				{
					set .@vrai,.@vrai + 1;
				}
				else
				{
					while (@nombreplayer != .@nombre3)
					{
						mes "FAUX : " + .@nombre1 + " - " + .@nombre2 + " = ";
						input @nombreplayer;
						set @faux,@faux + 1;
					}
				}
				goto fineventt;

				addsousmu_mu:
				set .@nombre1, rand(0,10);
				set .@nombre2, rand(0,10);
				set .@nombre3, .@nombre1 * .@nombre2;
				mes ""+.@r+"°) " + .@nombre1 + " x " + .@nombre2 + " = ";
				input @nombreplayer;
			
				if (@nombreplayer == .@nombre3)
				{
					set .@vrai,.@vrai + 1;
				}
				else
				{
					while (@nombreplayer != .@nombre3)
					{
						mes "FAUX : " + .@nombre1 + " x " + .@nombre2 + " = ";
						input @nombreplayer;
						set @faux,@faux + 1;
					}
				}
				goto fineventt;
	

				addsousmu_add:
				set .@nombre1, rand(0,@nb_max);
				set .@nombre2, rand(0,@nb_max);
				set .@nombre3, .@nombre1 + .@nombre2;
				mes ""+.@r+"°) " + .@nombre1 + " + " + .@nombre2 + " = ";
				input @nombreplayer;
			
				if (@nombreplayer == .@nombre3)
				{
					set .@vrai,.@vrai + 1;
				}
				else
				{
					while (@nombreplayer != .@nombre3)
					{
						mes "FAUX : " + .@nombre1 + " + " + .@nombre2 + " = ";
						input @nombreplayer;
						set @faux,@faux + 1;
					}
				}
				fineventt:
			}
		}
		return;
}



