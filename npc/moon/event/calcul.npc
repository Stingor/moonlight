//================== eAthena Script =======================================
//= Dr Kawashima
//================== By: ==================================================
//= ToZorMan (green-peach.com)
//================== Current Version: =====================================
//= 1.0
//================== Compatible With: =====================================
//=
//= eAthena SVN
//=
//================== Description: =========================================
//=
//=
//================== Additional Comments: =================================
//=
//= Avant d'utiliser le NPC, effectuez un Reset des records.
//= 
//= Record non faisable en Event.
//= 
//=========================================================================

gonryun,135,119,4	script	Dr Kamitsu	903,{



set $K_mapname$,"gonryun"; //Map d'annonce de position lors d'un Event.

set .@npc$,"[^6600CCDr Kamitsu^000000]";

set @faux,0;

if ($waitevent == 2)
{
mes .@npc$;
mes "L'Event va bientôt commencer. Tenez vous pręt !";
close;
}

if ($@addsousmu == 1) {set $@participant,$@participant+1;set @nb_max,0;set @round,0;goto addsousmu;}
if ($@addsous == 1) {set $@participant,$@participant+1;set @nb_max,0;set @round,0;goto addsous;}
if ($@addition == 1) {set $@participant,$@participant+1;set @nb_max,0;set @round,0;goto addition;}
if ($@soustraction == 1) {set $@participant,$@participant+1;set @nb_max,0;set @round,0;goto soustraction;}
if ($@multiplication == 1) {set $@participant,$@participant+1;set @nb_max,0;set @round,0;goto multiplication;}



//========================================================================================================
// Menu : Choix du Calcul + Définition du nombre de calcul (@round) et de la difficulté.
//========================================================================================================



menu_Dr_Kawashima:
mes .@npc$;
mes "Bienvenue ^0000FF"+strcharinfo(0)+"^000000";
mes "Quel Calcul veux tu faire ?.?";
mes " ";
mes "Si tu veux effectuer un Record il faut faire un minimum de 20 calculs ŕ la suite.";
next;
if (getgmlevel()<20)
{
	menu "- Addition / Soustraction / Multiplication",addsousmu_player,"- Addition / Soustraction ",addsous_player,"- Addition",addition_player,"- Soustraction",soustraction_player,"- Multiplication",multiplication_player,"- Record",record;
}
	menu "- Addition / Soustraction / Multiplication",addsousmu_player,"- Addition / Soustraction ",addsous_player,"- Addition",addition_player,"- Soustraction",soustraction_player,"- Multiplication",multiplication_player,"- Record",record,"- Faire un Event",event,"- Vérification + Reset des variables",resetvariable,"- Reset des Records",reset;

		event:
			next;
			menu "- Event Add / Sous / Multi",addsousmu_GM,"- Event Addition/Soustraction ",addsous_GM,"- Event Addition",addition_GM,"- Event Soustraction",soustraction_GM,"- Event Multiplication",multiplication_GM;

		resetvariable:
			mes "$@addsousmu = "+$@addsousmu+""; // = 1 preparation d'un event
			mes "$@addsous = "+$@addsous+""; // = 1 preparation d'un event
			mes "$@addition = "+$@addition+"";// = 1 preparation d'un event
			mes "$@soustraction = "+$@soustraction+"";// = 1 preparation d'un event
			mes "$@multiplication = "+$@multiplication+"";// = 1 preparation d'un event
			mes "$waitevent = "+$waitevent+"";// = 2 decompte NPC ---- = 1 event en cours
			mes "$@position = "+$@position+"";
			mes "$@participant = "+$@participant+"";
			mes "@round = "+@round+"";
			mes "$round = "+$round+"";
			mes "@nb_max = "+@nb_max+"";
			mes "$nb_max = "+$nb_max+"";
			next;
			menu "- Réinitialisation ŕ 0 des variables",-;
			set $waitevent,0;
			set $@participant,0;
			set $@addsousmu,0;
			set $@addsous,0;
			set $@addition,0;
			set $@soustraction,0;
			set $@multiplication,0;
			set $@position,0;
			set @round,0;
			set $round,0;
			set @nb_max,0;
			set $nb_max,0;
			close;


	addsousmu_player:
	callfunc ("K_menu");
	callfunc ("K_npctalk");
	goto addsousmu;
	
	addsousmu_GM:
	callfunc ("K_menuevent");
	close2;
	set $@addsousmu,1;
	announce "Event Addition/Soustraction/Multiplication du Dr Kawashima en "+$round+" round. Difficulté "+@difficulte$+"",bc_all;
	callfunc ("K_decompte_event");
	end;


	addsous_player:
	callfunc ("K_menu");
	callfunc ("K_npctalk");
	goto addsous;
	
	addsous_GM:
	callfunc ("K_menuevent");
	close2;
	set $@addsous,1;
	announce "Event Addition/Soustraction du Dr Kawashima en "+$round+" round. Difficulté "+@difficulte$+"",bc_all;
	callfunc ("K_decompte_event");
	end;


	addition_player:
	callfunc ("K_menu");
	callfunc ("K_npctalk");
	goto addition;

	addition_GM:
	callfunc ("K_menuevent");
	close2;
	set $@addition,1;
	announce "Event Addition du Dr Kawashima en "+$round+" round. Difficulté "+@difficulte$+"",bc_all;
	callfunc ("K_decompte_event");
	end;

	soustraction_player:
	callfunc ("K_menu");
	callfunc ("K_npctalk");
	goto soustraction;

	soustraction_GM:
	callfunc ("K_menuevent");
	close2;
	set $@soustraction,1;
	announce "Event Soustraction du Dr Kawashima en "+$round+" round. Difficulté "+@difficulte$+"",bc_all;
	callfunc ("K_decompte_event");
	end;

	multiplication_player:
	mes .@npc$;
	mes "Combien de calcul veux tu prédéfinir ?";
	input @round;
	if (@round == 0) close;
	callfunc ("K_npctalk");
	goto multiplication;

	multiplication_GM:
	mes .@npc$;
	mes "Combien de calcul veux tu prédéfinir ?";
	input $round;
	close2;
	set $@multiplication,1;
	announce "Event Multiplication du Dr Kawashima en "+@round+" round.",bc_all;
	callfunc ("K_decompte_event");
	end;


//========================================================================================================
// Calcul + Etablissement du record s'il y a :
//========================================================================================================



//========================================================================================================
// Addition/Soustraction/Multiplication :
//========================================================================================================



addsousmu:
		if ( $waitevent == 1 )
		{
			mes "C'est parti !";
			set @timeminute,gettime(2);
			set @timeseconde,gettime(1);
		}
		else
		{
			callfunc ("K_decompte");
		}

		callfunc ("K_addsousmu");
		callfunc ("K_totaltime");

		if ( @round >= 20 && @nb_max == 20)
		{
			if (@totaltimeminute < $recordtimeminute_asm_facile) goto newrecord_asm_facile;
			if (@totaltimeminute <= $recordtimeminute_asm_facile && @totaltimeseconde < $recordtimeseconde_asm_facile)
			{
				newrecord_asm_facile:
				callfunc ("K_resultattimerecord");


				set $recordtimeminute_asm_facile,@totaltimeminute;
				set $recordtimeseconde_asm_facile,@totaltimeseconde;
				set $recordman_asm_facile$,strcharinfo(0);

				goto recompense;
			}
		}

		if (@round >= 20 && @nb_max == 50)
		{
			if (@totaltimeminute < $recordtimeminute_asm_normal) goto newrecord_asm_normal;
			if (@totaltimeminute <= $recordtimeminute_asm_normal && @totaltimeseconde < $recordtimeseconde_asm_normal)
			{
				newrecord_asm_normal:
				callfunc ("K_resultattimerecord");

				set $recordtimeminute_asm_normal,@totaltimeminute;
				set $recordtimeseconde_asm_normal,@totaltimeseconde;
				set $recordman_asm_normal$,strcharinfo(0);

				goto recompense;
			}
		}

		if (@round >= 20 && @nb_max == 100)
		{
			if (@totaltimeminute < $recordtimeminute_asm_difficile) goto newrecord_asm_difficile;
			if (@totaltimeminute <= $recordtimeminute_asm_difficile && @totaltimeseconde < $recordtimeseconde_asm_difficile)
			{
				newrecord_asm_difficile:
				callfunc ("K_resultattimerecord");

				set $recordtimeminute_asm_difficile,@totaltimeminute;
				set $recordtimeseconde_asm_difficile,@totaltimeseconde;
				set $recordman_asm_difficile$,strcharinfo(0);

				goto recompense;
			}
		}

		if (@round >= 20 && @nb_max == 1000)
		{
			if (@totaltimeminute < $recordtimeminute_asm_tdifficile) goto newrecord_asm_tdifficil;
			if (@totaltimeminute <= $recordtimeminute_asm_tdifficile && @totaltimeseconde < $recordtimeseconde_asm_tdifficile)
			{
				newrecord_asm_tdifficil:
				callfunc ("K_resultattimerecord");

				set $recordtimeminute_asm_tdifficile,@totaltimeminute;
				set $recordtimeseconde_asm_tdifficile,@totaltimeseconde;
				set $recordman_asm_tdifficile$,strcharinfo(0);

				goto recompense;
			}
		}
		goto recompense_sans_record;




//========================================================================================================
// Addition/Soustraction :
//========================================================================================================



addsous:
		if ( $waitevent == 1 )
		{
			mes "C'est parti !";
			set @timeminute,gettime(2);
			set @timeseconde,gettime(1);
		}
		else
		{
			callfunc ("K_decompte");
		}

		callfunc ("K_addsous");
		callfunc ("K_totaltime");

		if ( @round >= 20 && @nb_max == 20)
		{
			if (@totaltimeminute < $recordtimeminute_as_facile) goto newrecord_as_facile;
			if (@totaltimeminute <= $recordtimeminute_as_facile && @totaltimeseconde < $recordtimeseconde_as_facile)
