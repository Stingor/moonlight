function GetColor {
	return ((checkquest(getarg(0),PLAYTIME) == 2 || checkquest(getarg(0),PLAYTIME) == -1)?"^00A000":"^FF0000");
}

Hard_Mode:
	if( is_party_leader(getcharid(1)) == true && (getgroupid() == 99 || getarg(0) != "^FF0000") ) {
		clear;
		mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
		mes "Cette instance est disponible avec plusieur niveau de difficulté, ętes vous pręts ŕ tenter?";
		return select( "Facile(1)", "Normal(2)", "Moyen(3)", "", "Difficile(5)", "", "Trčs Difficile (7)", "", "", "MALADE (10)" );
	}
	return 1;

Turbo_Mode:
	if( is_party_leader(getcharid(1)) == true && (getgroupid() == 99 || getarg(0) != "^FF0000") ) {
		clear;
		mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
		mes "Cette instance est disponible avec le mode turbo.";
		mes "^FF0000Attention!!";
		mes "une fois activé vous sauterez la plupart des dialogues!!^000000";
		if( select( "Mode turbo OFF", "Mode turbo ON" ) == 2 )
			return 1;
	}
	return 0;
	
Party_Check: // Check si une party existe bien
	if( instance_check_party(getcharid(1), 1) == 0 ) {
		clear;
		mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
		mes "^0000ff"+getarg(0)+"^000000 - Problčme de party";
		mes "Faites une party.";
		close;
	}
	return;

Leader_Check: // Pour instance Solo
	if( is_party_leader(getcharid(1)) == false ) {
		clear;
		mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
		mes "^ff0000Cette instance est ŕ faire seul. Seul le party leader peut entrer.^000000";
		close;
	}
	return;

Create_Instance: // Création instance
	.@hardmode = getarg(1,1);
	if( .@hardmode < 1 )
		.@hardmode = 1;
	.@turbo = getarg(2,0);
	if( .@turbo < 1 )
		.@turbo = 0;
	if( is_party_leader(getcharid(1)) == true ) {
		if( instance_create(getarg(0), IM_PARTY, getcharid(1), .@hardmode, .@turbo) < 1 ) {
			clear;
			mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
			mes "Party name: " + getpartyname(getcharid(1));
			mes "Character name: " + strcharinfo(0);
			mes "^0000ff" + getarg(0) + "^000000 - Création echouée!";
			close;
		}
		else {
			if( .@hardmode > 1 )
				logmes "Création de l'instance: " + getarg(0) + " niveau " + .@hardmode;
			else
				logmes "Création de l'instance: " + getarg(0);
		}
	}
	return;

Quick_Enter:
	if ( BaseLevel < 100 ) {
		mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
		mes "Vous venez ętre au moins niveau 100 pour entrer cette instance!";
		close;
	} 
	switch( instance_enter(getarg(0)) ) {
		case IE_NOMEMBER:
		case IE_NOINSTANCE:
		case IE_OTHER:
			break;
		case IE_OK:
			end;
	}
	clear;
	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	mes "^ff0000Le timer de cette instance expire ŕ 4h du matin.^000000";
	next;
	goto L_Instance;

Process_Instance:
	if( checkquest(getarg(3),PLAYTIME) == 2 )
		erasequest getarg(3); // Reset de la quest cooldown
	if( getgroupid() == 99 ) {
		if( select("bypassgm?", "non") == 1 )
		{
			callsub Create_Instance, getarg(0), getarg(1), getarg(2,0); // Création instance
			if( getarg(3,0) != 0 && isbegin_quest(getarg(3,0)))
				erasequest getarg(3);
			if( getarg(4,0) != 0 && isbegin_quest(getarg(4,0)))
				erasequest getarg(4);
			switch( instance_enter(getarg(0)) ) {
				case IE_NOMEMBER: goto L_NOMEMBER;
				case IE_NOINSTANCE: goto L_NOINSTANCE;
				case IE_OTHER: goto L_OTHER;
				case IE_OK:
					if( getarg(4,0) != 0) {
						if( isbegin_quest(getarg(4)) == 0 )
							setquest getarg(4); // Set de la quest bonus
					}
					setquest getarg(3); // Set de la quest cooldown
					end;
			}
			end;
		}
	}
	switch( checkquest(getarg(3),PLAYTIME) ) {
		case -1:
			clear;
			mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
			mes "^ff0000Si vous mourrez ou sortez vous ne pourrez plus entrer de nouveau.^000000";
			if( select("-:Ok:-") == 2 ) next;
			else close;
			callsub Create_Instance, getarg(0), getarg(1); // Création instance
			if ( BaseLevel < 100 ) {
				mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
				mes "Vous venez ętre au moins niveau 100 pour entrer cette instance!";
				close;
			} 
			switch( instance_enter(getarg(0)) ) {
				case IE_NOMEMBER: goto L_NOMEMBER;
				case IE_NOINSTANCE: goto L_NOINSTANCE;
				case IE_OTHER: goto L_OTHER;
				case IE_OK:
					if( getarg(4,0) != 0) {
						if( isbegin_quest(getarg(4)) == 0 )
							setquest getarg(4); // Set de la quest bonus
					}
					setquest getarg(3); // Set de la quest cooldown
					end;
			}
			end;
		case 0:
		case 1:
			// if( is_party_leader(getcharid(1)) == true )
				// callsub Quick_Enter,getarg(0); end;
		case 2:
			clear;
			mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
			mes "^ff0000Vous devez attendre le reset de votre instance.^000000";
			close;
	}
	end;

L_NOMEMBER:
	clear;
	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	mes "^ff0000Vous n'avez plus de party ?^000000";
	close;
L_NOINSTANCE:
	clear;
	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	mes "^ff0000L'instance ne semble pas ętre générée.^000000";
	close;
L_OTHER:
	clear;
	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	mes "Une erreur est survenue.";
	close;

L_Autre:
	clear;
	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	mes "Sélectionnez la destination de votre choix :";
	switch( select("• Forge:• Shop armement:• Eden Group:• Flame Bassin:• Mid Camp:• Seals:• Yggdrasil:• ^e64c00Menu Précédent.^000000") ) {
		case 1: warp_fct("gon_in", 94, 21); break;
		case 2: warp_fct("gon_in", 163, 23); break;
		case 3: warp_fct("moc_para01", 31, 14); break;
		case 4: warp_fct("moro_vol", 0, 0); break;
		case 5: warp_fct("mid_camp", 220, 235); break;
		case 6: warp_fct("cmd_fild02", 193, 169); break;
		case 7: warp_fct("yggdrasil01", 52, 63); break;
		default: goto L_warpa; break;
	}
	end;

L_Fields:
	clear;
	// if( #Mission_Total < 20 && getgroupid() < 60 ) {
		// mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
		// mes "Il est possible de débloquer l'access au field warper.";
		// mes "Pour celŕ vous devez effectuer 20 missions de chasse (mob ou mvp).";
