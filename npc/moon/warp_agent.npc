	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	mes "Sélectionnez le <<Field>> de votre choix :";
	switch( select( "• Amatsu (ama_fild)",
					"• Ayothaya (ayo_fild)",
					"• Bifrost (bif_fild)",
					"• Brasilis (bra_fild)",
					"• Comodo (cmd_fild)",
