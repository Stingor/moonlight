L_Rooms:
	clear;
	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	mes "Sélectionnez la salle de votre choix :";
	switch( select("• Carnage Room [ ^FF0000"+getmapusers("pvp_n_3-5")+"^000000 joueur(s) ]:• PvP Room [ ^FF0000"+getmapusers("pvp_n_4-1")+"^000000 joueur(s) ]:• Duel Room [ ^FF0000"+getmapusers("pvp_n_2-1")+"^000000 joueur(s) ]:• GvG Room [ ^FF0000"+getmapusers("pvp_n_5-1")+"^000000 joueur(s) ]:• DB Room [ ^FF0000"+getmapusers("pvp_n_1-1")+"^000000 joueur(s) ]:• BB Room [ ^FF0000"+getmapusers("pvp_n_3-1")+"^000000 joueur(s) ]:• Test Room [ ^FF0000"+getmapusers("pvp_n_5-5")+"^000000 joueur(s) ]:• ^e64c00Menu Précédent.^000000") ) {
		case 1:	// Carnage Room
			callsub Check_Buffs;
			warp_fct("pvp_n_3-5", 0, 0);
			break;
		case 2:	// PvP Room
			clear;
			mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
			mes "N'oubliez-pas que dans cette salle, battez vous de façon loyal...";
			mes "Freekill interdit et punissable.";
			mes "Fairplay oblige.";
			if( select("Entrer en PvP Room", "Non merci,j'ai peur.") == 1 ) {
				callsub Check_Buffs;
				warp_fct("pvp_n_4-1", 105, 71);
				end;
			}
			else
				goto L_warpa;
			break;
		case 3:	// Duel Room
			warp_fct("pvp_n_2-1", 105, 71);
			break;
		case 4:	// GvG Room
			clear;
			mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
			mes "N'oubliez-pas que dans cette salle, battez vous de façon loyal...";
			mes "Freekill interdit et punissable.";
			mes "Fairplay oblige.";
			if( select("Entrer en GvG Room", "Non merci,j'ai peur.") == 1 ) {
				callsub Check_Buffs;
				warp_fct("pvp_n_5-1", 105, 64);
				end;
			}
			else
				goto L_warpa;
			break;
		case 5: warp_fct("pvp_n_1-1", 104, 71); break;	// DB room
		case 6: warp_fct("pvp_n_3-1", 104, 71); break;	// BB room
		case 7: warp_fct("pvp_n_5-5", 0, 0); break;		// Test Room
		default: goto L_warpa; break;
	}
	end;

Check_Buffs:
	if( getstatus(SC_CP_WEAPON) || getstatus(SC_CP_ARMOR) || getstatus(SC_CP_SHIELD) || getstatus(SC_CP_HELM) || getstatus(SC_SPIRIT) ) {
		next;
		mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
		mes "Vous ętes sur le point d'entrer en pvp avec une protection d'Alchemist et/ou un boost Soul Linker.";
		mes "Vous allez ętre dispell de ce buff, ętes vous certain de vouloir rentrer ?";
		if( select("Non:Oui") == 1 )
			close;
		close2;
		sc_end SC_CP_WEAPON;
		sc_end SC_CP_ARMOR;
		sc_end SC_CP_SHIELD;
		sc_end SC_CP_HELM;
		sc_end SC_SPIRIT;
	}
	return;

L_Save:
	clear;
L_SaveCmd:
	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	atcommand "@save";
	mes "Ton point de sauvegarde est ŕ présent ŕ l'endroit oů tu es placé.";
	mes "Bon jeu !";
	close;

OnInit:
	if( strnpcinfo(3) == "warp_agent" ) {
		defpattern 1, "([^:]+):.*\\s@warp.*", "L_WarpaCmd";
		defpattern 1, "([^:]+):.*\\s@go.*", "L_VillesCmd";
		defpattern 1, "([^:]+):.*\\s@save.*", "L_SaveCmd";
		activatepset 1;
	}
	end;
}

