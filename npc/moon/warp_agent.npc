					"• Hugel (hu_fild)",
					"• Lasagna (lasa_fild)",
					"• Lighthalzen (lhz_fild)",
					"• Luoyang (lou_fild)",
					"• Lutie (xmas_fild)",
					"• Malaya (ma_fild)",
					"• Manuk (man_fild)",
					"• Mjolnir (mjolnir)",
					"• Moscovia (mosk_fild)",
					"• Niflheim (nif_fild)",
					"• Payon (pay_fild)",
					"• Prontera (prt_fild)",
					"• Rachel (ra_fild)",
					"• Sograt (Morocc - moc_fild)",
					"• Splendide (spl_fild)",
					"• Umbala (um_fild)",
					"• Veins (ve_fild)",
					"• Juno (yuno_fild)",
					"• ^e64c00Menu Précédent.^000000") ) {
		case 1:
			warp_fct("ama_fild01", 0, 0); break;
		case 2:
			switch( select("• ayo_fild01:• ayo_fild02") ) {
				case 1: warp_fct("ayo_fild01", 0, 0); break;
				case 2: warp_fct("ayo_fild02", 0, 0); break;
			}
			break;
		case 3:
			switch( select("• bif_fild01:• bif_fild02") ) {
				case 1: warp_fct("bif_fild01", 0, 0); break;
				case 2: warp_fct("bif_fild02", 0, 0); break;
			}
			break;
		case 4:
			warp_fct("bra_fild01", 0, 0); break;
		case 5:
			switch( select("• cmd_fild01:• cmd_fild02:• cmd_fild03:• cmd_fild04:• cmd_fild05 (Pas dispo en Renewal):• cmd_fild06:• cmd_fild07:• cmd_fild08:• cmd_fild09") ) {
				case 1:  warp_fct("cmd_fild01", 0, 0); break;
				case 2:  warp_fct("cmd_fild02", 0, 0); break;
				case 3:  warp_fct("cmd_fild03", 0, 0); break;
				case 4:  warp_fct("cmd_fild04", 0, 0); break;
				case 5:  goto L_Fields; break;
				case 6:  warp_fct("cmd_fild06", 0, 0); break;
				case 7:  warp_fct("cmd_fild07", 0, 0); break;
				case 8:  warp_fct("cmd_fild08", 0, 0); break;
				case 9:  warp_fct("cmd_fild09", 0, 0); break;
			}
			break;
		case 6:
