//===== Moonlight-Destiny ==================================
//= Script warp agent.
//===== Par: =================================================
//= Yaro / Moonlight-Destiny Dev Team
//===== Version courrante: ===================================
//= 3.1
//===== Description: =========================================
//= Permet aux joueurs de se teleporter, sauvegarder
//=	Acceder au instances.
//===== Commentaires: ========================================
//= 1.0 Creation [Stingor]
//= 1.1 Ajouter d'une save dynamique sur menu sauvegarde [Kamitsu]
//= 1.2 Ajout de Moscovia en ville+duplicate [Stingor]
//= 1.3 Correction warp aldebaran (mauvais x/y) [Stingor]
//= 1.4 Ajout couleurs [Kamitsu]
//= 1.5 Ajout de uniquenames type ::warpa_map [Stingor]
//= 1.6 Ajout de $map_pvp$ pour le switcher [Stingor]
//= 1.7 Fix au complet des warp dungeon qui ne warp pas au bon niveau [Frecky]
//= 1.8 Effacement du warp de Rebirth lab, cette map n'existe pas [Frecky]
//= 2.0 Mise ŕ jour [Stingor]
//= 2.1 Ajout support party pour thana warp+support clés
//= 2.2 Cleanup [Stingor]
//= 3.0 rAthena update & tweaks [Stingor]
//= 3.1 Ajout Fields [Stingor]
//============================================================

gonryun,165,129,3	script	Warp Agent::warp_agent	4_F_01,{
	function GetColor;

L_WarpaCmd:
	mes "[ ^1F81D4" + strnpcinfo(0) + "^000000 ]";
	mes "Bonjour ^4a8b3e" + strcharinfo(0) + "^000000 !";
	mes "Je suis le Npc qui sert ŕ se teleporter dans les villes et les donjons ainsi que de sauvegarder !";
L_warpa:
	if( lastm_warpa$ == "" && lastx_warpa == 0 && lasty_warpa == 0 )
		@lastwarp$ = "";
	else
		@lastwarp$ = "• ^51a1f3" + getmapname(lastm_warpa$) + "^000000";

	if( !getmapxy(.@map$, .@mapx, .@mapy) ) {
		if( getsavepoint(0) == .@map$ && getsavepoint(1) == .@mapx && getsavepoint(2) == .@mapy )
			.@save$ = "";
		else
			.@save$ = "• ^805bdfSauvegarder^000000";
	}
	else .@save$ = "";

	menu @lastwarp$, -,
		"• ^5ca57bVilles^000000", L_Villes,
		"• ^f28e0dDonjons^000000", L_Donjons,
		"• ^d28efdFields^000000", L_Fields,
		"• ^f08eddGuild Dungeons^000000",L_Guild_Dungeons,
		"• ^f08eedInstances^000000", L_Instance,
		"• ^c08dedAutre^000000", L_Autre,
		"• ^f279acRooms^000000", L_Rooms,
		.@save$, L_Save;
	warp_fct(lastm_warpa$, lastx_warpa, lasty_warpa);
	end;

L_Villes:
	clear;
L_VillesCmd:
	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	mes "Sélectionnez la destination de votre choix :";
	switch( select("^ff0000• Gonryun^000000",
				   "• Alberta",
				   "• Aldebaran",
				   "• Amatsu",
				   "• Ayothaya",
				   "• Brasilis",
				   "• Comodo",
				   "• Dewata",
				   "• Dicastes",
				   "• Eclage",
				   "• Einbech",
				   "• Einbroch",
				   "• Geffen",
				   "• Hugel",
				   "• Izlude",
				   "• Jawaii",
				   "• Lasagna",
				   "• Lighthalzen",
				   "• Luoyang",
				   "• Lutie",
				   "• Malangdo",
				   "• Malaya",
				   "• Manuk",
				   "• Mora",
				   "• Morocc",
				   "• Moscovia",
				   "• Niflheim",
				   "• Payon",
				   "• Prontera",
				   "• Rachel",
				   "• Rock Ridge",
				   "• Splendide",
				   "• Umbala",
				   "• Veins",
				   "• Juno",
				   "• ^e64c00Menu Précédent.^000000") ) {
		case 1:  warp_fct("gonryun",156+rand(1,5),120+rand(1,4)); break;
		case 2:  warp_fct("alberta", 50, 240); break;
		case 3:  warp_fct("aldebaran", 140, 117); break;
		case 4:  warp_fct("amatsu", 200, 110); break;
		case 5:  warp_fct("ayothaya", 207, 192); break;
		case 6:  warp_fct("brasilis", 195, 215); break;
		case 7:  warp_fct("comodo", 166, 161); break;
		case 8:  warp_fct("dewata", 200, 174); break;
		case 9:  warp_fct("dicastes01", 197, 223); break;
		case 10: warp_fct("eclage", 167, 194); break;
		case 11: warp_fct("einbech", 170, 125); break;
		case 12: warp_fct("einbroch", 65, 200); break;
		case 13: warp_fct("geffen", 120, 68); break;
		case 14: warp_fct("hugel", 96, 145); break;
		case 15: warp_fct("izlude", 128, 111); break;
		case 16: warp_fct("jawaii", 135, 202); break;
		case 17: warp_fct("lasagna", 193, 182); break;
		case 18: warp_fct("lighthalzen", 158, 92); break;
		case 19: warp_fct("louyang", 218, 115); break;
		case 20: warp_fct("xmas", 148, 131); break;
		case 21: warp_fct("malangdo", 167, 136); break;
		case 22: warp_fct("malaya", 144, 240); break;
		case 23: warp_fct("manuk", 286, 230); break;
		case 24: warp_fct("mora", 136, 91); break;
		case 25: warp_fct("morocc", 158, 93); break;
		case 26: warp_fct("moscovia", 224, 192); break;
		case 27: warp_fct("niflheim", 194, 186); break;
		case 28: warp_fct("payon", 177, 104); break;
		case 29: warp_fct("prontera", 155, 182); break;
		case 30: warp_fct("rachel", 128, 111); break;
		case 31: warp_fct("harboro1", 283, 212); break;
		case 32: warp_fct("splendide", 200, 149); break;
		case 33: warp_fct("umbala", 122, 138); break;
		case 34: warp_fct("veins", 196, 230); break;
		case 35: warp_fct("yuno", 153, 123); break;
		case 36: goto L_warpa; break;
	}
	end;

L_Guild_Dungeons:
	clear;
	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	mes "Sélectionnez la destination de votre choix :";
	switch( select("• Corridor of the Abyss - Tears of Hero",
				   "• Corridor of the Abyss - Dead Man Hill",
				   "• Corridor of the Abyss - Ancient Wind",
				   "• Corridor of the Abyss - Warrior's Way",
				   "• Greenwood Lake Guild Dungeon 1",
				   "• Greenwood Lake Guild Dungeon 2",
				   "• Luina Guild Dungeon 1",
				   "• Luina Guild Dungeon 2",
				   "• Valkyrie Guild Dungeon 1",
				   "• Valkyrie Guild Dungeon 2",
				   "• Britoniah Guild Dungeon 1",
				   "• Britoniah Guild Dungeon 2",
				   "• Arunafeltz Guild Dungeon",
				   "• Schwartzvald Guild Dungeon",
				   "• TE Subterranean Guild Dungeon 1",
				   "• TE Subterranean Guild Dungeon 2",
				   "• ^e64c00Menu Précédent.^000000") ) {
		case 1:  warp_fct("gld2_ald", 147, 155); break;
		case 2:  warp_fct("gld2_gef", 152, 118); break;
		case 3:  warp_fct("gld2_pay", 120, 130); break;
		case 4:  warp_fct("gld2_prt", 140, 132); break;
		case 5:  warp_fct("gld_dun01", 119, 93); break;
		case 6:  warp_fct("gld_dun01_2", 119, 93); break;
		case 7:  warp_fct("gld_dun02", 39, 161); break;
		case 8:  warp_fct("gld_dun02_2", 39, 161); break;
		case 9:  warp_fct("gld_dun03", 50, 44); break;
		case 10: warp_fct("gld_dun03_2", 50, 44); break;
		case 11: warp_fct("gld_dun04", 116, 45); break;
		case 12: warp_fct("gld_dun04_2", 116, 45); break;
		case 13: warp_fct("arug_dun01", 199, 195); break;
		case 14: warp_fct("schg_dun01", 200, 124); break;
		case 15: warp_fct("teg_dun01", 42, 36); break;
		case 16: warp_fct("teg_dun02", 26, 160); break;
		case 17: goto L_warpa; break;
	}
	end;

L_Instance:
	clear;
	.@hardmode = 1;
	.@party_id = getcharid(1);
	if( .@party_id < 1 ) {
		party_create("party" + gettimetick(0));
		mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
		mes "Party genérée...";
		mes "Attention, il n'est pas possible de retourner dans une instance une fois que vous l'avez quittée.";
		next;
	}
	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	mes "Sélectionnez la destination de votre choix :";
	switch( select( GetColor(15050)+"• Airship Assault (Solo & HM)^000000",
					GetColor(12278)+"• Bakonawa Lake^000000",
					GetColor(9223)+"• Bangungot Hospital 2F (HM)^000000",
					GetColor(4229)+"• Buwaya Cave (HM)^000000",
					GetColor(12347)+"• Central Laboratory^000000",
					GetColor(13185)+"• Charleston in Distess^000000",
					GetColor(7577)+"• Devil's Tower^000000",
					(instance_delay_cellar < gettimetick(2)?"^00A000":"^FF0000")+"• Endless Cellar (HM, Custom)^000000",
					GetColor(60200)+"• Endless Tower (HM)^000000",
					GetColor(12325)+"• Faceworms Nest (Solo)^000000",
					(GeffenTournament < gettimetick(2)?"^00A000":"^FF0000")+"• Gef. Magic Tour. (HM, Solo, Custom)^000000",
					GetColor(1261)+"• Ghost Palace (Solo)^000000",
					GetColor(7211)+"• Hazy Forest^000000",
					GetColor(12331)+"• Horror Toy Factory (HM)^000000",
					GetColor(15005)+"• Isle Of Bios^000000",
					GetColor(11379)+"• Last Room^000000",
					GetColor(12254)+"• Malangdo Culvert^000000",
					GetColor(9319)+"• Morse Cave^000000",
					GetColor(13182)+"• Nightmarish Jitterbug (HM)^000000",
					GetColor(3135)+"• Nydhoggur's Nest^000000",
					GetColor(4197)+"• Octopus Cave^000000",
					GetColor(12317)+"• Old Glast Heim (HM)^000000",
					GetColor(12059)+"• Orc's Memory^000000",
					GetColor(7706)+"• Room of Consciousness (HM, Solo)^000000",
					GetColor(9336)+"• Sarah and Fenrir^000000",
					GetColor(15002)+"• Sara Memory^000000",
					GetColor(3040)+"• Sealed Shrine^000000",
					GetColor(5112)+"• Wolfchev's Laboratory^000000",
					// "• Temple of Demon God^000000",
					"• ^e64c00Menu Précédent.^000000") ) {
		case 1: { // Airship Assault
			if( select( GetColor(15050)+"Acces direct^000000", "Se rendre dans le Rift" ) == 1 ) {
				.@md_name$ = "Assault on the Airship";
				.@questid = 15050; // Memorial Dungeon: Airship Assault
				callsub Party_Check,.@md_name$;
				callsub Leader_Check; // Pour instance Solo
				.@hardmode = callsub(Hard_Mode,GetColor(.@questid));
				.@turbo = callsub(Turbo_Mode,GetColor(.@questid));
				callsub Process_Instance,.@md_name$,.@hardmode,.@turbo,.@questid;
				break;
			}
			warp_fct("dali02", 139, 82); break;
		}
		case 2: { // Bakonawa Lake
			if( select( GetColor(12278)+"Acces direct^000000", "Se rendre au lac" ) == 1 ) {
				.@md_name$ = "Bakonawa Lake";
				.@questid1 = 12278; // Towards Bakonawa Lake...
				.@questid2 = 12279; // Get Rid of Bakonawa
				if( isbegin_quest(.@questid2) > 1 )
					completequest .@questid2;
				callsub Party_Check,.@md_name$;
				callsub Process_Instance,.@md_name$,.@hardmode,.@turbo,.@questid1,.@questid2;
				break;
			}
			warp_fct("ma_scene01", 172, 175); break;
		}
		case 3: { // Bangungot Hospital
			if( select( GetColor(9223)+"Acces direct^000000", "Se rendre au 1er étage" ) == 1 ) {
				.@md_name$ = "Bangungot Hospital 2F";
				.@questid1 = 9223; // Will there be Peace at the Hospital?
				.@questid2 = 9222; // Get Rid of Bangungot from Hospital 2F
				if( isbegin_quest(.@questid2) > 1 )
					completequest .@questid2;
				callsub Party_Check,.@md_name$;
				.@hardmode = callsub(Hard_Mode,GetColor(.@questid1));
				callsub Process_Instance,.@md_name$,.@hardmode,.@turbo,.@questid1,.@questid2;
				break;
			}
			warp_fct("ma_dun01", 151, 8); break;
		}
		case 4:	{ // Buwaya Cave
			.@md_name$ = "Buwaya Cave";
			.@questid = 4229; // Devil in the Cave
			callsub Party_Check,.@md_name$;
			.@hardmode = callsub(Hard_Mode,GetColor(.@questid));
			callsub Process_Instance,.@md_name$,.@hardmode,.@turbo,.@questid;
			break;
			// warp_fct("ma_fild02", 316, 317);
		}
		case 5:	{ // Central Laboratory
			if( select( GetColor(12347)+"Acces direct^000000", "Se rendre sur place" ) == 1 ) {
				.@md_name$ = "Central Laboratory";
				.@questid1 = 12347; // Trace of Laboratory Access
				.@questid2 = 12346; // Strange Ancient Science
				if( isbegin_quest(.@questid2) == 1 )
					completequest .@questid2;
				callsub Party_Check,.@md_name$;
				callsub Process_Instance,.@md_name$,.@hardmode,.@turbo,.@questid1,.@questid2;
				break;
			}
			warp_fct("verus01", 151, 150); break;
		}
		case 6:	{ // Charleston in distress
L_Charleston:
			if( select( GetColor(13185)+"Acces direct^000000", "Se rendre sur place" ) == 1 ) {
				.@md_name$ = "Charleston in Distress";
				.@questid = 13185; // Charleston Factory - Hold

				if( checkquest(13186) > -1 ) {
					getexp 1800000,600000;
					if( isbegin_quest(13184) )
						erasequest 13184;
					erasequest 13186;
					mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
					mes "Vous venez de completer des quętes!";
					next;
					goto L_Charleston;
				}

				callsub Party_Check,.@md_name$;
				callsub Process_Instance,.@md_name$,.@hardmode,.@turbo,.@questid;
				break;
			}
			warp_fct("verus04", 77, 118); break;
		}
		case 7:	{ // Devil's Tower
L_DevilTower:
			if( select( GetColor(7577)+"Acces direct^000000", "Se rendre sur place" ) == 1 ) {
				.@md_name$ = "Devil's Tower";

				callsub Party_Check,.@md_name$;

				if( checkquest(7577,PLAYTIME) == 2 )
					erasequest 7577; // Space distortion

				if( isbegin_quest(7576) > 0 ) {// instance completed
					erasequest 7571;// Tower Expedition
					erasequest 7574;// Thanatos Tower
					erasequest 7576;// Morocc castle seal
					getexp 450000,450000;
					clear;
					mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
					mes "Vous venez de completer des quętes!";
					next;
					goto L_DevilTower;
				}

				if( isbegin_quest(7574) > 0 ) { // failed after seal
					erasequest 7571;// Tower Expedition
					erasequest 7574;// Thanatos Tower
					getexp 300000,300000;
					clear;
					mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
					mes "Vous venez de completer des quętes!";
					next;
					goto L_DevilTower;
				}

				if( isbegin_quest(7571) > 0 ) {// failed at stair 2 tnm1
					erasequest 7571;// Tower Expedition
					if (isbegin_quest(7572)) erasequest 7572;// Lucile...?
					if (isbegin_quest(7573)) erasequest 7573;// Magic Swordman Thanatos
					getexp 200000,200000;
					clear;
					mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
					mes "Vous venez de completer des quętes!";
					next;
					goto L_DevilTower;
				}

				switch( checkquest(7577,PLAYTIME) ) {
					case -1:
						callsub Create_Instance,.@md_name$,.@hardmode; // Création instance
						if ( BaseLevel < 100 ) {
							mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
							mes "Vous venez ętre au moins niveau 100 pour entrer cette instance!";
							close;
						} 
						switch( instance_enter(.@md_name$) ) {
							case IE_NOMEMBER: goto L_NOMEMBER;
							case IE_NOINSTANCE: goto L_NOINSTANCE;
							case IE_OTHER: goto L_OTHER;
							case IE_OK:
								if (isbegin_quest(7569)) erasequest 7569;// Treat the injured
								if (isbegin_quest(7570)) erasequest 7570;// Destroy the demons
								setquest 7577; // Space distortion
								end;
						}
						end;
					case 0:
					case 1:
						callsub Quick_Enter,.@md_name$;
				}
				break;
			}
			warp_fct("dali02", 137, 115); break;
		}
		case 8:	{ // Endless Cellar
			.@md_name$ = "Endless Cellar";
			.instance_delay = 20 * 60 * 60; // 20h
			callsub Party_Check,.@md_name$;
			if( is_party_leader(getcharid(1)) == true && instance_delay_cellar < gettimetick(2) ) {
				mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
				mes "Cette instance est disponible avec plusieur niveau de difficulté, ętes vous pręts ŕ tenter?";
				mes "^FF0000Attention!!";
				mes "Le timer reste le męme pour chaque niveau !! Si vous échouez au 5 vous ne pourrez changer la difficulté.^000000";
				.@hardmode = select( "Facile(1)", "Normal(2)", "Moyen(3)", "", "Difficile(5)", "", "Trčs Difficile(7)", "", "", "MALADE(10)", "", "", "", "", "Mindblown(15)", "", "", "", "", "Game Over(20)" );
				callsub Create_Instance, .@md_name$, .@hardmode; // Création instance
			}
			if ( BaseLevel < 100 ) {
				mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
				mes "Vous venez ętre au moins niveau 100 pour entrer cette instance!";
				close;
			} 
			switch( instance_enter(.@md_name$) ) {
				case IE_NOMEMBER: goto L_NOMEMBER;
				case IE_NOINSTANCE: goto L_NOINSTANCE;
				case IE_OTHER: goto L_OTHER;
				case IE_OK:
					instance_delay_cellar = (gettimetick(2) + .instance_delay);
					end;
			}
			break;
			// warp_fct("e_tower", 78, 80);
		}
		case 9:	{ // Endless Tower
			.@md_name$ = "Endless Tower";
			.@questid = 60200; // Endless Tower Effect
			callsub Party_Check,.@md_name$;
			if( is_party_leader(getcharid(1)) == true && GetColor(.@questid) != "^FF0000" ) {
				mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
				mes "Cette instance est disponible avec plusieur niveau de difficulté, ętes vous pręts ŕ tenter?";
				mes "^FF0000Attention!!";
				mes "Le timer reste le męme pour chaque niveau !! Si vous échouez au 5 vous ne pourrez changer la difficulté.^000000";
				.@hardmode = select( "Facile(1)", "Normal(2)", "Moyen(3)", "", "Difficile(5)", "", "Trčs Difficile(7)", "", "", "MALADE(10)", "", "", "", "", "Mindblown(15)", "", "", "", "", "Game Over(20)" );
			}
			callsub Process_Instance,.@md_name$,.@hardmode,.@turbo,.@questid;
			break;
			// warp_fct("e_tower", 72, 112);
		}
		case 10: { // Faceworm's Nest
			if( select( GetColor(12325)+"Acces direct^000000", "Se rendre sur place" ) == 1 ) {
				.@md_name$ = "Faceworm's Nest";
				.@questid = 12325; // Faceworm's Nest after-effects
				callsub Party_Check,.@md_name$;
				callsub Leader_Check; // Pour instance Solo
				callsub Process_Instance,.@md_name$,.@hardmode,.@turbo,.@questid;
				break;
			}
			warp_fct("dali", 85, 64); break;
		}
		case 11: { // Geffen Magic Tournament
			if( select( (GeffenTournament < gettimetick(2)?"^00A000":"^FF0000")+"Acces direct^000000", "Se rendre sur place" ) == 1 ) {
				.@md_name$ = "Geffen Magic Tournament";
				callsub Party_Check,.@md_name$;
				callsub Leader_Check; // Pour instance Solo

				if( checkquest(9309) != -1 ) {
					for( .@i = 9284; .@i <= 9314; .@i++ )
						if( checkquest(.@i) != -1 )
							erasequest .@i;

					if( checkquest(9315) != -1 )
						changequest 9315,9316;
				}

				if( checkquest(9308) != -1 ) {
					for( .@i = 9284; .@i <= 9314; .@i++ )
						if( checkquest(.@i) != -1 )
							erasequest .@i;

					if (checkquest(9315) != -1)
						changequest 9315,9316;
				}

				if( GeffenTournament < gettimetick(2) ) {
					for (.@i = 9284; .@i <= 9314; .@i++)
						if( checkquest(.@i) != -1 )
							erasequest .@i;
					clear;
					mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
					mes "Cette instance est disponible avec plusieur niveau de difficulté, ętes vous pręts ŕ tenter?";
					mes "^FF0000Attention!!";
					mes "Le timer reste le męme pour chaque niveau !! Si vous échouez au 5 vous ne pourrez changer la difficulté.^000000";
					.@hardmode = select( "Facile(1)", "Normal(2)", "Moyen(3)", "", "Difficile(5)", "", "Trčs Difficile(7)", "", "", "MALADE(10)" );
					callsub Create_Instance,.@md_name$,.@hardmode; // Création instance
					if ( BaseLevel < 100 ) {
						mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
						mes "Vous venez ętre au moins niveau 100 pour entrer cette instance!";
						close;
					} 
					switch( instance_enter(.@md_name$) ) {
						case IE_NOMEMBER: goto L_NOMEMBER;
						case IE_NOINSTANCE: goto L_NOINSTANCE;
						case IE_OTHER: goto L_OTHER;
						case IE_OK:
						GeffenTournament = gettimetick(2) + 72000; // 20h
						if( checkquest(9316,PLAYTIME) != -1 )
							erasequest 9316;
						setquest 9316;
						end;
					}
				}
				else {
					clear;
					mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
					mes "Vous devez attendre la fin du cooldown.";
					.@time = GeffenTournament - gettimetick(2);
					.@sec = .@time % 60;
					.@min = (.@time / 60) % 60;
					.@hrs = (.@time / 3600) % 24;
					mes "Cooldown: ^3355FF"+(.@hrs < 10 ? "0" : "")+.@hrs+":"+(.@min < 10 ? "0" : "")+.@min+":"+(.@sec < 10 ? "0" : "")+.@sec+"^000000";
					end;
				}
				break;
			}
			warp_fct("dali", 94, 141); break;
