OnLoDDead:
	query_sql("UPDATE `char` SET mvp_count = mvp_count + 1 WHERE `char_id` = '"+getcharid(0,strcharinfo(0))+"'");
	if( Mission_MVP != #Mission_Count_MVP && Mission_MVP_ID > 1) {
		if( killedrid == .mvps[Mission_MVP_ID-2] ) {
			Mission_MVP = 1;
			dispbottom "[Chasse MVP] Vous avez tué le MVP pour votre mission retournez voir Chuck !";
		}
	}
	killmonster "niflheim",strnpcinfo(3)+"::OnInvasionMonsters";
	initnpctimer;
OnInvasionMonsters:
	end;
}
