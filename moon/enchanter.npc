				close;
			}
			mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
			mes "Je peux retirer l'enchantement sans toucher au ^ff0000 refine et les cards. L'équippement ne sera pas détruit!^000000";
			next;
			if( select( "Non merci...", "Payer 150000z" ) == 1 ) {
				mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
				mes "Oh ok.";
				next;
				goto L_menu;
			}
			if( Zeny < 150000 ) {
				mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
				mes "Désolé mais tu n'as pas l'argent nécessaire!";
				close;
			}
			if( !getequipisequiped(EQI_HAND_R) ) {
				mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
				mes "Mais attend t'as pas d'arme en faite!?";
				close;
			}
			specialeffect2 EF_REPAIRWEAPON;
			mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
			mes "L'enchantement est maintenant retiré.";
			Zeny -= 150000;

			// anti-hack
			if( callfunc("F_IsEquipIDHack", EQI_HAND_R, .@equip_id) ||
				callfunc("F_IsEquipRefineHack", EQI_HAND_R, .@equip_refine) ||
				callfunc("F_IsEquipCardHack", EQI_HAND_R, .@equip_card[0], .@equip_card[1], .@equip_card[2], .@equip_card[3]) )
				close;

			.@logmes$ = "Enchantement Reset: " + logequip(EQI_HAND_R);
			delequip EQI_HAND_R;

			// GetNonSlotItemSock2 .@equip_refine .@equip_id .@equip_card[0] .@equip_card[1] .@equip_card[2] .@equip_card[3]
			for( .@i = getiteminfo(.@equip_id,10); .@i < MAX_SLOTS; .@i++ ) {
				if( callfunc("F_IsCharm",.@equip_card[.@i]) == true )
					.@equip_card[.@i] = 0;// Armor Enchant System
			}
			getitem2 .@equip_id,1,1,.@equip_refine,0,.@equip_card[0],.@equip_card[1],.@equip_card[2],.@equip_card[3];
			equip .@equip_id;
			logmes .@logmes$ + " [UID:"+getequipuniqueid(EQI_HAND_R)+"]";
			next;
			goto L_menu;
		}
	}
	else {
L_fastoff:
		if( Zeny >= 400000 ) {
			if( !@fastenchant ) {
				@menufastench$ = "Activer le fast enchant";
				mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
				mes "Je recherche des moyens d'améliorer les armures en renforçant leurs pouvoirs.";
				next;
				mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
				mes "J'ai développé une compétence extraordinaire qui permet d'insuffler dans les slots d'une armure un pouvoir permettant de développer certaines statistiques.";
				next;
				mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
				mes "Mais si vous voulez utiliser mes services, vous devrez bien garder ŕ l'esprit que si vous avez deux armures du męme type dans votre inventaire, seule la premičre sera enchantée.";
				next;
				mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
				mes "Et dans ce cas, ça pourrait vouloir dire que l'armure que vous ne vouliez pas pourrait ętre enchantée ŕ la place de la bonne. Alors si vous ne voulez pas risquer que ça arrive, ne portez sur vous ^5555ffqu'un seul exemplaire^000000 de l'armure que vous désirez enchanter...";
				next;
				mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
				mes "Je ne serai pas responsable de ce qui pourrait arriver si vous en aviez plusieurs du męme type dans votre inventaire.";
				next;
			}
L_faston:
			if( @lastarmorenchant ) .@lastarmor$ = "Derničre armure enchantée "+getitemname(@lastarmorenchant)+".";
			else .@lastarmor$ = "";
			if( @fastenchant )
				@menufastench$ = "Désactiver le fast enchant";
			switch( select(.@lastarmor$,"Armure sans slot","Armure avec un slot","Armure de haute facture",@menufastench$) ) {
				case 1:
					callsub S_EnchantArmor,@lastarmorenchant,@lastarmorrate;
					end;
				case 2:
					setarray .@Items[0],2307,2309,2314,2316,2321,2325,2327,2328,2330,2332,2334,2335,2341,2344,2346,2348,2350,2337,2386,2394,2395,2396;
					.@j = 50;
					break;
				case 3:
					setarray .@Items[0],2311,2318,2319,2320,2308,2310,2315,2317,2322,2324,2326,2331,2333,2336,2342,2345,2347,2349,2351;
					.@j = 55;
					.@k = 1;
					break;
				case 4:
					setarray .@Items[0],2364,2365,2391,2374,2375,2376,2377,2378,2379,2380,2381,2382,2387,2388,2389,2390;
					.@j = 60;
					break;
				case 5:
					if( !@fastenchant ) {
						@fastenchant = 1;
						goto L_faston;
					}
					else {
						@fastenchant = 0;
						goto L_fastoff;
					}
					break;
			}
			.@menu$ = "";
			for( .@i = 0; .@i < getarraysize(.@Items); .@i = .@i+1)
				.@menu$ = .@menu$+getitemname(.@Items[.@i])+((.@k)?" [1]":"")+":";
				callsub S_EnchantArmor, .@Items[select(.@menu$)-1], .@j;
			end;
		}
		else {
			mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
			mes "J'ai pour tâche d'enchanter les armures. Pour le dire simplement, j'étudie le moyen de les améliorer.";
			next;
			mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
			mes "Si jamais vous vouliez enchanter votre armure, il faudrait que vous m'apportiez 400,000 zenys ainsi que l'armure que sur laquelle vous voudriez que je travaille, et je m'y mettrai.";
			close;
		}

S_EnchantArmor:
		@lastarmorenchant = getarg(0);
		@lastarmorrate = getarg(1);
		.@itemid = getarg(0);
		.@failrate = getarg(1);
		.@supzeny = 600000;
		if( countitem(.@itemid) == 1 && !getequipcardcnt(EQI_ARMOR) && getequipid(EQI_ARMOR) == .@itemid ) {
			mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
			
			if( !@fastenchant ) {
				mes "L'enchantement des armures coűte 400,000 zenys. Le bonus généré est aléatoire, et bien sűr il y a une chance pour cela échoue et que votre armure soit détruite.";
				next;
				mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
				mes "Tout d'abord, et avant tout, ^ff5555le Taux de Raffinage actuel de l'armure ainsi que les Cartes qui y sont attachées seront perdues.^000000";
				mes "Voulez-vous enchanter votre armure malgré cela?";
				if( select("Hum... Je vais y réfléchir.:Allez-y.") == 1 ) {
					clear;
					mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
					mes "Eh bien, je dois dire que je comprends. La sécurité d'abord, hein?";
					mes "Passez une bonne "+ ( isday() ? "journée" : "soirée" ) +".";
					close;
				}
				clear;
				mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
				mes "Bon avec un petit pot de vin de ^5555ff600.000z^000000 supplementaire, je peux vous garantir un enchantement.";
				mes "Ca vous interesse ?";
			}
			else
				mes "Payer les "+.@supzeny+"z ?";

			if( select("Oui","Non") == 2 )
				.@supzeny = 0;

			if( Zeny < (400000 + .@supzeny) ) {
				clear;
				mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
				mes "Oh, désolé mais vous n'avez pas assez de Zenys sur vous!";
				close;
			}
			close2;
			specialeffect2 EF_MAPPILLAR;
			Zeny -= 400000 + .@supzeny;
			if( @fastenchant )
				progressbar "ffff00",1;
			else
				progressbar "ffff00",3;
			.@logmes$ = "Enchantement Armor: " + logequip(EQI_ARMOR) + " -> " + getitemname(.@addpart);
			delequip EQI_ARMOR;
L_rerand:
			switch( rand(1, .@failrate) ) {
				case 1: .@addpart = 4702;break;
				case 2: .@addpart = 4712;break;
				case 3: .@addpart = 4722;break;
				case 4: .@addpart = 4732;break;
				case 5: .@addpart = 4742;break;
				case 6: .@addpart = 4752;break;
				case 7:
				case 8: .@addpart = 4701;break;
				case 9:
				case 10: .@addpart = 4711;break;
				case 11:
				case 12: .@addpart = 4721;break;
				case 13:
				case 14: .@addpart = 4731;break;
				case 15:
				case 16: .@addpart = 4741;break;
				case 17:
				case 18: .@addpart = 4751;break;
				case 19:
				case 20:
				case 21: .@addpart = 4700;break;
				case 22:
				case 23:
				case 24: .@addpart = 4710;break;
				case 25:
				case 26:
				case 27: .@addpart = 4720;break;
				case 28:
				case 29:
				case 30: .@addpart = 4730;break;
				case 31:
				case 32:
				case 33: .@addpart = 4740;break;
				case 34:
				case 35:
				case 36: .@addpart = 4750;break;
				default:
					if( .@supzeny == 600000 )
						goto L_rerand;
					specialeffect2 EF_PHARMACY_FAIL;
					mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
					mes "Oh, quel dommage! Je n'ai pas pu enchanter l'armure comme vous le vouliez.";
					logmes "Enchantement Armor fail: " + logequip(EQI_ARMOR);
					close;
			}
			npctalk "Houuuah!! "+getitemname(.@itemid)+" reçois "+getitemname(.@addpart), "", bc_self;
			getitem2 .@itemid, 1, 1, 0, 0, 0, 0, 0, .@addpart;
			equip .@itemid;
			logmes .@logmes$ + " [UID:"+getequipuniqueid(EQI_ARMOR)+"]";
			if( Zeny >= 400000 )
				goto L_faston;
			else
				end;
		}
		else {
			mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
			mes "Hein? Mais qu'est-ce que vous voulez que j'enchante?";
			mes	"Revenez avec un, et un seul exemplaire de l'armure sur laquelle je devrai travailler et equippez lŕ!";
			mes	"Retirez aussi la card bon sang!!";
			close;
		}
	}
}

malangdo,213,167,4	duplicate(enchant_gon)	Mayomayo::malangdodup	4_CAT_3COLOR
