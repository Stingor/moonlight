				callfunc("F_IsEquipCardHack", EQI_HAND_R, .@equip_card[0], .@equip_card[1], .@equip_card[2], .@equip_card[3]))
				close;

				 if (.@equip_card[3] == 0 && .@enclimit == 1) .@equip_card[3] = .@enchant;
			else if (.@equip_card[3] == 0 && .@enclimit >= 2) .@equip_card[3] = .@enchant;
			else if (.@equip_card[2] == 0 && .@enclimit >= 2) .@equip_card[2] = .@enchant;
			else {
				clear;
				mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
				mes "Cette arme est au max d'enchantement !";
				close;
			}
			if( .@enchant == 9 ) {	//  Should never happen.
				specialeffect2 EF_SUI_EXPLOSION;
				mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
				mes "Oh my god!";
				logmes "Enchantement Fail: " + logequip(EQI_HAND_R);
				delitem .@coin[.@coin_select],.@total[.@coin_select];
				delequip EQI_HAND_R;
				close;
			}
			specialeffect2 EF_REPAIRWEAPON;
			mes "...";
			mes "J'ai enchanté le ^990000slot "+.@socket+"^000000 de cette arme.";
			delitem .@coin[.@coin_select], .@total[.@coin_select];
			.@logmes$ = "Enchantement Arme: " + logequip(EQI_HAND_R) + " -> [Slot #" + .@socket + "] " + getitemname(.@equip_card[.@socket - 1]);
			npctalk "Houuuah!! "+getitemname(.@equip_id)+" reçois "+getitemname(.@equip_card[.@socket - 1]), "", bc_self;
			delequip EQI_HAND_R;
			// GetNonSlotItemSock2 .@equip_refine .@equip_id .@equip_card[0] .@equip_card[1] .@equip_card[2] .@equip_card[3]
			getitem2 .@equip_id,1,1,.@equip_refine,0,.@equip_card[0],.@equip_card[1],.@equip_card[2],.@equip_card[3];
			equip .@equip_id;
			logmes .@logmes$ + " [UID:"+getequipuniqueid(EQI_HAND_R)+"]";
			close;
		}
		else if( .@select == 2 ) {
			clear;
