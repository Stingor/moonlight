-	script	#alootid2	-1,{

OnInit:
	.enable_login_autoload = 1;
	.max_alootid_group = 10;
	.max_alootid_item = 50;
	bindatcmd("alootid2", strnpcinfo(3)+"::OnCommand");
	end;

OnCommand:
	.@cid = getcharid(0);
	.@alootid_group = atoi(.@atcmd_parameters$[1]);

	if (!.@atcmd_numparameters) {
		dispbottom "Usage: "+.@atcmd_command$+" list";
		dispbottom "Usage: "+.@atcmd_command$+" load <#>";
		dispbottom "Usage: "+.@atcmd_command$+" save <#> <item1> ... <item"+.max_alootid_item+">";
		dispbottom "Usage: "+.@atcmd_command$+" set <#> name <name>";
		if (.enable_login_autoload)
			dispbottom "Usage: "+.@atcmd_command$+" set <#> autoload <1/0>";
	}
	else if (.@atcmd_parameters$[0] == "save") {
		if (!.@alootid_group || .@alootid_group <= 0 || .@alootid_group > .max_alootid_group) {
			dispbottom "Usage: "+.@atcmd_command$+" save <"+.@alootid_group+"> - invalid no "+.@alootid_group+". (min: 1, max: "+.max_alootid_group+")";
		}
		else {
			for (.@i = 2; .@i < .@atcmd_numparameters; .@i++) {
				.@nameid = atoi(.@atcmd_parameters$[.@i]);
				if (getitemname(.@nameid) != "null")
					.@sql$ = .@sql$ + ((.@i >= 3) ? ", ":"") + "("+.@cid+", "+.@alootid_group+", "+.@nameid+")";
			}
			if (.@sql$ == "") {
				dispbottom "Usage: "+.@atcmd_command$+" save <"+.@alootid_group+"> - save failed.";
			}
			else {
				query_sql("DELETE FROM `alootid` WHERE `cid` = "+.@cid+" AND `no` = "+.@alootid_group);
				query_sql("INSERT INTO `alootid` (`cid`,`no`, `nameid`) VALUES " + .@sql$);
				dispbottom "Usage: "+.@atcmd_command$+" save <"+.@alootid_group+"> - save successfully.";
			}
		}
	}
	else if (.@atcmd_parameters$[0] == "load") {
		if (!.@alootid_group || .@alootid_group <= 0 || .@alootid_group > .max_alootid_group) {
			dispbottom "Usage: "+.@atcmd_command$+" load <"+.@alootid_group+"> - invalid no "+.@alootid_group+".";
		}
		else {
			.@size = query_sql("SELECT `nameid` FROM `alootid` WHERE `cid` = "+.@cid+" AND `no` = "+.@alootid_group+" LIMIT "+.max_alootid_item, .@nameid);
			if (!.@size) {
				dispbottom "Usage: "+.@atcmd_command$+" load <"+.@alootid_group+"> - settings not found.";
			}
			else {
				atcommand("@alootid reset");
				for (.@i = 0; .@i < .@size; .@i++)
					atcommand("@alootid +"+.@nameid[.@i]);
				dispbottom "Usage: "+.@atcmd_command$+" load <"+.@alootid_group+"> - loaded successfully.";
			}
		}
	}
	else if (.@atcmd_parameters$[0] == "list") {
		.@size = query_sql("SELECT `no`, `name`, `auto`, GROUP_CONCAT(nameid SEPARATOR ', ') FROM `alootid` WHERE `cid` = "+.@cid+" GROUP BY `name`, `no` LIMIT "+.max_alootid_group, .@no, .@name$, .@auto, .@nameid_list$);
		for (.@i = 0; .@i < .@size; .@i++) {
			dispbottom "Group <"+.@no[.@i]+"> "+.@name$[.@i]+" - "+.@nameid_list$[.@i] + (.enable_login_autoload && .@auto[.@i]? " (autoload)":"");
		}
		dispbottom "Usage: "+.@atcmd_command$+" list - found "+.@size+" settings.";
	}
	else if (.@atcmd_parameters$[0] == "set") {
		if (!.@alootid_group || .@alootid_group <= 0 || .@alootid_group > .max_alootid_group) {
			dispbottom "Usage: "+.@atcmd_command$+" set <"+.@alootid_group+"> - invalid no "+.@alootid_group+".";
		}
		else if (.@atcmd_parameters$[2] == "name") {
			query_sql("UPDATE `alootid` SET `name` = '"+escape_sql(.@atcmd_parameters$[3])+"' WHERE `cid` = "+.@cid+" AND `no` = "+.@alootid_group);
			dispbottom "Usage: "+.@atcmd_command$+" set <"+.@alootid_group+"> name '"+.@atcmd_parameters$[3]+"' successfully.";
		}
		else if (.enable_login_autoload && .@atcmd_parameters$[2] == "autoload") {
			query_sql("UPDATE `alootid` SET `auto` = CASE WHEN `no` = "+.@alootid_group+" THEN "+(atoi(.@atcmd_parameters$[3]) > 0)+" ELSE 0 END WHERE `cid` = "+.@cid);
			dispbottom "Usage: "+.@atcmd_command$+" set <"+.@alootid_group+"> autoload '"+((atoi(.@atcmd_parameters$[3]) > 0) ? "enabled":"disabled")+"' successfully.";
		}
		else {
			dispbottom "Usage: "+.@atcmd_command$+" set <"+.@alootid_group+"> invalid options.";
			dispbottom "Usage: "+.@atcmd_command$+" set <"+.@alootid_group+"> name <name>";
			if (.enable_login_autoload)
				dispbottom "Usage: "+.@atcmd_command$+" set <"+.@alootid_group+"> autoload <1/0>";
		}
	}
	else {
		dispbottom "Usage: "+.@atcmd_command$+" invalid options.";
	}
	end;
OnPCLoginEvent:
	if (.enable_login_autoload) {
		addtimer 1000, strnpcinfo(3)+"::OnAutoLoad";
	}
	end;

OnAutoLoad:
	if (.enable_login_autoload) {
		.@size = query_sql("SELECT `no`, `nameid` FROM `alootid` WHERE `cid` = "+getcharid(0)+" AND `auto` = 1 LIMIT "+.max_alootid_item, .@alootid_group, .@nameid);
		if (.@size) {
			atcommand("@alootid reset");
			for (.@i = 0; .@i < .@size; .@i++)
				atcommand("@alootid +"+.@nameid[.@i]);
			dispbottom "Usage: @alootid2 load <"+.@alootid_group+"> - loaded successfully.";
		}
	}
	end;
}

-	script	searchid	-1,{
	function SearchStorage;
	function ClearVars;

OnAtcommand:
	accountid = getcharid(3);
	charid = getcharid(0);
	.@itemid = .@atcmd_parameters$[0];
	if( .@atcmd_command$ == "@deepsearchid" )
		.@deep = 1;

	//Si aucun id n'est renseignée
	if( .@atcmd_parameters$[0] == "" || .@itemid < 500 )
	{
	   dispbottom "Merci de specifier un itemID uniquement, aucune lettre possible ( @searchid <Item ID> )";
	   end;
	}
	.@itemname$ = getitemname(.@itemid);
	//Si l'id n'existe pas
	if( .@itemname$ == "" || .@itemname$ == "null" )
	{
		dispbottom "Cet ItemID n'existe pas !";
		end;
	}
	else
	{ //Si tout est ok on query
		dispbottom "[ Recherche de "+.@itemname$+" ("+.@itemid+") ]",0xF0FF0F;
		// Dans l'inventaire - sd->inventory
		showscript "Recherche dans l'inventaire", accountid, SELF;
		progressbar "FFFFFF",1;
		.@nbi = countitem(.@itemid);
		if( .@nbi > 0 )
			dispbottom "[ "+.@nbi+" dans votre inventaire ! ]",0xF0FF0F;
		if( .@deep && getiteminfo( .@itemid, ITEMINFO_TYPE ) == IT_CARD )
		{
			ClearVars();
			getinventorylist();
			if( @inventorylist_count > 0 ) {
				showscript "Recherche dans les slots d'items de l'inventaire", accountid, SELF;
				progressbar "FFFFFF",1;
				.@it = 0;
				
				for( .@i = 0; .@i < @inventorylist_count; ++.@i )
				{
					.@nb = 0;
					if( getitemslots(@inventorylist_id[.@i]) == 0) continue;
					if( @inventorylist_card0[.@i] == .@itemid) .@nb++;
					if( @inventorylist_card1[.@i] == .@itemid) .@nb++;
					if( @inventorylist_card2[.@i] == .@itemid) .@nb++;
					if( @inventorylist_card3[.@i] == .@itemid) .@nb++;
					if( @inventorylist_card0[.@i] == .@itemid ||
						@inventorylist_card1[.@i] == .@itemid ||
						@inventorylist_card2[.@i] == .@itemid ||
						@inventorylist_card3[.@i] == .@itemid)
					{
						.@flaggeditemid[.@it] = @inventorylist_id[.@i]; // Cet item contient 1 ou plus de la card / gem recherchée.
						.@flaggeditemeq[.@it] = @inventorylist_equip[.@i]; // Cet item est peut-ętre équipé
						.@flaggeditemnb[.@it] = .@nb; // nb de card contenu
						.@flaggeditemrefine[.@it] = @inventorylist_refine[.@i]; // niveau de refine
						.@it++;
						.@nbi += .@nb;
					}
				}
				if( getarraysize(.@flaggeditemid) > 0 )
				{
					dispbottom "[ Contenu dans du stuff de l'inventaire ]",0xF0FF0F;
					for (.@i = 0; .@i < getarraysize(.@flaggeditemid); ++.@i) {
						dispbottom "| "+(.@flaggeditemrefine[.@i]>0?"+"+.@flaggeditemrefine[.@i]+" ":"")+""+getitemname(.@flaggeditemid[.@i])+""+(.@flaggeditemeq[.@i]?" qui est équipé":"")+" en contient "+.@flaggeditemnb[.@i]+" !";
						sleep2 100;
					}
				}
			}
		}

		// Dans le storage - sd->storage.stor_id == 0
		.@nb1 = SearchStorage(.@itemid, accountid, 0, .@deep);

		// Dans le storage1 - sd->premiumStorage.stor_id == 1
		.@nb2 = SearchStorage(.@itemid, accountid, 1, .@deep);

		// Dans le storage2 - sd->premiumStorage.stor_id == 2
		.@nb3 = SearchStorage(.@itemid, accountid, 2, .@deep);

		// Dans le storage3 - sd->premiumStorage.stor_id == 3
		.@nb4 = SearchStorage(.@itemid, accountid, 3, .@deep);

		// Dans le storage4 - sd->premiumStorage.stor_id == 4
		.@nb5 = SearchStorage(.@itemid, accountid, 4, .@deep);

		// Dans le storage5 - sd->premiumStorage.stor_id == 5
		.@nb6 = SearchStorage(.@itemid, accountid, 5, .@deep);

		// Dans la charette - sd->cart
		if( checkcart() )
		{
			showscript "Recherche dans le cart", accountid, SELF;
			progressbar "FFFFFF",1;
			.@nbc = cartcountitem(.@itemid);
			if( .@nbc > 0 )
				dispbottom "[ "+.@nbc+" dans votre charette !",0xF0FF0F;
			if( .@deep && getiteminfo( .@itemid, ITEMINFO_TYPE ) == IT_CARD )
			{
				ClearVars();
				getcartlist();
				if( @cartlist_count > 0 )
				{
					showscript "Recherche dans les slots d'items du cart", accountid, SELF;
					progressbar "FFFFFF",1;
					.@it = 0;
					
					for (.@i = 0; .@i < @cartlist_count; ++.@i)
					{
						.@nb = 0;
						if( @cartlist_id[.@i] > 0 && getitemslots(@cartlist_id[.@i]) == 0) continue;
						if( @cartlist_card0[.@i] == .@itemid) .@nb++;
						if( @cartlist_card1[.@i] == .@itemid) .@nb++;
						if( @cartlist_card2[.@i] == .@itemid) .@nb++;
						if( @cartlist_card3[.@i] == .@itemid) .@nb++;
						if( @cartlist_card0[.@i] == .@itemid ||
							@cartlist_card1[.@i] == .@itemid ||
							@cartlist_card2[.@i] == .@itemid ||
							@cartlist_card3[.@i] == .@itemid)
						{
							.@flaggeditemid[.@it] = @cartlist_id[.@i]; // Cet item contient 1 ou plus de la card / gem recherchée.
							.@flaggeditemnb[.@it] = .@nb; // nb de card contenu
							.@flaggeditemrefine[.@it] = @cartlist_refine[.@i]; // niveau de refine
							.@it++;
							.@nbc += .@nb;
						}
					}
					if( getarraysize(.@flaggeditemid) > 0 )
					{
						dispbottom "[ Contenu dans du stuff du cart ]",0xF0FF0F;
						for (.@i = 0; .@i < getarraysize(.@flaggeditemid); ++.@i)
						{
							dispbottom "| "+(.@flaggeditemrefine[.@i]>0?"+"+.@flaggeditemrefine[.@i]+" ":"")+""+getitemname(.@flaggeditemid[.@i])+" en contient "+.@flaggeditemnb[.@i]+" !";
							sleep2 100;
						}
					}
				}
			}
		}

		// Dans le guild storage - sd->guild
		if( getcharid(2) )
		{
			showscript "Recherche dans le guild storage", accountid, SELF;
			progressbar "FFFFFF",1;
			.@nbg = guildstoragecountitem(.@itemid);
			if( .@nbg > 0 )
				dispbottom "[ "+.@nbg+" dans votre guild storage !",0xF0FF0F;
			if( .@deep && getiteminfo( .@itemid, ITEMINFO_TYPE ) == IT_CARD )
			{
				ClearVars();
				getguildstoragelist();
				if( @guildstoragelist_count > 0 )
				{
					showscript "Recherche dans les slots d'items du guild storage", accountid, SELF;
					progressbar "FFFFFF",1;
					.@it = 0;
					
					for (.@i = 0; .@i < @guildstoragelist_count; ++.@i)
					{
						.@nb = 0;
						if( @guildstoragelist_id[.@i] > 0 && getitemslots(@guildstoragelist_id[.@i]) == 0) continue;
						if( @guildstoragelist_card0[.@i] == .@itemid) .@nb++;
						if( @guildstoragelist_card1[.@i] == .@itemid) .@nb++;
						if( @guildstoragelist_card2[.@i] == .@itemid) .@nb++;
						if( @guildstoragelist_card3[.@i] == .@itemid) .@nb++;
						if( @guildstoragelist_card0[.@i] == .@itemid ||
							@guildstoragelist_card1[.@i] == .@itemid ||
							@guildstoragelist_card2[.@i] == .@itemid ||
							@guildstoragelist_card3[.@i] == .@itemid)
						{
							.@flaggeditemid[.@it] = @guildstoragelist_id[.@i]; // Cet item contient 1 ou plus de la card / gem recherchée.
							.@flaggeditemnb[.@it] = .@nb; // nb de card contenu
							.@flaggeditemrefine[.@it] = @guildstoragelist_refine[.@i]; // niveau de refine
							.@it++;
							.@nbg += .@nb;
						}
					}
					if( getarraysize(.@flaggeditemid) > 0 )
					{
						dispbottom "[ Contenu dans du stuff du guild storage ]",0xF0FF0F;
						for (.@i = 0; .@i < getarraysize(.@flaggeditemid); ++.@i)
						{
							dispbottom "| "+(.@flaggeditemrefine[.@i]>0?"+"+.@flaggeditemrefine[.@i]+" ":"")+""+getitemname(.@flaggeditemid[.@i])+" en contient "+.@flaggeditemnb[.@i]+" !";
							sleep2 100;
						}
					}
				}
			}
		}

		// Calcul du total
		.@total = .@nbi + .@nb1 + .@nb2 + .@nb3 + .@nb4 + .@nb5 + .@nb6 + .@nbc + .@nbg;

		if( .@deep )
		{
			/* RECHERCHE SUR LES AUTRES PERSONNAGES */

			//Recupération de la liste des personnages du joueur sauf celui en ligne
			query_sql("SELECT `char_id`, `name`, `class`, `base_level` FROM `char` WHERE `char_id` <> "+charid+" AND account_id = "+accountid, .@charidList, .@charnameList$, .@charclassList, .@charlvlList);
			if( getarraysize(.@charidList) > 0 )
			{
				dispbottom "[ Recherche dans le reste du compte ]",0xF0FF0F;
				if( getarraysize(.@charidList) > 1 )
				{
					showscript "Recherche sur les "+getarraysize(.@charidList)+" autres personnages de votre compte", accountid, SELF;
					progressbar "FFFFFF",1;
				}
				//Parcours de la liste des personnages ŕ la recherche de l'item
				for( .@p = 0; .@p < getarraysize(.@charidList); ++.@p )
				{
					ClearVars();
					.@nb = 0;
					showscript "Recherche sur votre "+jobname(.@charclassList[.@p])+" - "+.@charnameList$[.@p]+" (Lv:"+.@charlvlList[.@p]+")", accountid, SELF;
					progressbar "FFFFFF",1;
					query_sql("SELECT SUM(`amount`) FROM `inventory` WHERE `char_id` = "+.@charidList[.@p]+" AND `nameid` = "+.@itemid, .@nb);

					//Si on a trouvé l'item sur ce personnage
					if( .@nb > 0 )
					{
						dispbottom "| "+.@charnameList$[.@p]+" - "+jobname(.@charclassList[.@p])+" (Lv:"+.@charlvlList[.@p]+") en a "+.@nb+" dans son inventaire.";
						.@total += .@nb;
					}
					if( getiteminfo( .@itemid, ITEMINFO_TYPE ) == IT_CARD )
					{
						query_sql("SELECT `nameid`, `equip`, `refine`, `card0`, `card1`, `card2`, `card3` FROM `inventory` WHERE `char_id` = "+.@charidList[.@p]+" AND (`card0` = "+.@itemid+" OR `card1` = "+.@itemid+" OR `card2` = "+.@itemid+" OR `card3` = "+.@itemid+")",
							@inventorylist_id, @inventorylist_equip, @inventorylist_refine, @inventorylist_card0, @inventorylist_card1, @inventorylist_card2, @inventorylist_card3);
							@inventorylist_count = getarraysize(@inventorylist_id);

						if( @inventorylist_count > 0 ) {
							showscript "Recherche dans les slots d'items de l'inventaire", accountid, SELF;
							progressbar "FFFFFF",1;
							.@it = 0;
							
							for (.@i = 0; .@i < @inventorylist_count; ++.@i)
							{
								.@nb = 0;
								if( getitemslots(@inventorylist_id[.@i]) == 0) continue;
								if( @inventorylist_card0[.@i] == .@itemid) .@nb++;
								if( @inventorylist_card1[.@i] == .@itemid) .@nb++;
								if( @inventorylist_card2[.@i] == .@itemid) .@nb++;
								if( @inventorylist_card3[.@i] == .@itemid) .@nb++;
								if( @inventorylist_card0[.@i] == .@itemid ||
									@inventorylist_card1[.@i] == .@itemid ||
									@inventorylist_card2[.@i] == .@itemid ||
									@inventorylist_card3[.@i] == .@itemid)
								{
									.@flaggeditemid[.@it] = @inventorylist_id[.@i]; // Cet item contient 1 ou plus de la card / gem recherchée.
									.@flaggeditemeq[.@it] = @inventorylist_equip[.@i]; // Cet item est peut-ętre équipé
									.@flaggeditemnb[.@it] = .@nb; // nb de card contenu
									.@flaggeditemrefine[.@it] = @inventorylist_refine[.@i]; // niveau de refine
									.@it++;
									.@total += .@nb;
								}
							}
							if ( getarraysize(.@flaggeditemid) > 0 )
							{
								dispbottom "[ Contenu dans du stuff de l'inventaire de "+.@charnameList$[.@p]+"]",0xF0FF0F;
								for (.@i = 0; .@i < getarraysize(.@flaggeditemid); ++.@i) {
									dispbottom "| "+(.@flaggeditemrefine[.@i]>0?"+"+.@flaggeditemrefine[.@i]+" ":"")+""+getitemname(.@flaggeditemid[.@i])+""+(.@flaggeditemeq[.@i]?" qui est équipé":"")+" en contient "+.@flaggeditemnb[.@i]+" !";
									sleep2 100;
								}
							}
						}
					}
					
					ClearVars();
					.@nb = 0;
					query_sql("SELECT SUM(`amount`) FROM `cart_inventory` WHERE `char_id` = "+.@charidList[.@p]+" AND `nameid` = "+.@itemid, .@nb);
					//Si on a trouvé l'item dans le cart du perso
					if( .@nb > 0 )
					{
						dispbottom "| "+.@charnameList$[.@p]+" - "+jobname(.@charclassList[.@p])+" (Lv:"+.@charlvlList[.@p]+") en a "+.@nb+" dans sa charette.";
						.@total += .@nb;
					}
					if( getiteminfo( .@itemid, ITEMINFO_TYPE ) == IT_CARD )
					{
						query_sql("SELECT `nameid`, `equip`, `refine`, `card0`, `card1`, `card2`, `card3` FROM `cart_inventory` WHERE `char_id` = "+.@charidList[.@p]+" AND (`card0` = "+.@itemid+" OR `card1` = "+.@itemid+" OR `card2` = "+.@itemid+" OR `card3` = "+.@itemid+")",
							@cartlist_id, @cartlist_equip, @cartlist_refine, @cartlist_card0, @cartlist_card1, @cartlist_card2, @cartlist_card3);
							@cartlist_count = getarraysize(@cartlist_id);

						if( @cartlist_count > 0 ) {
							showscript "Recherche dans les slots d'items du cart de "+.@charnameList$[.@p], accountid, SELF;
							progressbar "FFFFFF",1;
							.@it = 0;
							
							for (.@i = 0; .@i < @cartlist_count; ++.@i)
							{
								.@nb = 0;
								if( getitemslots(@cartlist_id[.@i]) == 0) continue;
								if( @cartlist_card0[.@i] == .@itemid) .@nb++;
								if( @cartlist_card1[.@i] == .@itemid) .@nb++;
								if( @cartlist_card2[.@i] == .@itemid) .@nb++;
								if( @cartlist_card3[.@i] == .@itemid) .@nb++;
								if( @cartlist_card0[.@i] == .@itemid ||
									@cartlist_card1[.@i] == .@itemid ||
									@cartlist_card2[.@i] == .@itemid ||
									@cartlist_card3[.@i] == .@itemid)
								{
									.@flaggeditemid[.@it] = @cartlist_id[.@i]; // Cet item contient 1 ou plus de la card / gem recherchée.
									.@flaggeditemeq[.@it] = @cartlist_equip[.@i]; // Cet item est peut-ętre équipé
									.@flaggeditemnb[.@it] = .@nb; // nb de card contenu
									.@flaggeditemrefine[.@it] = @cartlist_refine[.@i]; // niveau de refine
									.@it++;
									.@total += .@nb;
								}
							}
							if ( getarraysize(.@flaggeditemid) > 0 )
							{
								dispbottom "[ Contenu dans du stuff du cart de "+.@charnameList$[.@p]+"]",0xF0FF0F;
								for (.@i = 0; .@i < getarraysize(.@flaggeditemid); ++.@i) {
									dispbottom "| "+(.@flaggeditemrefine[.@i]>0?"+"+.@flaggeditemrefine[.@i]+" ":"")+""+getitemname(.@flaggeditemid[.@i])+" en contient "+.@flaggeditemnb[.@i]+" !";
									sleep2 100;
								}
							}
						}
					}
				}
			}
		}

		// Affichage final
		if( .@total > 0 )
			dispbottom "Vous avez au total "+.@total+" "+.@itemname$+" !",0xF0FF0F;
		else
			dispbottom "Vous n'avez pas "+.@itemname$+" !",0xF0FF0F;
		ClearVars();
		end;
	}

function SearchStorage {
	.@id = getarg(0);
	.@aid = getarg(1);
	.@stor_id = getarg(2,0);
	.@deep = getarg(3);
	ClearVars();
	if( .@stor_id > 0 )
		loadstorage .@stor_id;	// bien faire un sleep2 ou progressbar pour attendre le load du storage
	showscript "Recherche dans le @storage"+(.@stor_id>0?.@stor_id:""), .@aid, SELF;
	progressbar "FFFFFF",1;
	.@nbr = storagecountitem(.@id, .@aid, .@stor_id);
	if (.@nbr > 0)
		dispbottom "[ "+.@nbr+" dans le Storage"+(.@stor_id>0?.@stor_id:"")+" ]",0xF0FF0F;
	if (.@deep && getiteminfo( .@id, ITEMINFO_TYPE ) == IT_CARD)
	{
		getstoragelist(.@stor_id);
		if( @storagelist_count > 0 ) {
			showscript "Recherche dans les slots d'items du storage"+(.@stor_id>0?.@stor_id:""), .@aid, SELF;
			progressbar "FFFFFF",1;
			.@it = 0;
			
			for (.@i = 0; .@i < @storagelist_count; ++.@i)
			{
				.@nb = 0;
				if( @storagelist_id[.@i] > 0 && getitemslots(@storagelist_id[.@i]) == 0) continue;
				if( @storagelist_card0[.@i] == .@id) .@nb++;
				if( @storagelist_card1[.@i] == .@id) .@nb++;
				if( @storagelist_card2[.@i] == .@id) .@nb++;
				if( @storagelist_card3[.@i] == .@id) .@nb++;
				if( @storagelist_card0[.@i] == .@id ||
					@storagelist_card1[.@i] == .@id ||
					@storagelist_card2[.@i] == .@id ||
					@storagelist_card3[.@i] == .@id)
				{
					.@flaggeditemid[.@it] = @storagelist_id[.@i]; // Cet item contient 1 ou plus de la card / gem recherchée.
					.@flaggeditemnb[.@it] = .@nb; // nb de card contenu
					.@flaggeditemrefine[.@it] = @storagelist_refine[.@i]; // niveau de refine
					.@it++;
					.@nbr += .@nb;
				}
			}
			if ( getarraysize(.@flaggeditemid) > 0 )
			{
				dispbottom "[ Contenu dans du stuff de storage"+(.@stor_id>0?.@stor_id:"")+" ]",0xF0FF0F;
				for (.@i = 0; .@i < getarraysize(.@flaggeditemid); ++.@i)
				{
					dispbottom "| "+(.@flaggeditemrefine[.@i]>0?"+"+.@flaggeditemrefine[.@i]+" ":"")+""+getitemname(.@flaggeditemid[.@i])+" en contient "+.@flaggeditemnb[.@i]+" !";
					sleep2 100;
				}
			}
		}
	}
	return .@nbr;
}

function ClearVars {
	if( getarraysize(.@flaggeditemid) > 0 ) {
		cleararray .@flaggeditemid[0], 0, getarraysize(.@flaggeditemid);
		cleararray .@flaggeditemeq[0], 0, getarraysize(.@flaggeditemeq);
		cleararray .@flaggeditemnb[0], 0, getarraysize(.@flaggeditemnb);
		cleararray .@flaggeditemrefine[0], 0, getarraysize(.@flaggeditemrefine);
	}
	if( getarraysize(@inventorylist_id) > 0)
	{
		@inventorylist_count = 0;
		cleararray @inventorylist_id[0],     0, getarraysize(@inventorylist_id);
		cleararray @inventorylist_equip[0],  0, getarraysize(@inventorylist_equip);
		cleararray @inventorylist_refine[0], 0, getarraysize(@inventorylist_refine);
		cleararray @inventorylist_card0[0],  0, getarraysize(@inventorylist_card0);
		cleararray @inventorylist_card1[0],  0, getarraysize(@inventorylist_card1);
		cleararray @inventorylist_card2[0],  0, getarraysize(@inventorylist_card2);
		cleararray @inventorylist_card3[0],  0, getarraysize(@inventorylist_card3);
	}
	if( getarraysize(@storagelist_id) > 0)
	{
		@storagelist_count = 0;
		cleararray @storagelist_id[0],     0, getarraysize(@storagelist_id);
		cleararray @storagelist_refine[0], 0, getarraysize(@storagelist_refine);
		cleararray @storagelist_card0[0],  0, getarraysize(@storagelist_card0);
		cleararray @storagelist_card1[0],  0, getarraysize(@storagelist_card1);
		cleararray @storagelist_card2[0],  0, getarraysize(@storagelist_card2);
		cleararray @storagelist_card3[0],  0, getarraysize(@storagelist_card3);
	}
	if( getarraysize(@cartlist_id) > 0)
	{
		@cartlist_count = 0;
		cleararray @cartlist_id[0],     0, getarraysize(@cartlist_id);
		cleararray @cartlist_refine[0], 0, getarraysize(@cartlist_refine);
		cleararray @cartlist_card0[0],  0, getarraysize(@cartlist_card0);
		cleararray @cartlist_card1[0],  0, getarraysize(@cartlist_card1);
		cleararray @cartlist_card2[0],  0, getarraysize(@cartlist_card2);
		cleararray @cartlist_card3[0],  0, getarraysize(@cartlist_card3);
	}
	if( getarraysize(@guildstoragelist_id) > 0)
	{
		@guildstoragelist_count = 0;
		cleararray @guildstoragelist_id[0],     0, getarraysize(@guildstoragelist_id);
		cleararray @guildstoragelist_refine[0], 0, getarraysize(@guildstoragelist_refine);
		cleararray @guildstoragelist_card0[0],  0, getarraysize(@guildstoragelist_card0);
		cleararray @guildstoragelist_card1[0],  0, getarraysize(@guildstoragelist_card1);
		cleararray @guildstoragelist_card2[0],  0, getarraysize(@guildstoragelist_card2);
		cleararray @guildstoragelist_card3[0],  0, getarraysize(@guildstoragelist_card3);
	}
	return;
}

OnInit:
		bindatcmd("searchid",strnpcinfo(3)+"::OnAtcommand");
		bindatcmd("deepsearchid",strnpcinfo(3)+"::OnAtcommand");
		end;
}
