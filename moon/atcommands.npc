-	script	#gmclicdroit	-1,{
OnInit:
	bindatcmd("gmclicdroit",strnpcinfo(0)+"::OnCommand",80,99);
	end;

OnCommand:
	ignoretimeout 1;
	mes "-- Menu special GM --";
	mes "Joueur: " + strcharinfo(0,atoi(.@atcmd_parameters$[0]));
	.@login$ = callfunc("getuserid",getcharid(3,strcharinfo(0,atoi(.@atcmd_parameters$[0]))));
	mes "Login: " + .@login$;
	mes "Vote: " + callfunc("getvote",callfunc("getuniqueid",getcharid(3,strcharinfo(0,atoi(.@atcmd_parameters$[0])))));
	mes "Event: " + readparam(132, atoi(.@atcmd_parameters$[0]));
L_main:
	switch( select( "Voir l'equippements", "Points Events", "Faire venir le joueur", "@nuke", (readparam(Sitting, atoi(.@atcmd_parameters$[0]))?"Debout":"Assis"), "",
					(getstatus(SC_NOCHAT, 0, atoi(.@atcmd_parameters$[0]))?"Unmute":"Mute"),
					"Kick",
					(getstatus(SC_JAILED, 0, atoi(.@atcmd_parameters$[0]))?"Unjail":"Jail"),
					"^FF0000Bannir^000000") ) {
		case 1: viewequip getcharid(0), atoi(.@atcmd_parameters$[0]); break;
		case 2:
			clear;
			mes "Le joueur possede "+readparam(132, atoi(.@atcmd_parameters$[0]))+" points d'évent";
			mes "Combien voulez-vous lui retirer ou donner?";
			mes "- pour retirer etc (max 50 ŕ la fois).";
			input .@pts,-50,50;
			if( readparam(132, atoi(.@atcmd_parameters$[0])) + .@pts < 0 ) .@pts += (readparam(132, atoi(.@atcmd_parameters$[0])) + .@pts) * -1;
			if( .@pts != 0) {
				logmes "menugm: Vous "+(.@pts<0?"retirez":"ajoutez") + " " + (.@pts<0?.@pts*-1:.@pts) +" pts d'évent ŕ "+strcharinfo(0,atoi(.@atcmd_parameters$[0]));
				dispbottom "Vous "+(.@pts<0?"retirez":"ajoutez") + " " + (.@pts<0?.@pts*-1:.@pts) +" pts d'évent ŕ "+strcharinfo(0,atoi(.@atcmd_parameters$[0]));
				dispbottom "Vous "+(.@pts<0?"perdez":"gagnez") + " " + (.@pts<0?.@pts*-1:.@pts) +" pts d'évent.", 0x777777, atoi(.@atcmd_parameters$[0]);
				setd "#KAFRAPOINTS",(readparam(132, atoi(.@atcmd_parameters$[0]))+.@pts),atoi(.@atcmd_parameters$[0]);
			}
			clear;
			goto OnCommand;
		case 3: 
			stand strcharinfo(0,atoi(.@atcmd_parameters$[0]));
			sleep2 200;
			unitwalkto getcharid(3,strcharinfo(0,atoi(.@atcmd_parameters$[0]))),getcharid(3);
			break;
		case 4: atcommand "@nuke " + strcharinfo(0,atoi(.@atcmd_parameters$[0])); break;
		case 5:
			if( readparam(Sitting, atoi(.@atcmd_parameters$[0])) )
				stand strcharinfo(0,atoi(.@atcmd_parameters$[0]));
			else
				sit strcharinfo(0,atoi(.@atcmd_parameters$[0]));
			break;
		case 7:
			if( getstatus(SC_NOCHAT, 0, atoi(.@atcmd_parameters$[0])) )
				atcommand "@unmute " + strcharinfo(0,atoi(.@atcmd_parameters$[0]));
			else
				atcommand "@mute 60 " + strcharinfo(0,atoi(.@atcmd_parameters$[0]));
			break;
		case 8: atcommand "@kick " + strcharinfo(0,atoi(.@atcmd_parameters$[0])); break;
		case 9:
			if( getstatus(SC_JAILED, 0, atoi(.@atcmd_parameters$[0])) )
				atcommand "@unjail " + strcharinfo(0,atoi(.@atcmd_parameters$[0]));
			else
				atcommand "@jail " + strcharinfo(0,atoi(.@atcmd_parameters$[0]));
			break;
		case 10: atcommand "@block " + strcharinfo(0,atoi(.@atcmd_parameters$[0])); break;
		default:
			break;
	}
	goto L_main;
	end;
}

-	script	#monsterevent	-1,{
OnInit:
	bindatcmd("monsterevent",strnpcinfo(0)+"::OnCommand",80,99);
	end;

OnCommand:
	if( .@atcmd_parameters$[0] == "" ) {
		dispbottom "Usage: @monsterevent <MonsterID/SpriteName> <Amount> <HP>";
		dispbottom "MonsterID: ID du monstre ŕ faire apparaître.";
		dispbottom "SpriteName: Nom du sprite du monstre ŕ faire apparaître.";
		dispbottom "Amount: Nombre de monstres ŕ faire apparaître.";
		dispbottom "HP: Points de vie des monstres ŕ faire apparaître.";
		end;
	}

	.@mobid = getmonsterinfo(atoi(.@atcmd_parameters$[0]) > 0 ? atoi(.@atcmd_parameters$[0]) : .@atcmd_parameters$[0], MOB_ID);

	if( .@mobid == -1 )
	{
		dispbottom "Mob introuvable.";
		end;
	}

	.@amount = cap_value(atoi(.@atcmd_parameters$[1]), 1, 200);
	.@hp = cap_value(atoi(.@atcmd_parameters$[2]), 1, 100000000);
	if( !getmapxy(.@map$, .@x, .@y, BL_PC) && (.@val = monster_event(.@map$, .@x, .@y, .@mobid, .@amount, .@hp, (atoi(.@atcmd_parameters$[3]) > 0 ? 1 : 0))) )
		unittalk getcharid(3), "Summon de "+.@amount+" "+getmonsterinfo(.@mobid, MOB_NAME)+" ŕ "+.@val+" HP";
	end;
}

-	script	#npcblock	-1,{
OnInit:
	bindatcmd("npcblock",strnpcinfo(0)+"::OnCommand",0,99);
	end;

OnCommand:
	switch( .@atcmd_parameters$[0] ) {
		case 1:
			if( #BlockMoonNpc & 1 ) {
				dispbottom "Vous ne bloquez plus le Job Master.";
				#BlockMoonNpc &= ~1;
			}
			else {
				dispbottom "Vous bloquez désormais le Job Master.";
				#BlockMoonNpc |= 1;
			}
			break;
		case 2:
			if( #BlockMoonNpc & 2 ) {
				dispbottom "Vous ne bloquez plus la Kafra.";
				#BlockMoonNpc &= ~2;
			}
			else {
				dispbottom "Vous bloquez désormais la Kafra.";
				#BlockMoonNpc |= 2;
			}
			break;
		case 3:
			if( #BlockMoonNpc & 4 ) {
				dispbottom "Vous ne bloquez plus le Styliste.";
				#BlockMoonNpc &= ~4;
			}
			else {
				dispbottom "Vous bloquez désormais le Styliste.";
				#BlockMoonNpc |= 4;
			}
			break;
		case 4:
			if( #BlockMoonNpc & 8 ) {
				dispbottom "Vous ne bloquez plus le PvP Warper.";
				#BlockMoonNpc &= ~8;
			}
			else {
				dispbottom "Vous bloquez désormais le PvP Warper.";
				#BlockMoonNpc |= 8;
			}
			break;
		case 5:
			if( #BlockMoonNpc & 16 ) {
				dispbottom "Vous ne bloquez plus le DB/BB/MVP Warper.";
				#BlockMoonNpc &= ~16;
			}
			else {
				dispbottom "Vous bloquez désormais le DB/BB/MVP Warper.";
				#BlockMoonNpc |= 16;
			}
			break;
		default:
			if( #BlockMoonNpc ) {
				dispbottom "Vous ne bloquez plus les npcs ([1]Job master, [2]kafra, [3]styliste, [4]pvp warper, [5]db/bb/mvp warper).";
				#BlockMoonNpc = 0;
			}
			else {
				dispbottom "Vous bloquez les npcs ([1]Job master, [2]kafra, [3]styliste, [4]pvp warper, [5]db/bb/mvp warper).";
				#BlockMoonNpc = 31;
			}
			break;
	}
	end;
}

