		410280,410282,410289,410295,410315,410329,410331,410363,410368,420242,
		420271,420304,420337,420338,420351,420382,420423,420424,420429,420430,
		420451,420511,420512,420552,420731,440008,480092,480097,480122,480131,
		480168,480203,480205,480286,480288,480296,480298,480458,480470,480505,
		480627,480664;
	setarray .@effects[0],
		HAT_EF_FLUTTER_BUTTERFLY,HAT_EF_ANGEL_FLUTTERING,HAT_EF_RESONATETAEGO,HAT_EF_GIFT_OF_SNOW,HAT_EF_BLOSSOM_FLUTTERING,HAT_EF_CAMELLIA_HAIR_PIN,HAT_EF_FEATHER_FLUTTERING,HAT_EF_VALHALLA_IDOL,HAT_EF_FLORAL_WALTZ,HAT_EF_MAGICCIRCLE,
		HAT_EF_FULL_BLOOMCHERRY_TREE,HAT_EF_C_BLESSINGS_OF_SOUL,HAT_EF_C_SHINING_ANGEL_WING,HAT_EF_DIGITAL_SPACE,HAT_EF_C_MAPLE_WHICH_FALLS_RD,HAT_EF_MAGICCIRCLERAINBOW,HAT_EF_C_GHOST_EFFECT,HAT_EF_C_POPPING_PORING_AURA,HAT_EF_C_VALKYRIE_WING,HAT_EF_MAGICAL_FEATHER,
		HAT_EF_DOUBLEGUMGANG,HAT_EF_BAKURETSU_HADOU,HAT_EF_GOLD_SHOWER,HAT_EF_C_FLUTTERBUTTERFLY_BL,HAT_EF_QSCARABA,HAT_EF_MANYSTARS,HAT_EF_C_Disapear_Time_TW,HAT_EF_C_15TH_NOV_HELMET,HAT_EF_MAGIC_STAR_TW,HAT_EF_C_DARK_LORD_MANTEAU,
		HAT_EF_C_ROS2023_CAPE_1,HAT_EF_C_ROS2023_CAPE_2,HAT_EF_GEARWHEEL,HAT_EF_C_ROMANCE_ROSE_TW,HAT_EF_FLUFFYWING,HAT_EF_FLUFFYWING,HAT_EF_C_ROMANCE_ROSE_TW,HAT_EF_VIP_HAIR,HAT_EF_VIP_HAIR,HAT_EF_BLACK_THUNDER,
		HAT_EF_EFST_C_20TH_ANNIVERSARY_HAT,HAT_EF_C_BULB_WREATH,HAT_EF_Qscaraba,HAT_EF_C_Magic_Heir_TW,HAT_EF_C_SUDDEN_WEALTH_TW,HAT_EF_FALLING_SNOW,HAT_EF_C_Released_Ground,HAT_EF_C_SPOT_LIGHT,HAT_EF_alice_tea,HAT_EF_AUTUMN_FULL_MOON,
		HAT_EF_NIFLHEIM_NIGHT_SKY,HAT_EF_C_1ST_EVT_BALLOON_MSP,HAT_EF_C_BABY_GLOOM,HAT_EF_WINTERNIGHTBELLS,HAT_EF_C_CONSECRATE_F_AUREOLA,HAT_EF_C_DRAGON_GREEN_AURA,HAT_EF_C_DRAGON_YELLOW_AURA,HAT_EF_AURA_OF_GHOST_S,HAT_EF_PERM_FROST_OBLIVION,HAT_EF_C_FLUTTERING_HAZE,
		HAT_EF_COSMIC_CONNECTION,HAT_EF_NIGHTSKYOFRUTIE,HAT_EF_C_ANCIENT_RUNE,HAT_EF_C_CLB_SS_LL,HAT_EF_C_AUSPICLOUD,HAT_EF_ATQUE_POENITENTIA,HAT_EF_INKPAINTING_DAY,HAT_EF_INKPAINTING_NIGHT,HAT_EF_GUIDE_OF_DEAD_TEXT,HAT_EF_MEDJED_TEXT,
		HAT_EF_HANMAC_MUNCH,HAT_EF_C_OVER_CLOUD,HAT_EF_C_AURORA_ON_CLOUDS,HAT_EF_DIVINE_SKY_INVITE,HAT_EF_C_CLB_GAT_DOC,HAT_EF_C_MASTER,HAT_EF_C_SUDDEN_WEALTH_TW,HAT_EF_SNOW_POWDER,HAT_EF_C_SAMBA_CARNIVAL,HAT_EF_C_Swirling_Flame,
		HAT_EF_C_MELODY_WING,HAT_EF_Magiccircle_Blue_TW,HAT_EF_C_Astra_Blessing,HAT_EF_SERPENT_SHADOW,HAT_EF_C_DARK_LORD_CLOAK,HAT_EF_C_SAKURA_FUBUKI,HAT_EF_rabbit_aura,HAT_EF_C_FH_LOSTWING,HAT_EF_VACATION,HAT_EF_C_ROS2024_WING_1,
		HAT_EF_C_2025ROSFESTA,HAT_EF_C_CURSED_SERPENT;
	// AUTO-GENERATED-END

	setpcblock PCBLOCK_COMMANDS,true;
	.@size = getarraysize(.@items);
	.@per_page = 20;
	.@offset = 0;
	while(1) {
		.@menu$ = "";
		for(.@i = 0; .@i < .@per_page; .@i++)
			.@menu$ = .@menu$ + getitemname(.@items[(.@offset + .@i) % .@size]) + " [" + .@items[(.@offset + .@i) % .@size] + "]:";
		.@menu$ = .@menu$ + "Quitter";
		@menu = prompt(.@menu$);
		if(.@effid > 0) {
			hateffect(.@effid,false);
			.@effid = 0;
		}
		if(@menu == 0 || @menu > .@per_page) {
			setpcblock PCBLOCK_COMMANDS,false;
			break;
		}
		.@idx = (.@offset + @menu - 1) % .@size;
		.@effid = .@effects[.@idx];
		hateffect(.@effid,true);
		.@offset = (.@offset + @menu) % .@size;
	}
	end;
}

