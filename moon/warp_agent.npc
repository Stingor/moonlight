	switch( select("Ģ moc_fild01:Ģ moc_fild02:Ģ moc_fild03:Ģ moc_fild04:Ģ moc_fild05:Ģ moc_fild06:Ģ moc_fild07:Ģ moc_fild08:Ģ moc_fild09:Ģ moc_fild10:Ģ moc_fild11:Ģ moc_fild12:Ģ moc_fild13:Ģ moc_fild14:Ģ moc_fild15:Ģ moc_fild16:Ģ moc_fild17:Ģ moc_fild18:Ģ moc_fild19:Ģ moc_fild20:Ģ moc_fild21:Ģ moc_fild22") ) {
		case 1:  warp_fct("moc_fild01");
		case 2:  warp_fct("moc_fild02");
		case 3:  warp_fct("moc_fild03");
		case 4:  warp_fct("moc_fild04");
		case 5:  warp_fct("moc_fild05");
		case 6:  warp_fct("moc_fild06");
		case 7:  warp_fct("moc_fild07");
		case 8:  warp_fct("moc_fild08");
		case 9:  warp_fct("moc_fild09");
		case 10: warp_fct("moc_fild10");
		case 11: warp_fct("moc_fild11");
		case 12: warp_fct("moc_fild12");
		case 13: warp_fct("moc_fild13");
		case 14: warp_fct("moc_fild14");
		case 15: warp_fct("moc_fild15");
		case 16: warp_fct("moc_fild16");
		case 17: warp_fct("moc_fild17");
		case 18: warp_fct("moc_fild18");
		case 19: warp_fct("moc_fild19");
		case 20: warp_fct("moc_fild20");
		case 21:
			if (rebirth_moc_edq < 4)
				warp_fct("moc_fild20", 349, 185);
			else if (rebirth_moc_edq > 3 && rebirth_moc_edq < 8 && countitem(Continental_Guard_Paper) > 0)
				warp_fct("moc_fild21", 38, 193);
			else if (rebirth_moc_edq == 8 && countitem(Continental_Guard_Paper) > 0 )
				warp_fct("moc_fild21", 38, 193);
			break;
		case 22: 
			if (countitem(Continental_Guard_Paper) > 0) 
				warp_fct("moc_fild22", 38, 193);
			else if (countitem(Continental_Guard_Paper) < 1) {
				mes "[Continental Guard]";
				mes "Only members of the Continental Guards with Continental Guard Certificates are allowed to proceed beyond this point.";
				close;
			}
			break;
	}
	end;
