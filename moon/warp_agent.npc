//===== Moonlight-Destiny ==================================
//= Script warp agent.
//===== Par: =================================================
//= Yaro / Moonlight-Destiny Dev Team
//===== Version courrante: ===================================
//= 3.1
//===== Description: =========================================
//= Permet aux joueurs de se teleporter, sauvegarder
//=	Acceder au instances.
//===== Commentaires: ========================================
//= 1.0 Creation [Stingor]
//= 1.1 Ajouter d'une save dynamique sur menu sauvegarde [Kamitsu]
//= 1.2 Ajout de Moscovia en ville+duplicate [Stingor]
//= 1.3 Correction warp aldebaran (mauvais x/y) [Stingor]
//= 1.4 Ajout couleurs [Kamitsu]
//= 1.5 Ajout de uniquenames type ::warpa_map [Stingor]
//= 1.6 Ajout de $map_pvp$ pour le switcher [Stingor]
//= 1.7 Fix au complet des warp dungeon qui ne warp pas au bon niveau [Frecky]
//= 1.8 Effacement du warp de Rebirth lab, cette map n'existe pas [Frecky]
//= 2.0 Mise Ó jour [Stingor]
//= 2.1 Ajout support party pour thana warp+support clķs
//= 2.2 Cleanup [Stingor]
//= 3.0 rAthena update & tweaks [Stingor]
//= 3.1 Ajout Fields [Stingor]
//============================================================

gonryun,165,129,3	script	Warp Agent::warp_agent	4_F_01,{
	function GetColor;

L_WarpaCmd:
	mes "[ ^1F81D4" + strnpcinfo(0) + "^000000 ]";
	mes "Bonjour ^4a8b3e" + strcharinfo(0) + "^000000 !";
	mes "Je suis le Npc qui sert Ó se teleporter dans les villes et les donjons ainsi que de sauvegarder !";
L_warpa:
	if( lastm_warpa$ == "" && lastx_warpa == 0 && lasty_warpa == 0 )
		@lastwarp$ = "";
	else
		@lastwarp$ = "Ģ ^51a1f3" + getmapname(lastm_warpa$) + "^000000";

	if( !getmapxy(.@map$, .@mapx, .@mapy) ) {
		if( getsavepoint(0) == .@map$ && getsavepoint(1) == .@mapx && getsavepoint(2) == .@mapy )
			.@save$ = "";
		else
			.@save$ = "Ģ ^805bdfSauvegarder^000000";
	}
	else .@save$ = "";

	menu @lastwarp$, -,
		"Ģ ^5ca57bVilles^000000", L_Villes,
		"Ģ ^f28e0dDonjons^000000", L_Donjons,
		"Ģ ^d28efdFields^000000", L_Fields,
		"Ģ ^f08eddGuild Dungeons^000000",L_Guild_Dungeons,
		"Ģ ^f08eedInstances^000000", L_Instance,
		"Ģ ^c08dedAutre^000000", L_Autre,
		"Ģ ^f279acRooms^000000", L_Rooms,
		.@save$, L_Save;
	warp_fct(lastm_warpa$, lastx_warpa, lasty_warpa);
	end;

L_Villes:
	clear;
L_VillesCmd:
	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	mes "Sķlectionnez la destination de votre choix :";
	// Ajouter une ville: une valeur par tableau + l'entrķe dans .@vn$
	setarray .@vn$[0],
		"^ff0000Ģ Gonryun^000000", "Ģ Alberta",     "Ģ Aldebaran",   "Ģ Amatsu",
		"Ģ Ayothaya",              "Ģ Brasilis",     "Ģ Comodo",      "Ģ Dewata",
		"Ģ Dicastes",              "Ģ Eclage",       "Ģ Einbech",     "Ģ Einbroch",
		"Ģ Geffen",                "Ģ Hugel",        "Ģ Izlude",      "Ģ Jawaii",
		"Ģ Lasagna",               "Ģ Lighthalzen",  "Ģ Louyang",     "Ģ Lutie",
		"Ģ Malangdo",              "Ģ Malaya",       "Ģ Manuk",       "Ģ Mora",
		"Ģ Morocc",                "Ģ Moscovia",     "Ģ Niflheim",    "Ģ Payon",
		"Ģ Prontera",              "Ģ Rachel",       "Ģ Rock Ridge",  "Ģ Splendide",
		"Ģ Umbala",                "Ģ Veins",        "Ģ Juno";
	setarray .@vm$[0],
		"gonryun",    "alberta",    "aldebaran", "amatsu",
		"ayothaya",   "brasilis",   "comodo",    "dewata",
		"dicastes01", "eclage",     "einbech",   "einbroch",
		"geffen",     "hugel",      "izlude",    "jawaii",
		"lasagna",    "lighthalzen","louyang",   "xmas",
		"malangdo",   "malaya",     "manuk",     "mora",
		"morocc",     "moscovia",   "niflheim",  "payon",
		"prontera",   "rachel",     "harboro1",  "splendide",
		"umbala",     "veins",      "yuno";
	setarray .@vx[0],
		156,  50, 140, 200, 207, 195, 166, 200,
		197, 167, 170,  65, 120,  96, 128, 135,
		193, 158, 218, 148, 167, 144, 286, 136,
		158, 224, 194, 177, 155, 128, 283, 200,
		122, 196, 153;
	setarray .@vy[0],
		120, 240, 117, 110, 192, 215, 161, 174,
		223, 194, 125, 200,  68, 145, 111, 202,
		182,  92, 115, 131, 136, 240, 230,  91,
		 93, 192, 186, 104, 182, 111, 212, 149,
		138, 230, 123;
	.@n = getarraysize(.@vn$);
	.@sel$ = "";
	for (.@i = 0; .@i < .@n; .@i++)
		.@sel$ = .@sel$ + (.@i > 0 ? ":" : "") + .@vn$[.@i];
	.@c = select(.@sel$ + ":Ģ ^e64c00Menu Prķcķdent.^000000") - 1;
	if (.@c >= .@n) goto L_warpa;
	if (.@c == 0)
		warp_fct("gonryun", 156 + rand(1,5), 120 + rand(1,4));
	else
		warp_fct(.@vm$[.@c], .@vx[.@c], .@vy[.@c]);
	end;

L_Guild_Dungeons:
	clear;
	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	mes "Sķlectionnez la destination de votre choix :";
	// Ajouter un guild dungeon: une valeur par tableau + l'entrķe dans .@gn$
	setarray .@gn$[0],
		"Ģ Corridor of the Abyss - Tears of Hero",
		"Ģ Corridor of the Abyss - Dead Man Hill",
		"Ģ Corridor of the Abyss - Ancient Wind",
		"Ģ Corridor of the Abyss - Warrior's Way",
		"Ģ Greenwood Lake Guild Dungeon 1",
		"Ģ Greenwood Lake Guild Dungeon 2",
		"Ģ Luina Guild Dungeon 1",
		"Ģ Luina Guild Dungeon 2",
		"Ģ Valkyrie Guild Dungeon 1",
		"Ģ Valkyrie Guild Dungeon 2",
		"Ģ Britoniah Guild Dungeon 1",
		"Ģ Britoniah Guild Dungeon 2",
		"Ģ Arunafeltz Guild Dungeon",
		"Ģ Schwartzvald Guild Dungeon",
		"Ģ TE Subterranean Guild Dungeon 1",
		"Ģ TE Subterranean Guild Dungeon 2";
	setarray .@gm$[0],
		"gld2_ald",   "gld2_gef",   "gld2_pay",   "gld2_prt",
		"gld_dun01",  "gld_dun01_2","gld_dun02",  "gld_dun02_2",
		"gld_dun03",  "gld_dun03_2","gld_dun04",  "gld_dun04_2",
		"arug_dun01", "schg_dun01", "teg_dun01",  "teg_dun02";
	setarray .@gx[0],
		147, 152, 120, 140,
		119, 119,  39,  39,
		 50,  50, 116, 116,
		199, 200,  42,  26;
	setarray .@gy[0],
		155, 118, 130, 132,
		 93,  93, 161, 161,
		 44,  44,  45,  45,
		195, 124,  36, 160;
	.@n = getarraysize(.@gn$);
	.@sel$ = "";
	for (.@i = 0; .@i < .@n; .@i++)
		.@sel$ = .@sel$ + (.@i > 0 ? ":" : "") + .@gn$[.@i];
	.@c = select(.@sel$ + ":Ģ ^e64c00Menu Prķcķdent.^000000") - 1;
	if (.@c >= .@n) goto L_warpa;
	warp_fct(.@gm$[.@c], .@gx[.@c], .@gy[.@c]);
	end;

L_Instance:
	clear;
	.@hardmode = 1;
	.@party_id = getcharid(1);
	if( .@party_id < 1 ) {
		party_create("party" + gettimetick(0));
		mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
		mes "Party genķrķe...";
		mes "Attention, il n'est pas possible de retourner dans une instance une fois que vous l'avez quittķe.";
		next;
	}
	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	mes "Sķlectionnez la destination de votre choix :";
	switch( select( GetColor(15050)+"Ģ Airship Assault (Solo & HM)^000000",
					GetColor(12278)+"Ģ Bakonawa Lake^000000",
					GetColor(9223)+"Ģ Bangungot Hospital 2F (HM)^000000",
					GetColor(4229)+"Ģ Buwaya Cave (HM)^000000",
					GetColor(12347)+"Ģ Central Laboratory^000000",
					GetColor(13185)+"Ģ Charleston in Distess^000000",
					GetColor(7577)+"Ģ Devil's Tower^000000",
					(instance_delay_cellar < gettimetick(2)?"^00A000":"^FF0000")+"Ģ Endless Cellar (HM, Custom)^000000",
					GetColor(60200)+"Ģ Endless Tower (HM)^000000",
					GetColor(12325)+"Ģ Faceworms Nest (Solo)^000000",
					(GeffenTournament < gettimetick(2)?"^00A000":"^FF0000")+"Ģ Gef. Magic Tour. (HM, Solo, Custom)^000000",
					GetColor(1261)+"Ģ Ghost Palace (Solo)^000000",
					GetColor(7211)+"Ģ Hazy Forest^000000",
					GetColor(12331)+"Ģ Horror Toy Factory (HM)^000000",
					GetColor(15005)+"Ģ Isle Of Bios^000000",
					GetColor(11379)+"Ģ Last Room^000000",
					GetColor(12254)+"Ģ Malangdo Culvert^000000",
					GetColor(9319)+"Ģ Morse Cave^000000",
					GetColor(13182)+"Ģ Nightmarish Jitterbug (HM)^000000",
					GetColor(3135)+"Ģ Nydhoggur's Nest^000000",
					GetColor(4197)+"Ģ Octopus Cave^000000",
					GetColor(12317)+"Ģ Old Glast Heim (HM)^000000",
					GetColor(12059)+"Ģ Orc's Memory^000000",
					GetColor(7706)+"Ģ Room of Consciousness (HM, Solo)^000000",
					GetColor(9336)+"Ģ Sarah and Fenrir^000000",
					GetColor(15002)+"Ģ Sara Memory^000000",
					GetColor(3040)+"Ģ Sealed Shrine^000000",
					GetColor(5112)+"Ģ Wolfchev's Laboratory^000000",
					// "Ģ Temple of Demon God^000000",
					"Ģ ^e64c00Menu Prķcķdent.^000000") ) {
		case 1: { // Airship Assault
			if( select( GetColor(15050)+"Acces direct^000000", "Se rendre dans le Rift" ) == 1 ) {
				.@md_name$ = "Assault on the Airship";
				.@questid = 15050; // Memorial Dungeon: Airship Assault
				callsub Party_Check,.@md_name$;
				callsub Leader_Check; // Pour instance Solo
				.@hardmode = callsub(Hard_Mode,GetColor(.@questid));
				.@turbo = callsub(Turbo_Mode,GetColor(.@questid));
				callsub Process_Instance,.@md_name$,.@hardmode,.@turbo,.@questid;
				break;
			}
			warp_fct("dali02", 139, 82);
		}
		case 2: { // Bakonawa Lake
			if( select( GetColor(12278)+"Acces direct^000000", "Se rendre au lac" ) == 1 ) {
				.@md_name$ = "Bakonawa Lake";
				.@questid1 = 12278; // Towards Bakonawa Lake...
				.@questid2 = 12279; // Get Rid of Bakonawa
				if( isbegin_quest(.@questid2) > 1 )
					completequest .@questid2;
				callsub Party_Check,.@md_name$;
				callsub Process_Instance,.@md_name$,.@hardmode,.@turbo,.@questid1,.@questid2;
				break;
			}
			warp_fct("ma_scene01", 172, 175);
		}
		case 3: { // Bangungot Hospital
			if( select( GetColor(9223)+"Acces direct^000000", "Se rendre au 1er ķtage" ) == 1 ) {
				.@md_name$ = "Bangungot Hospital 2F";
				.@questid1 = 9223; // Will there be Peace at the Hospital?
				.@questid2 = 9222; // Get Rid of Bangungot from Hospital 2F
				if( isbegin_quest(.@questid2) > 1 )
					completequest .@questid2;
				callsub Party_Check,.@md_name$;
				.@hardmode = callsub(Hard_Mode,GetColor(.@questid1));
				callsub Process_Instance,.@md_name$,.@hardmode,.@turbo,.@questid1,.@questid2;
				break;
			}
			warp_fct("ma_dun01", 151, 8);
		}
		case 4:	{ // Buwaya Cave
			.@md_name$ = "Buwaya Cave";
			.@questid = 4229; // Devil in the Cave
			callsub Party_Check,.@md_name$;
			.@hardmode = callsub(Hard_Mode,GetColor(.@questid));
			callsub Process_Instance,.@md_name$,.@hardmode,.@turbo,.@questid;
			break;
			// warp_fct("ma_fild02", 316, 317);
		}
		case 5:	{ // Central Laboratory
			if( select( GetColor(12347)+"Acces direct^000000", "Se rendre sur place" ) == 1 ) {
				.@md_name$ = "Central Laboratory";
				.@questid1 = 12347; // Trace of Laboratory Access
				.@questid2 = 12346; // Strange Ancient Science
				if( isbegin_quest(.@questid2) == 1 )
					completequest .@questid2;
				callsub Party_Check,.@md_name$;
				callsub Process_Instance,.@md_name$,.@hardmode,.@turbo,.@questid1,.@questid2;
				break;
			}
			warp_fct("verus01", 151, 150);
		}
		case 6:	{ // Charleston in distress
L_Charleston:
			if( select( GetColor(13185)+"Acces direct^000000", "Se rendre sur place" ) == 1 ) {
				.@md_name$ = "Charleston in Distress";
				.@questid = 13185; // Charleston Factory - Hold

				if( checkquest(13186) > -1 ) {
					getexp 1800000,600000;
					if( isbegin_quest(13184) )
						erasequest 13184;
					erasequest 13186;
					mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
					mes "Vous venez de completer des quĻtes!";
					next;
					goto L_Charleston;
				}

				callsub Party_Check,.@md_name$;
				callsub Process_Instance,.@md_name$,.@hardmode,.@turbo,.@questid;
				break;
			}
			warp_fct("verus04", 77, 118);
		}
		case 7:	{ // Devil's Tower
L_DevilTower:
			if( select( GetColor(7577)+"Acces direct^000000", "Se rendre sur place" ) == 1 ) {
				.@md_name$ = "Devil's Tower";

				callsub Party_Check,.@md_name$;

				if( checkquest(7577,PLAYTIME) == 2 )
					erasequest 7577; // Space distortion

				if( isbegin_quest(7576) > 0 ) {// instance completed
					erasequest 7571;// Tower Expedition
					erasequest 7574;// Thanatos Tower
					erasequest 7576;// Morocc castle seal
					getexp 450000,450000;
					clear;
					mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
					mes "Vous venez de completer des quĻtes!";
					next;
					goto L_DevilTower;
				}

				if( isbegin_quest(7574) > 0 ) { // failed after seal
					erasequest 7571;// Tower Expedition
					erasequest 7574;// Thanatos Tower
					getexp 300000,300000;
					clear;
					mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
					mes "Vous venez de completer des quĻtes!";
					next;
					goto L_DevilTower;
				}

				if( isbegin_quest(7571) > 0 ) {// failed at stair 2 tnm1
					erasequest 7571;// Tower Expedition
					if (isbegin_quest(7572)) erasequest 7572;// Lucile...?
					if (isbegin_quest(7573)) erasequest 7573;// Magic Swordman Thanatos
					getexp 200000,200000;
					clear;
					mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
					mes "Vous venez de completer des quĻtes!";
					next;
					goto L_DevilTower;
				}

				switch( checkquest(7577,PLAYTIME) ) {
					case -1:
						callsub Create_Instance,.@md_name$,.@hardmode; // Crķation instance
						if ( BaseLevel < 100 ) {
							mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
							mes "Vous venez Ļtre au moins niveau 100 pour entrer cette instance!";
							close;
						} 
						switch( instance_enter(.@md_name$) ) {
							case IE_NOMEMBER: goto L_NOMEMBER;
							case IE_NOINSTANCE: goto L_NOINSTANCE;
							case IE_OTHER: goto L_OTHER;
							case IE_OK:
								if (isbegin_quest(7569)) erasequest 7569;// Treat the injured
								if (isbegin_quest(7570)) erasequest 7570;// Destroy the demons
								setquest 7577; // Space distortion
								end;
						}
						end;
					case 0:
					case 1:
						callsub Quick_Enter,.@md_name$;
				}
				break;
			}
			warp_fct("dali02", 137, 115);
		}
		case 8:	{ // Endless Cellar
			.@md_name$ = "Endless Cellar";
			.instance_delay = 20 * 60 * 60; // 20h
			callsub Party_Check,.@md_name$;
			if( is_party_leader(getcharid(1)) == true && instance_delay_cellar < gettimetick(2) ) {
				mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
				mes "Cette instance est disponible avec plusieur niveau de difficultķ, Ļtes vous prĻts Ó tenter?";
				mes "^FF0000Attention!!";
				mes "Le timer reste le mĻme pour chaque niveau !! Si vous ķchouez au 5 vous ne pourrez changer la difficultķ.^000000";
				.@hardmode = select( "Facile(1)", "Normal(2)", "Moyen(3)", "", "Difficile(5)", "", "TrĶs Difficile(7)", "", "", "MALADE(10)", "", "", "", "", "Mindblown(15)", "", "", "", "", "Game Over(20)" );
				callsub Create_Instance, .@md_name$, .@hardmode; // Crķation instance
			}
			if ( BaseLevel < 100 ) {
				mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
				mes "Vous venez Ļtre au moins niveau 100 pour entrer cette instance!";
				close;
			} 
			switch( instance_enter(.@md_name$) ) {
				case IE_NOMEMBER: goto L_NOMEMBER;
				case IE_NOINSTANCE: goto L_NOINSTANCE;
				case IE_OTHER: goto L_OTHER;
				case IE_OK:
					instance_delay_cellar = (gettimetick(2) + .instance_delay);
					end;
			}
			break;
			// warp_fct("e_tower", 78, 80);
		}
		case 9:	{ // Endless Tower
			.@md_name$ = "Endless Tower";
			.@questid = 60200; // Endless Tower Effect
			callsub Party_Check,.@md_name$;
			if( is_party_leader(getcharid(1)) == true && GetColor(.@questid) != "^FF0000" ) {
				mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
				mes "Cette instance est disponible avec plusieur niveau de difficultķ, Ļtes vous prĻts Ó tenter?";
				mes "^FF0000Attention!!";
				mes "Le timer reste le mĻme pour chaque niveau !! Si vous ķchouez au 5 vous ne pourrez changer la difficultķ.^000000";
				.@hardmode = select( "Facile(1)", "Normal(2)", "Moyen(3)", "", "Difficile(5)", "", "TrĶs Difficile(7)", "", "", "MALADE(10)", "", "", "", "", "Mindblown(15)", "", "", "", "", "Game Over(20)" );
			}
			callsub Process_Instance,.@md_name$,.@hardmode,.@turbo,.@questid;
			break;
			// warp_fct("e_tower", 72, 112);
		}
		case 10: { // Faceworm's Nest
			if( select( GetColor(12325)+"Acces direct^000000", "Se rendre sur place" ) == 1 ) {
				.@md_name$ = "Faceworm's Nest";
				.@questid = 12325; // Faceworm's Nest after-effects
				callsub Party_Check,.@md_name$;
				callsub Leader_Check; // Pour instance Solo
				callsub Process_Instance,.@md_name$,.@hardmode,.@turbo,.@questid;
				break;
			}
			warp_fct("dali", 85, 64);
		}
		case 11: { // Geffen Magic Tournament
			if( select( (GeffenTournament < gettimetick(2)?"^00A000":"^FF0000")+"Acces direct^000000", "Se rendre sur place" ) == 1 ) {
				.@md_name$ = "Geffen Magic Tournament";
				callsub Party_Check,.@md_name$;
				callsub Leader_Check; // Pour instance Solo

				if( checkquest(9309) != -1 ) {
					for( .@i = 9284; .@i <= 9314; .@i++ )
						if( checkquest(.@i) != -1 )
							erasequest .@i;

					if( checkquest(9315) != -1 )
						changequest 9315,9316;
				}

				if( checkquest(9308) != -1 ) {
					for( .@i = 9284; .@i <= 9314; .@i++ )
						if( checkquest(.@i) != -1 )
							erasequest .@i;

					if (checkquest(9315) != -1)
						changequest 9315,9316;
				}

				if( GeffenTournament < gettimetick(2) ) {
					for (.@i = 9284; .@i <= 9314; .@i++)
						if( checkquest(.@i) != -1 )
							erasequest .@i;
					clear;
					mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
					mes "Cette instance est disponible avec plusieur niveau de difficultķ, Ļtes vous prĻts Ó tenter?";
					mes "^FF0000Attention!!";
					mes "Le timer reste le mĻme pour chaque niveau !! Si vous ķchouez au 5 vous ne pourrez changer la difficultķ.^000000";
					.@hardmode = select( "Facile(1)", "Normal(2)", "Moyen(3)", "", "Difficile(5)", "", "TrĶs Difficile(7)", "", "", "MALADE(10)" );
					callsub Create_Instance,.@md_name$,.@hardmode; // Crķation instance
					if ( BaseLevel < 100 ) {
						mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
						mes "Vous venez Ļtre au moins niveau 100 pour entrer cette instance!";
						close;
					} 
					switch( instance_enter(.@md_name$) ) {
						case IE_NOMEMBER: goto L_NOMEMBER;
						case IE_NOINSTANCE: goto L_NOINSTANCE;
						case IE_OTHER: goto L_OTHER;
						case IE_OK:
						GeffenTournament = gettimetick(2) + 72000; // 20h
						if( checkquest(9316,PLAYTIME) != -1 )
							erasequest 9316;
						setquest 9316;
						end;
					}
				}
				else {
					clear;
					mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
					mes "Vous devez attendre la fin du cooldown.";
					.@time = GeffenTournament - gettimetick(2);
					.@sec = .@time % 60;
					.@min = (.@time / 60) % 60;
					.@hrs = (.@time / 3600) % 24;
					mes "Cooldown: ^3355FF"+(.@hrs < 10 ? "0" : "")+.@hrs+":"+(.@min < 10 ? "0" : "")+.@min+":"+(.@sec < 10 ? "0" : "")+.@sec+"^000000";
					end;
				}
				break;
			}
			warp_fct("dali", 94, 141);
		}
		case 12: { // Ghost Palace
			if( select( GetColor(1261)+"Acces direct^000000", "Se rendre dans le Rift" ) == 1 ) {
				.@md_name$ = "Ghost Palace";
