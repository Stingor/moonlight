function GetColor {
	return ((checkquest(getarg(0),PLAYTIME) == 2 || checkquest(getarg(0),PLAYTIME) == -1)?"^00A000":"^FF0000");
}

Hard_Mode:
	if( is_party_leader(getcharid(1)) == true && (getgroupid() == 99 || getarg(0) != "^FF0000") ) {
		clear;
		mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
		mes "Cette instance est disponible avec plusieur niveau de difficultķ, Ļtes vous prĻts Ó tenter?";
		return select( "Facile(1)", "Normal(2)", "Moyen(3)", "", "Difficile(5)", "", "TrĶs Difficile (7)", "", "", "MALADE (10)" );
	}
	return 1;

Turbo_Mode:
	if( is_party_leader(getcharid(1)) == true && (getgroupid() == 99 || getarg(0) != "^FF0000") ) {
		clear;
		mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
		mes "Cette instance est disponible avec le mode turbo.";
		mes "^FF0000Attention!!";
		mes "une fois activķ vous sauterez la plupart des dialogues!!^000000";
		if( select( "Mode turbo OFF", "Mode turbo ON" ) == 2 )
			return 1;
	}
	return 0;
	
Party_Check: // Check si une party existe bien
	if( instance_check_party(getcharid(1), 1) == 0 ) {
		clear;
		mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
		mes "^0000ff"+getarg(0)+"^000000 - ProblĶme de party";
		mes "Faites une party.";
		close;
	}
	return;

Leader_Check: // Pour instance Solo
	if( is_party_leader(getcharid(1)) == false ) {
		clear;
		mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
		mes "^ff0000Cette instance est Ó faire seul. Seul le party leader peut entrer.^000000";
		close;
	}
	return;

Create_Instance: // Crķation instance
	.@hardmode = getarg(1,1);
	if( .@hardmode < 1 )
		.@hardmode = 1;
	.@turbo = getarg(2,0);
	if( .@turbo < 1 )
		.@turbo = 0;
	if( is_party_leader(getcharid(1)) == true ) {
		if( instance_create(getarg(0), IM_PARTY, getcharid(1), .@hardmode, .@turbo) < 1 ) {
			clear;
			mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
			mes "Party name: " + getpartyname(getcharid(1));
			mes "Character name: " + strcharinfo(0);
			mes "^0000ff" + getarg(0) + "^000000 - Crķation echouķe!";
			close;
		}
		else {
			if( .@hardmode > 1 )
				logmes "Crķation de l'instance: " + getarg(0) + " niveau " + .@hardmode;
			else
				logmes "Crķation de l'instance: " + getarg(0);
		}
	}
	return;

Quick_Enter:
	if ( BaseLevel < 100 ) {
		mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
		mes "Vous venez Ļtre au moins niveau 100 pour entrer cette instance!";
		close;
	} 
	switch( instance_enter(getarg(0)) ) {
		case IE_NOMEMBER:
		case IE_NOINSTANCE:
		case IE_OTHER:
			break;
		case IE_OK:
			end;
	}
	clear;
	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	mes "^ff0000Le timer de cette instance expire Ó 4h du matin.^000000";
	next;
	goto L_Instance;

Process_Instance:
	if( checkquest(getarg(3),PLAYTIME) == 2 )
		erasequest getarg(3); // Reset de la quest cooldown
	if( getgroupid() == 99 ) {
		if( select("bypassgm?", "non") == 1 )
		{
			callsub Create_Instance, getarg(0), getarg(1), getarg(2,0); // Crķation instance
			if( getarg(3,0) != 0 && isbegin_quest(getarg(3,0)))
				erasequest getarg(3);
			if( getarg(4,0) != 0 && isbegin_quest(getarg(4,0)))
				erasequest getarg(4);
			switch( instance_enter(getarg(0)) ) {
				case IE_NOMEMBER: goto L_NOMEMBER;
				case IE_NOINSTANCE: goto L_NOINSTANCE;
				case IE_OTHER: goto L_OTHER;
				case IE_OK:
					if( getarg(4,0) != 0) {
						if( isbegin_quest(getarg(4)) == 0 )
							setquest getarg(4); // Set de la quest bonus
					}
					setquest getarg(3); // Set de la quest cooldown
					end;
			}
			end;
		}
	}
	switch( checkquest(getarg(3),PLAYTIME) ) {
		case -1:
			clear;
			mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
			mes "^ff0000Si vous mourrez ou sortez vous ne pourrez plus entrer de nouveau.^000000";
			if( select("-:Ok:-") == 2 ) next;
			else close;
			callsub Create_Instance, getarg(0), getarg(1); // Crķation instance
			if ( BaseLevel < 100 ) {
				mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
				mes "Vous venez Ļtre au moins niveau 100 pour entrer cette instance!";
				close;
			} 
			switch( instance_enter(getarg(0)) ) {
				case IE_NOMEMBER: goto L_NOMEMBER;
				case IE_NOINSTANCE: goto L_NOINSTANCE;
				case IE_OTHER: goto L_OTHER;
				case IE_OK:
					if( getarg(4,0) != 0) {
						if( isbegin_quest(getarg(4)) == 0 )
							setquest getarg(4); // Set de la quest bonus
					}
					setquest getarg(3); // Set de la quest cooldown
					end;
			}
			end;
		case 0:
		case 1:
			// if( is_party_leader(getcharid(1)) == true )
				// callsub Quick_Enter,getarg(0); end;
		case 2:
			clear;
			mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
			mes "^ff0000Vous devez attendre le reset de votre instance.^000000";
			close;
	}
	end;

L_NOMEMBER:
	clear;
	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	mes "^ff0000Vous n'avez plus de party ?^000000";
	close;
L_NOINSTANCE:
	clear;
	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	mes "^ff0000L'instance ne semble pas Ļtre gķnķrķe.^000000";
	close;
L_OTHER:
	clear;
	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	mes "Une erreur est survenue.";
	close;

L_Autre:
	clear;
	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	mes "Sķlectionnez la destination de votre choix :";
	switch( select("Ģ Forge:Ģ Shop armement:Ģ Eden Group:Ģ Flame Bassin:Ģ Mid Camp:Ģ Seals:Ģ Yggdrasil:Ģ ^e64c00Menu Prķcķdent.^000000") ) {
		case 1: warp_fct("gon_in", 94, 21);
		case 2: warp_fct("gon_in", 163, 23);
		case 3: warp_fct("moc_para01", 31, 14);
		case 4: warp_fct("moro_vol");
		case 5: warp_fct("mid_camp", 220, 235);
		case 6: warp_fct("cmd_fild02", 193, 169);
		case 7: warp_fct("yggdrasil01", 52, 63);
		default: goto L_warpa;
	}
	end;

L_Fields:
	clear;
	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	mes "Sķlectionnez le <<Field>> de votre choix :";
	// Ajouter un field: une ligne dans le menu + un label L_fld_xxx ci-dessous
	menu "Ģ Amatsu (ama_fild)",           L_fld_ama,
		 "Ģ Ayothaya (ayo_fild)",          L_fld_ayo,
		 "Ģ Bifrost (bif_fild)",           L_fld_bif,
		 "Ģ Brasilis (bra_fild)",          L_fld_bra,
		 "Ģ Comodo (cmd_fild)",            L_fld_cmd,
		 "Ģ Dewata (dew_fild)",            L_fld_dew,
		 "Ģ Eclage (ecl_fild)",            L_fld_ecl,
		 "Ģ Einbroch (ein_fild)",          L_fld_ein,
		 "Ģ El Dicastes (dic_fild)",       L_fld_dic,
		 "Ģ Geffen (gef_fild)",            L_fld_gef,
		 "Ģ Hugel (hu_fild)",              L_fld_hug,
		 "Ģ Kiwawa (Rockridge - rockrdg)", L_fld_roc,
		 "Ģ Kunlun (Gonryun - gon_fild)",  L_fld_gon,
		 "Ģ Lasagna (lasa_fild)",          L_fld_las,
		 "Ģ Lighthalzen (lhz_fild)",       L_fld_lhz,
		 "Ģ Louyang (lou_fild)",           L_fld_lou,
		 "Ģ Lutie (xmas_fild)",            L_fld_xma,
		 "Ģ Malaya (ma_fild)",             L_fld_mal,
		 "Ģ Manuk (man_fild)",             L_fld_man,
		 "Ģ Mjolnir (mjolnir)",            L_fld_mjo,
		 "Ģ Moscovia (mosk_fild)",         L_fld_mos,
		 "Ģ Nameless Island",              L_fld_nam,
		 "Ģ Niflheim (nif_fild)",          L_fld_nif,
		 "Ģ Payon (pay_fild)",             L_fld_pay,
		 "Ģ Prontera (prt_fild)",          L_fld_prt,
		 "Ģ Rachel (ra_fild)",             L_fld_rac,
		 "Ģ Sograt (Morocc - moc_fild)",   L_fld_moc,
		 "Ģ Splendide (spl_fild)",         L_fld_spl,
		 "Ģ Umbala (um_fild)",             L_fld_umb,
		 "Ģ Veins (ve_fild)",              L_fld_vei,
		 "Ģ Juno (yuno_fild)",             L_fld_yun,
		 "Ģ ^e64c00Menu Prķcķdent.^000000", -;
	goto L_warpa;
	end;

L_fld_ama: warpmenu("ama_fild01"); goto L_Fields; end;
L_fld_ayo: warpmenu("ayo_fild01", "ayo_fild02"); goto L_Fields; end;
L_fld_bif: warpmenu("bif_fild01", "bif_fild02"); goto L_Fields; end;
L_fld_bra: warpmenu("bra_fild01"); goto L_Fields; end;
L_fld_cmd: warpmenu("cmd_fild01", "cmd_fild02", "cmd_fild03", "cmd_fild04", "cmd_fild05",
					"cmd_fild06", "cmd_fild07", "cmd_fild08", "cmd_fild09"); goto L_Fields; end;
L_fld_dew: warpmenu("dew_fild01"); goto L_Fields; end;
L_fld_ecl: warpmenu("ecl_fild01"); goto L_Fields; end;
L_fld_ein: warpmenu("ein_fild01", "ein_fild02", "ein_fild03", "ein_fild04", "ein_fild05",
					"ein_fild06", "ein_fild07", "ein_fild08", "ein_fild09", "ein_fild10"); goto L_Fields; end;
L_fld_dic: warpmenu("dic_fild01", "dic_fild02"); goto L_Fields; end;
