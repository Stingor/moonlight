		case 8: warp_fct("tha_t08", 29, 44);
		case 9: warp_fct("tha_t09", 87, 146);
		case 10:warp_fct("tha_t10");
		case 11:warp_fct("tha_t11");
		case 12:warp_fct("tha_t12");
		case 13:
			if( $@thana_summon >= 6 && $@thana_summon_name$ == "" ) {
				clear;
				mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
				mes "Thanatos est dķjÓ mort.";
				mes $@thana_summon_name_$+" l'a tuķ Ó "+gettimestr("%H:%M:%S",21,$@thana_summon_time);
				close;
			}
			else {
				if( $@thana_summon_name$ != "" ) {
					if( $@thana_summon_name$ != strcharinfo(0)
						&& getcharid(1, $@thana_summon_name$) != 0
						&& getcharid(1) != 0
						&& getcharid(1, $@thana_summon_name$) == getcharid(1)
						&& $@thana_summon2 > 0) {
						clear;
						mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
						mes $@thana_summon_name$+" a commencķ l'invocation.";
						close2;
						warp_fct("thana_boss", 142, 222);
						end;
					}
					else if( $@thana_summon_name$ != strcharinfo(0) && $@thana_summon2 > 0 ) {
						clear;
						mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
						mes $@thana_summon_name$+" invoque actuellement Thanatos, vous ne pouvez acceder Ó cet ķtage.";
						close;
					}
				}
			}
			warp_fct("thana_boss", 142, 222);
	}
end;
L_thor:
	switch( select("Ģ Niveau 1:Ģ Niveau 2:Ģ Niveau 3") ) {
		case 1: warp_fct("thor_v01", 20, 230);
		case 2: warp_fct("thor_v02", 80, 204);
		case 3: warp_fct("thor_v03", 34, 272);
	}
end;
L_toy:
	if( select("Ģ Niveau 1:Ģ Niveau 2") == 1 )
		warp_fct("xmas_dun01", 205, 21);
	else
		warp_fct("xmas_dun02", 130, 135);
end;
L_tur:
	switch( select("Ģ Entrķe:Ģ Niveau 1:Ģ Niveau 2:Ģ Niveau 3") ) {
		case 1: warp_fct("tur_dun01", 159, 36);
		case 2: warp_fct("tur_dun02", 148, 263);
		case 3: warp_fct("tur_dun03", 132, 189);
		case 4: warp_fct("tur_dun04", 100, 190);
	}
end;
L_wer: warp_fct("slabw01", 14, 88); end;
L_ygg: warp_fct("nyd_dun01", 54, 70); end;

L_Rooms:
	clear;
	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	mes "Sķlectionnez la salle de votre choix :";
	switch( select("Ģ Carnage Room [ ^FF0000"+getmapusers("pvp_n_3-5")+"^000000 joueur(s) ]:Ģ PvP Room [ ^FF0000"+getmapusers("pvp_n_4-1")+"^000000 joueur(s) ]:Ģ Duel Room [ ^FF0000"+getmapusers("pvp_n_2-1")+"^000000 joueur(s) ]:Ģ GvG Room [ ^FF0000"+getmapusers("pvp_n_5-1")+"^000000 joueur(s) ]:Ģ DB Room [ ^FF0000"+getmapusers("pvp_n_1-1")+"^000000 joueur(s) ]:Ģ BB Room [ ^FF0000"+getmapusers("pvp_n_3-1")+"^000000 joueur(s) ]:Ģ Test Room [ ^FF0000"+getmapusers("pvp_n_5-5")+"^000000 joueur(s) ]:Ģ ^e64c00Menu Prķcķdent.^000000") ) {
		case 1:	// Carnage Room
			callsub Check_Buffs;
			warp_fct("pvp_n_3-5");
			break;
		case 2:	// PvP Room
			clear;
			mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
			mes "N'oubliez-pas que dans cette salle, battez vous de fańon loyal...";
			mes "Freekill interdit et punissable.";
			mes "Fairplay oblige.";
			if( select("Entrer en PvP Room", "Non merci,j'ai peur.") == 1 ) {
				callsub Check_Buffs;
				warp_fct("pvp_n_4-1", 105, 71);
				end;
			}
			else
				goto L_warpa;
			break;
		case 3:	// Duel Room
			warp_fct("pvp_n_2-1", 105, 71);
			break;
		case 4:	// GvG Room
			clear;
			mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
			mes "N'oubliez-pas que dans cette salle, battez vous de fańon loyal...";
			mes "Freekill interdit et punissable.";
			mes "Fairplay oblige.";
			if( select("Entrer en GvG Room", "Non merci,j'ai peur.") == 1 ) {
				callsub Check_Buffs;
				warp_fct("pvp_n_5-1", 105, 64);
				end;
			}
			else
				goto L_warpa;
			break;
		case 5: warp_fct("pvp_n_1-1", 104, 71);	// DB room
		case 6: warp_fct("pvp_n_3-1", 104, 71);	// BB room
		case 7: warp_fct("pvp_n_5-5");		// Test Room
		default: goto L_warpa;
	}
	end;

Check_Buffs:
	if( getstatus(SC_CP_WEAPON) || getstatus(SC_CP_ARMOR) || getstatus(SC_CP_SHIELD) || getstatus(SC_CP_HELM) || getstatus(SC_SPIRIT) ) {
		next;
		mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
		mes "Vous Ļtes sur le point d'entrer en pvp avec une protection d'Alchemist et/ou un boost Soul Linker.";
		mes "Vous allez Ļtre dispell de ce buff, Ļtes vous certain de vouloir rentrer ?";
		if( select("Non:Oui") == 1 )
			close;
		close2;
		sc_end SC_CP_WEAPON;
		sc_end SC_CP_ARMOR;
		sc_end SC_CP_SHIELD;
		sc_end SC_CP_HELM;
		sc_end SC_SPIRIT;
	}
	return;

L_Save:
	clear;
L_SaveCmd:
	mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
	atcommand "@save";
	mes "Ton point de sauvegarde est Ó prķsent Ó l'endroit o∙ tu es placķ.";
	mes "Bon jeu !";
	close;

OnInit:
	if( strnpcinfo(3) == "warp_agent" ) {
		defpattern 1, "([^:]+):.*\\s@warp.*", "L_WarpaCmd";
		defpattern 1, "([^:]+):.*\\s@go.*", "L_VillesCmd";
		defpattern 1, "([^:]+):.*\\s@save.*", "L_SaveCmd";
		activatepset 1;
	}
	end;
}

