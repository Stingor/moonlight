		case 25: { // Sarah and Fenrir
			if( select( GetColor(9336)+"Acces direct^000000", "Se rendre dans le Rift" ) == 1 ) {
				.@md_name$ = "Fenrir and Sarah";
				.@questid = 9336; // Go back to Professor Bernhard
				callsub Party_Check,.@md_name$;

				if( checkquest(.@questid,PLAYTIME) == 2 ) {
					erasequest .@questid; // Reset de la quest cooldown
					if( isbegin_quest(9337) > 0 )
						erasequest 9337; // Wrapping up the Adventure
				}
				if( isbegin_quest(9335) == 1 ) {
					if( sarah_fenrir == 0 )
						.@s = select( "The left earring of Sarah", "The right earring of Sarah" ) - 1;
					erasequest 9335;// Search for shards of Gigantes
					if( sarah_fenrir == 0 ) {
						sarah_fenrir = 1;
						getitem (28310+.@s),1;
					}
				}
				if( isbegin_quest(9335) == 0 )
					setquest 9335;

				switch( checkquest(.@questid,PLAYTIME) ) {
					case -1:
						callsub Create_Instance,.@md_name$,.@hardmode; // Crķation instance
						if ( BaseLevel < 100 ) {
							mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
							mes "Vous venez Ļtre au moins niveau 100 pour entrer cette instance!";
							close;
						} 
						switch( instance_enter(.@md_name$) ) {
							case IE_NOMEMBER: goto L_NOMEMBER;
							case IE_NOINSTANCE: goto L_NOINSTANCE;
							case IE_OTHER: goto L_OTHER;
							case IE_OK:
								setquest .@questid; // Set de la quest cooldown
								end;
						}
						end;
					case 0:
					case 1:
						callsub Quick_Enter,.@md_name$;
				}
				break;
			}
			warp_fct("dali02", 92, 141);
		}
