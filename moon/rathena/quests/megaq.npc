		{
			mes "[^996666Marshmesmow^000000]";
			mes "Hello voyageur !";
			sleep2 1500;
			mes "[^996666Marshmesmow^000000]";
			mes "Pourquoi ne faites-vous plus parti du club qui cartonne ?";
			close;
		}
		#MEGAQ1VAL7 = max(0, #MEGAQ1VAL7);
		#MEGAQ1VAL8 = max(0, #MEGAQ1VAL8);
		#MEGAQ1VAL9 = max(0, #MEGAQ1VAL9);
		if( #MEGAQ1VAL7 <= 0 && #MEGAQ1VAL8 <= 0 && #MEGAQ1VAL9 <= 0 )
		{
L_label:
			mes "[^996666Marshmesmow^000000]";
			mes "Parfait... En marche pour la startup nation comme dirait l'autre c**.";
			sleep2 2500;
			mes "Je sais je ne marsh pas mes mow.";
			sleep2 500;
			mes "...";
			sleep2 500;
			mes "...";
			sleep2 500;
			mes "...";
			sleep2 500;
			mes "...";
			sleep2 500;
			mes "... XD";
			sleep2 1500;
			clear;
			mes "[^996666Marshmesmow^000000]";
			mes "Un petit cadeau pour vous remercier toussa toussa.";
			sleep2 1000;
			getitem 7719,1;
			if( countitem(7719) ) #MEGAQ1 = 19;
			close;
		}
		mes "[^996666Marshmesmow^000000]";
		mes "Je ne sais pas quoi dire en ce moment désolé....";
		switch( select("Je ne me souviens plus de ce qu'il faut", "J'ai une partie de ce qu'il faut", "J'ai tout ce qu'il faut") )
		{
			clear;
			.@val7 = min(#MEGAQ1VAL7, countitem(7111));
			.@val8 = min(#MEGAQ1VAL8, countitem(1024));
