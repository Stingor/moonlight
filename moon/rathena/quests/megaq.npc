xmas_dun02,236,152,3	script	#dolldistrib::npcq_dolldist	562,{
	if( #MEGAQ1 == 35 )
	{
		.@frappe = 0;
		mes "La machine semble ne pas fonctionner correctement.";
L_menu1:
		if( select( "Frapper la machine", "Inspecter la machine" ) == 1 )
		{
			clear;
			.@frappe++;
			if( .@frappe == 1 )
				mes "Vous frappez la machine mais celà ne change rien.";
			else if( .@frappe == 2 )
				mes "Vous frappez de nouveau la machine, des leds clignotent sur la façade.";
			else if( .@frappe == 3 )
				mes "Vous frappez encore une fois la machine, un message d'erreur apparaît à l'écran.";
			else if( .@frappe == 4 )
			{
				mes "Vous la frappez de nouveau, cette fois une alarme retentit, le bruit est assourdissant, vous partez.";
				.@frappe = 0;
				next;
				warp "SavePoint",0,0;
				end;
			}
			goto L_menu1;
		}
		clear;
		mes "L'écran affiche un numéro d'erreur.";
		mes "E01-32";
L_menu4:
		if( select( "Appuyer sur le bouton menu", "Faire le tour de la machine" ) == 1 )
		{
			.@attemptpass = 0;
			clear;
L_menu2:
			mes "Le menu est bloqué par un mot de passe.";
			input .@var$;
			if( .@var$ == "B055man69" || .@var$ == "B055 man69" || .@var$ == "BØ55man69" || .@var$ == "BØ55 man69" ) {
				mes "Le menu s'ouvre laissant apparaître plusieurs sous-menus.";
L_menu3:
				if( @qprixdist ) @qprixdist$ = "Prix - "+@qprixdist+"z";
				else @qprixdist$ = "Prix";
				if( @qchancedist ) @qchancedist$ = "Chance - "+@qchancedist+"%";
				else @qchancedist$ = "Chance";
				if( @qacquit ) @qacquit$ = "";
				else @qacquit$ = "Acquitter Erreur";
				switch( select(@qprixdist$, @qchancedist$, @qacquit$, "Reboot", "Utiliser la machine") )
				{
					clear;
					case 1:
						mes "Le menu sert à fixer le prix d'un essai.";
						mes "Doit être compris entre 1.000.000z et 50.000.000z.";
						input @qprixdist,1000000,50000000;
						next;
						goto L_menu3;
					case 2:
						mes "Le menu sert à fixer les chances de réussir à attraper une poupée.";
						mes "Doit être compris entre 10 et 90.";
						input @qchancedist,10,90;
						next;
						goto L_menu3;
					case 3:
						if( @qacquit ) {
							mes "Aucune Erreur.";
							goto L_menu3;
						}
						mes "Le menu sert à acquitter le défaut.";
						if( select("Acquitter", "Retour") == 2 )
							goto L_menu3;
						@qacquit = 1;
						next;
						goto L_menu3;
					case 4:
						if( @qacquit ) {
							mes "La machine redémarre.";
							goto L_menu4;
						}
						mes "La machine redémarre, celà retire le défaut.";
						if( select("Reboot", "Retour") == 2 )
							goto L_menu3;
						@qacquit = 1;
						next;
						goto L_menu4;
L_menu5:
					default:
						if( @qacquit && @qprixdist && @qchancedist ) {
							mes "La machine vous réclame "+@qprixdist+"z.";
							mes "Vous apercevez une carte bleue parmi les porings dolls.";
							if( select( "Jouer", "Appuyer sur le bouton menu" ) == 2 )
							{
								clear;
								goto L_menu2;
							}
							else
							{
								if( Zeny < @qprixdist )
								{
									mes "Vous n'avez pas assez d'argent.";
									mes "Peut-être pouvez-vous changer les paramètres...";
									next;
									goto L_menu3;
								}
								Zeny -= @qprixdist;
								if ( rand(1,100) < @qchancedist )
								{
									clear;
									mes "Vous gagnez une Poring Doll.";
									mes "Vous apercevez toujours la carte bleue parmis les dolls.";
									getitem 741,1;
									next;
									if ( Zeny >= @qprixdist ) goto L_menu5;
									else
									{
										mes "Vous n'avez plus assez d'argent.";
										close;
									}
								}
								else
								{
									mes "Vous avez réussi à obtenir la carte.";
									sleep2 1000;
									getitem 7466,1;
									if( countitem(7466) ) #MEGAQ1 = 36;
									if( getgroupid() >= 80 ) {
										sleep2 3000;
										warp "gonryun",160,97;
										end;
									}
									close;
								}
							}
						}
						mes "La machine n'est pas prête à être utilisée.";
						goto L_menu4;
				}
				close;
			}
			else
			{
				.@attemptpass++;
				mes "Mot de passe incorrect.";
				if( .@attemptpass >= 3 )
				{
					mes "Au bout du 3éme essai, une alarme retentit, le bruit est assourdissant, vous partez.";
					.@attemptpass = 0;
					next;
					warp "SavePoint",0,0;
					end;
				}
				next;
				goto L_menu2;
			}
		}
		clear;
		mes "Vous repérez une plaque constructeur.";
		mes "Propriété de Nolan Sorrento.";
		mes "Innovative Online Industries.";
		sleep2 2500;
		mes "^0080ffOK, je devrais peut-être Google ça.^000000";
		goto L_menu4;
		end;
	}
	else if( #MEGAQ1 == 36 )
	{
		mes "Vous n'avez vraiment plus envie de jouer.";
		close;
		
	}
	end;
}

