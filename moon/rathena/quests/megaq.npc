				if( #MEGAQ1VAL8 ) mes #MEGAQ1VAL8+" <ITEM>"+getitemname(1024)+"<INFO>1024</INFO></ITEM>";
				if( #MEGAQ1VAL9 ) mes #MEGAQ1VAL9+" <ITEM>"+getitemname(938)+"<INFO>938</INFO></ITEM>";
				close;
