		sleep2 2000;
		mes "[^996666Tic^000000]";
		mes "En temps normal nous ne sommes pas de mauvais enquêteurs...";
		sleep2 3000;
		clear;
		mes "[^996666Tac^000000]";
		mes "...mais avec le ventre vide c'est une autre histoire...";
