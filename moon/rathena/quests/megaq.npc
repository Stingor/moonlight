		if( #MEGAQ1 == 11 ) #MEGAQ1 = 12;
		if( getgroupid() >= 80 ) {
			sleep2 3000;
			warp "gonryun",160,97;
			end;
		}
		close2;
		sleep2 1000;
		npctalk "* SsSssss *","npcq_creeper",bc_area;
		atcommand "@nuke " + strcharinfo(0);
		end;
	}
	else
	{
		npctalk "* SsSssss *","npcq_creeper",bc_area;
		atcommand "@nuke " + strcharinfo(0);
		end;
	}
	end;
}

alberta,196,146,3	script	Ekard::npcq_ekard	969,{
	if( getgroupid() >= 80 )
	{
		@killdrake = 1;
	}
	if( #MEGAQ1 < 12 )
	{
		mes "...";
		close;
	}
	if( #MEGAQ1 == 12 )
	{
		#MEGAQ1VAL5 = 947;
		#MEGAQ1VAL6 = 59;
		mes "^0080ffEkard?^000000";
		sleep2 1500;
		mes "[^91666AEkard^000000]";
		mes "Ah enfin, voilà la personne de la situation.";
		sleep2 2500;
		clear;
		mes "[^91666AEkard^000000]";
		mes "Mon cousin Drake m'a fait une grosse crasse de p***.";
		sleep2 1500;
		mes "Je souhaiterais que vous le tuiez.";
		mes "Il se trouve (...) dtc, enfin quoi merde vous savez où il est.";
		#MEGAQ1 = 13;
		close;
	}
	else if( #MEGAQ1 == 13 || #MEGAQ1 == 14 )
	{
		if( !@killdrake && #MEGAQ1 == 13 )
		{
			mes "[^91666AEkard^000000]";
			mes "Ca te sert à quoi de revenir si t'as pas encore tué Drake dans le Sunken Ship ?";
			close;
		}
		
		if( #MEGAQ1 == 13 ) #MEGAQ1 = 14;
		mes "[^91666AEkard^000000]";
		mes "Parfait ma vengeance est accomplie!";
		sleep2 1000;
		mes "...";
		sleep2 1500;
		clear;
		mes "^0080ffEt maintenant?^000000";
		sleep2 1500;
		mes "[^91666AEkard^000000]";
		mes "Je souhaiterais me refaire une beauté, une jambe de bois neuve pour tout dire, ainsi que nourrir mon corbak.";
		sleep2 5500;
		clear;
		mes "[^91666AEkard^000000]";
		mes "Pour celà, il me faudrait :";
		mes #MEGAQ1VAL5+" <ITEM>"+getitemname(7201)+"<INFO>7201</INFO></ITEM>";
		mes #MEGAQ1VAL6+" <ITEM>"+getitemname(6903)+"<INFO>6903</INFO></ITEM>";
		mes "Ces vers se drop sur les Li Me Mang Ryang.";
		if( getgroupid() >= 80 ) {
			getitem 7201,#MEGAQ1VAL5;
			getitem 6903,#MEGAQ1VAL6;
		}
		#MEGAQ1 = 15;
		sleep2 5000;
		mes "[^91666AEkard^000000]";
		mes "Oui, il faut beaucoup d'essais pour craft une belle jambe de bois !";
		close;
	}
	else if( #MEGAQ1 == 15 )
	{
		#MEGAQ1VAL5 = max(0, #MEGAQ1VAL5);
		#MEGAQ1VAL6 = max(0, #MEGAQ1VAL6);
		if( #MEGAQ1VAL5 <= 0 && #MEGAQ1VAL6 <= 0 )
		{
L_label:
			mes "[^996666Ekard^000000]";
			mes "Ah! Bien bien bien.";
			sleep2 1000;
			mes "[^996666Ekard^000000]";
			mes "Bon vous m'avez déjà rendu un grand service en exécutant mon couz.";
			sleep2 3500;
			clear;
			mes "[^996666Ekard^000000]";
			mes "Et là chapeau, vous me comblez, tenez, un petit cadeau pour la suite.";
			sleep2 1000;
			getitem 7599,1;
			getitem 7462,1;
			if( countitem(7599) && countitem(7462) ) #MEGAQ1 = 16;
			close;
		}
		mes "[^996666Ekard^000000]";
		mes "Cyka Blyat matelot.";
		switch( select("Je ne me souviens plus de ce qu'il faut", "J'ai une partie de ce qu'il faut", "J'ai tout ce qu'il faut") )
		{
			clear;
			.@val5 = min(#MEGAQ1VAL5, countitem(7201));
			.@val6 = min(#MEGAQ1VAL6, countitem(6903));
			case 1:
				mes "[^996666Ekard^000000]";
				if( #MEGAQ1VAL5 ) mes #MEGAQ1VAL5+" <ITEM>"+getitemname(7201)+"<INFO>7201</INFO></ITEM>";
				if( #MEGAQ1VAL6 ) mes #MEGAQ1VAL6+" <ITEM>"+getitemname(6903)+"<INFO>6903</INFO></ITEM>";
				mes "Ces vers se drop sur les Li Me Mang Ryang.";
				close;
			case 2:
			default:
				if( .@val5 || .@val6 )
				{
					if( .@val5 && #MEGAQ1VAL5 > 0 )
					{
						delitem 7201, .@val5;
						#MEGAQ1VAL5 -= .@val5;
					}
					if( .@val6 && #MEGAQ1VAL6 > 0 )
					{
						delitem 6903, .@val6;
						#MEGAQ1VAL6 -= .@val6;
					}
					if( #MEGAQ1VAL5 <= 0 && #MEGAQ1VAL6 <= 0 )
						goto L_label;
					mes "[^996666Ekard^000000]";
					mes "C'est mieux que rien...";
					mes "Il manque encore "+( #MEGAQ1VAL5 ? #MEGAQ1VAL5+" <ITEM>"+getitemname(7201)+"<INFO>7201</INFO></ITEM>"+( #MEGAQ1VAL6 ? " et ":"" ):"" )+( #MEGAQ1VAL6 ? #MEGAQ1VAL6+" <ITEM>"+getitemname(6903)+"<INFO>6903</INFO></ITEM>" : "" );
					close;
				}
				if( #MEGAQ1VAL5 <= 0 && #MEGAQ1VAL6 <= 0 )
					goto L_label;
				mes "[^996666Ekard^000000]";
				mes "Bien essayé mais il manque encore "+( #MEGAQ1VAL5 ? #MEGAQ1VAL5+" <ITEM>"+getitemname(7201)+"<INFO>7201</INFO></ITEM>"+( #MEGAQ1VAL6 ? " et ":"" ):"" )+( #MEGAQ1VAL6 ? #MEGAQ1VAL6+" <ITEM>"+getitemname(6903)+"<INFO>6903</INFO></ITEM>" : "" );
				mes "Un petit effort....";
				close;
		}
		end;
	}
	else if( #MEGAQ1 >= 16 )
	{
		mes "[^996666Ekard^000000]";
		mes "Bon cassez vous maintenant, retournez voir les deux tronfions d'écureuil.";
		if( getgroupid() >= 80 ) {
			sleep2 3000;
			warp "gonryun",160,97;
			end;
		}
		close;
	}
	end;
}

comodo,207,309,3	script	Marshmesmow::npcq_marsh	10287,{
