		sleep2 1900;
		mes "[^996666Marshmesmow^000000]";
		mes "Allez voir ma copine Jacqueline dans Toy Factory 1.";
		if( getgroupid() >= 80 ) {
			sleep2 3000;
			warp "xmas_dun01",79,37;
			end;
		}
		navigateto "xmas_dun01",79,37,NAV_NONE;
