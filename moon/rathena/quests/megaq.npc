						#MEGAQ1VAL9 -= .@val9;
					}
					if( #MEGAQ1VAL7 <= 0 && #MEGAQ1VAL8 <= 0 && #MEGAQ1VAL9 <= 0 )
						goto L_label;
				}
				mes "[^996666Marshmesmow^000000]";
				mes "Bien essayé mais il manque encore "+
				( #MEGAQ1VAL7 ? #MEGAQ1VAL7+" <ITEM>"+getitemname(7111)+"<INFO>7111</INFO></ITEM>"+( #MEGAQ1VAL8 || #MEGAQ1VAL9 ? " et ":"" ) : "" )+
				( #MEGAQ1VAL8 ? #MEGAQ1VAL8+" <ITEM>"+getitemname(1024)+"<INFO>1024</INFO></ITEM>"+( #MEGAQ1VAL9 ? " et ":"" ) : "" )+
				( #MEGAQ1VAL9 ? #MEGAQ1VAL9+" <ITEM>"+getitemname(938)+"<INFO>938</INFO></ITEM>" : "" );
