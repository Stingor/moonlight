prt_church,100,128,4	script	PrĻtre#w	1_M_PASTOR,{
	cutin "wedding_bomars01",2;
	if( Upper == 2 ) {
		mes "[Vomars]";
		mes "Bonjour mon enfant.";
		mes "Es-tu perdu? Hum... O∙ sont ton papa et ta maman?";
		close2;
		cutin "wedding_bomars01",255;
		end;
	}

	if( !getpartnerid() ) {
		if( !$wedding ) {
			if( wedding_sign == 1 ) {
				getpartymember(getcharid(1));
				.@partymembercount = $@partymembercount;
				if( .@partymembercount == 2 ) {
					if( is_party_leader() ) {
						$wedding = 1;
						initnpctimer;
						mes "[Vomars]";
						mes "Jeunes amants, que ce jour reste Ó jamais gravķ dans vos mķmoires. Que votre futur soit paisible et bķni de joie. Que l'amour que vous partagez ne cesse de grandir chaque jour.";
						next;
						mapannounce "prt_church","Monsieur "+strcharinfo(0)+" est sur le point de se marier...",bc_map;
						mes "[Vomars]";
						mes "Jusqu'Ó la fin de votre vie,vous devrez rester aux c¶tķs de celle que vous aimez, l'aider et la protķger Ó n'importe quel prix.";
						mes "Puis-je maintenant connaŅtre le nom de votre future ķpouse?";
						input $wed_bride$;
						clear;
						mes "[Vomars]";
						mes "Monsieur "+strcharinfo(0)+"...";
						mes "Jurez-vous de chķrir Mademoiselle "+$wed_bride$+", de l'aimer de prendre soin d'elle, jusqu'Ó ce que la mort vous sķpare?";
						select("Je le jure.");
						clear;
						$wed_groom$ = strcharinfo(0);
						mes "[Vomars]";
						mes "C'est maintenant au tour de votre future ķpouse de prononcer ses voeux. Qu'elle s'avance vers moi...";
						close2;
						mapannounce "prt_church","Monsieur "+strcharinfo(0)+" a prononcķ ses voeux envers Mademoiselle "+$wed_bride$+"...",bc_map;
						cutin "",255;
						end;
					}
					mes "[Vomars]";
					mes "Je suis dķsolķ, mais le futur ķpoux doit venir me parler en premier afin de commencer la cķrķmonie. Je suis attachķ au protocole,vous savez.";
					goto L_End;
				}
				mes "[Vomars]";
				mes "Avant de pouvoir vous marier,vous devez crķer un groupe dont vous serez les deux seuls membres. Une fois ceci fait,la cķrķmonie pourra commencer.";
				goto L_End;
			}
			mes "[Vomars]";
			mes "Avant de pouvoir vous marier,vous devez vous inscrire auprĶs de Marry. Elle vous fournira ķgalement tous les renseignements concernant la procķdure du mariage.";
			goto L_End;
		}
		else if( $wedding == 1 ) {
			if( wedding_sign == 1 ) {
				getpartymember(getcharid(1));
				.@partymembercount = $@partymembercount;
				if( .@partymembercount == 2 ) {
					if( !is_party_leader() ) {
						if( strcharinfo(0) == $wed_bride$ ) {
							mes "[Vomars]";
							mes "Jeunes amants, que ce jour reste Ó jamais gravķ dans vos mķmoires. Que votre futur soit paisible et bķni de joie. Que l'amour que vous partagez ne cesse de grandir chaque jour.";
							next;
							mapannounce "prt_church",$wed_bride$+" est sur le point de se marier...",bc_map;
							mes "[Vomars]";
							mes $wed_bride$+"...";
							mes "Jurez-vous de rester fidĶle Ó "+$wed_groom$+", de l'aimer et de rester Ó ses c¶tķs et ce jusqu'Ó ce que la mort vous sķpare?";
							if( select("^FF0000Non.^000000:Oui,je le jure.") == 1 ) {
								clear;
								cutin "wedding_bomars03",2;
								mapannounce "prt_church",$wed_groom$+" a refusķ la demande...",bc_map;
								mes "[Vomars]";
								mes "Alors, vous pensez que "+$wed_groom$+" n'est pas celui que vous devez ķpouser?";
								mes "Je vous prķsente mes excuses pour cet incident...";
								set $wedding,0;
								close2;
								stopnpctimer;
								cutin "",255;
								end;
							}
							mes "[Vomars]";
							mes "Jurez-vous de lui rester Ó jamais fidĶle? De partager ses souffrances comme ses joies?";
							mes "Souhaitez-vous de tout votre coeur ķpouser "+$wed_groom$+"?";
							if( select("Oui, je le veux.:^FF0000Non.^000000") == 1 ) {
								clear;
								if( isloggedin(getcharid(3,$wed_groom$)) ) {
									if( marriage($wed_groom$) ) {
										//Call Wedding effect
										wedding;
										//Give ring to Bride,and change to wedding sprite.
										sc_start SC_Wedding,3600000,1;
										getitem 2635,1; //Bride_Ring
										//Give ring to Groom,and change to wedding sprite.
										attachrid(getcharid(3,$wed_groom$));
										sc_start SC_Wedding,3600000,1;
										getitem 2634,1; //Bridegroom_Ring
										detachrid;
										//Switch Script progression back to Bride
										attachrid(getcharid(3,$wed_bride$));
										cutin "wedding_bomars02",2;
										mes "[Vomars]";
										mes "Que votre futur soit aussi bķni par la joie divine.";
										$wed_groom$ = "";
										$wed_bride$ = "";
										$wedding = 0;
										close2;
										stopnpctimer;
										cutin "",255;
										detachrid;
										end;
									}
								}
								cutin "wedding_bomars03",2;
								mes "[Vomars]";
								mes "Hum. Il semblerait que votre futur ķpoux se soit dķfilķ avant la fin de la cķrķmonie. Il vous faudra certainement reprendre la cķrķmonie dĶs son retour.";
								goto L_End;
							}
							else {
								cutin "wedding_bomars03",2;
								mapannounce "prt_church",$wed_bride$+" a refusķ d'ķpouser "+$wed_groom$+"!",bc_map;
								mes "[Vomars]";
								mes "Hum. Il semblerait que vous ayiez changķ d'avis. Vous m'en voyez trĶs peinķ. Vous avez certainement brisķ le coeur de ce garńon Ó tout jamais...";
							}
							$wed_groom$ = "";
							$wed_bride$ = "";
							$wedding = 0;
							close2;
							stopnpctimer;
							cutin "",255;
							end;
						}
						callsub S_Busy;
					}
					callsub S_Busy;
				}
				callsub S_Busy;
			}
			if( strcharinfo(0) == $wed_bride$ ) {
				mes "[Vomars]";
				mes "Hum? On dirait que Marry n'a pas reńu votre inscription. Allez lui parler, et nous pourrons commencer la cķrķmonie.";
				goto L_End;
			}
			callsub S_Busy;
		}
		callsub S_Busy;
	}
	mes "[Vomars]";
	mes "Je vous souhaite un bonheur ķternel. Peu importe la noirceur du prķsent, restez prķsent aux c¶tķs de votre Ōme soeur et regardez vers le futur avec confiance et espoir.";

L_End:
	close2;
	cutin  "",255;
	end;

S_Busy:
	if( $wed_groom$ != "" && $wed_bride$ != "" ) {
		mes "[Vomars]";
		mes "Le mariage de Mademoiselle "+$wed_bride$+" et Monsieur "+$wed_groom$+" est actuellement en cours. Merci de ne pas gĻner le dķroulement de la cķrķmonie.";
		goto L_End;
	}
	mes "[Vomars]";
	mes "Une cķrķmonie de mariage est en cours, veuillez ne pas me dķranger. Merci de votre comprķhension...";
	goto L_End;

OnTimer180000:
	mapannounce "prt_church","Le temps imparti pour l'inscription au mariage est ķcoulķ... La cķrķmonie est annulķe.",bc_map;
	stopnpctimer;
OnReset:
	$wed_groom$ = "";
	$wed_bride$ = "";
OnInit:
	$wedding = 0;
	end;

OnStop:
	stopnpctimer;
	end;
}
