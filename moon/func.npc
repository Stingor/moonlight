//===== Moonlight-Destiny ====================================

function	script	MissionMVP	{
	if( !playerattached() ) return;
	.@killed_mob = killedrid;    // id du monstre tuÈ
	.@killer_cid = getcharid(0); // sauvegarde pour restauration en fin de fonction

	if( .@killed_mob < 1 ) return;

	// --- Killer ---
	if( getarg(0,0) ) // Compte pour le classement ? (par dÈfaut non)
		query_sql("UPDATE `char` SET mvp_count = mvp_count + 1 WHERE `char_id` = '" + .@killer_cid + "'");
	if( Mission_MVP != #Mission_Count_MVP && .@killed_mob == Mission_MVP_ID ) {
		Mission_MVP = 1;
		dispbottom "[Chasse MVP] Vous avez tuÈ le MVP de votre mission, retournez voir Chuck !";
	}
	if( getarg(1,"") != "" ) // Message de log ? (par dÈfaut aucun)
		logmes getarg(1);

	// --- Membres de party dans la mÍme instance ---
	.@killer_map$ = strcharinfo(3);
	.@party_id    = getcharid(1);

	if( .@party_id > 0 ) {
		getpartymember(.@party_id, 2); // remplit $@partymembercid[] et $@partymembercount
		for( .@i = 0; .@i < $@partymembercount; ++.@i ) {
			if( $@partymembercid[.@i] == .@killer_cid ) continue; // dÈjý traitÈ
			attachrid($@partymembercid[.@i]);
			if( !playerattached() ) continue;                     // hors-ligne
			if( strcharinfo(3) != .@killer_map$ ) continue;       // pas dans l'instance
			if( Mission_MVP == #Mission_Count_MVP ) continue;     // pas de mission ou dÈjý validÈe
			if( Mission_MVP_ID != .@killed_mob ) continue;        // mission diffÈrente
			Mission_MVP = 1;
			dispbottom "[Chasse MVP] Votre party a tuÈ le MVP de votre mission, retournez voir Chuck !";
		}
		attachrid(.@killer_cid); // restaure le killer comme joueur attachÈ
	}
	return;
}

function	script	announce2	{
	.@color = getarg(2,-1);
	if( .@color == -1 )
		announce getarg(0),getarg(1);
	else 
		announce getarg(0),getarg(1),.@color;
	// query_sql("INSERT INTO `discord` (`text`) VALUES ('"+escape_sql(getarg(0))+"');");
	return;
}

function	script	mapannounce2	{
	.@color = getarg(3,-1);
	if( .@color == -1 )
		mapannounce getarg(0),getarg(1),getarg(2);
	else 
		mapannounce getarg(0),getarg(1),getarg(2),.@color;
	// query_sql("INSERT INTO `discord` (`text`) VALUES ('"+escape_sql(getarg(1))+"');");
	return;
}
function	script	getuniqueid	{
	query_sql("SELECT `user_id` FROM `login` WHERE `account_id` = '"+getarg(0)+"'", .@uniqueid);
	return .@uniqueid;
}

function	script	getusername	{
	query_sql("SELECT `username` FROM `site`.`phpbb_users` WHERE `user_id` = '"+getarg(0)+"'", .@username$);
	return .@username$;
}

function	script	getvote	{
	query_sql("SELECT `vote` FROM `vote` WHERE `user_id` = '"+getarg(0)+"'", .@vote);
	return .@vote;
}

function	script	getevent	{
	query_sql("SELECT `value` FROM `acc_reg_num` WHERE `key` = '#KAFRAPOINTS' AND `account_id` = '"+getarg(0)+"'", .@event);
	return .@event;
}

function	script	getuserid	{
	query_sql("SELECT `userid` FROM `login` WHERE `account_id` = '"+getarg(0)+"'", .@userid$);
	return .@userid$;
}

function	script	getcharname	{
	query_sql("SELECT `name` FROM `char` WHERE `char_id` = '"+getarg(0)+"'", .@name$);
	return .@name$;
}

// attachrid(getpartyleader(instance_live_info(ILI_OWNER), 1));
function	script	instancereward	{
	if( @norewardinstance ) {
		logmes "RÈcompenses non reÁues pour cause de double account.";
		@norewardinstance = 0;
		return;
	}
	.@hm =  getarg(0,1);
	.@instance$ = getarg(1,"");
	.@zeny = getarg(2);
	.@zenyback = 0;
	explode(.@item$[0], getarg(3), ":");
	explode(.@amount$[0], getarg(4), ":");
	if( playerattached() ) {
		if( Zeny + .@zeny < MAX_ZENY )
			Zeny += .@Zeny;
		else if ( #BANKVAULT + .@zeny < MAX_ZENY ) {
			dispbottom .@Zeny+"z sont envoyÈs dans votre bank car vous Ítes arrivez au max (Ctrl+b).";
			#BANKVAULT += .@Zeny;
		}
		else 
			dispbottom "Vous ne gagnez pas de zeny car vous Ítes trop riche.";

		for( .@i = 0; .@i < size(.@item$); .@i++ ) {
			if( atoi(.@amount$[.@i]) < 1 ) continue;
			if( checkweight(atoi(.@item$[.@i]),atoi(.@amount$[.@i]))  )
				getitem atoi(.@item$[.@i]),atoi(.@amount$[.@i]);
			else {
				.@title$ = "Fin d'instance";
				.@body$ = "FÈlicitation vous avez terminÈ l'instance "+.@instance$+" !";
				setarray .@mailitem[0], atoi(.@item$[.@i]);
				setarray .@mailamount[0], atoi(.@amount$[.@i]);
				mail getcharid(0), .@instance$, .@title$, .@body$, .@zenyback, .@mailitem, .@mailamount;
				dispbottom "Une rÈcompense vous est envoyÈe par mail ! (Pas de place)";
			}
		}
		logmes "RÈcompenses reÁues.";
		return;
	}
	else
		logmes "RÈcompenses non reÁues pour cause de double account.";
	return;
}

