function	script	monster_event	{
	.@map$ = getarg(0);
	.@x = getarg(1, 0);
	.@y = getarg(2, 0);
	.@mobid = getarg(3, 1002);
	.@amount = cap_value(getarg(4, 1), 1, 10);
	if( .@mobid < 1001 || getmonsterinfo(.@mobid, MOB_ID) == -1 || .@amount < 1 )
		return 0;
	.@hp = getarg(5, 0);

	monster .@map$,(.@x - 5)+rand(10),(.@y - 5)+rand(10),"Furious "+getmonsterinfo(.@mobid, MOB_NAME),.@mobid,.@amount,"",2;

	if( .@hp > 0 ) {
		for( .@i = 0; .@i <= (.@amount - 1); .@i++) {
			.@mobgid = $@mobid[.@i];
			setunitdata .@mobgid, UMOB_LEVEL, 666;
			if( getarg(6, 0) == 1 )
				setunitdata .@mobgid, UMOB_MODE, MD_CANMOVE|MD_AGGRESSIVE|MD_ASSIST|MD_CANATTACK|MD_CHANGECHASE|MD_ANGRY|MD_CHANGETARGETMELEE|MD_CHANGETARGETCHASE|MD_RANDOMTARGET|MD_MVP|MD_KNOCKBACKIMMUNE|MD_STATUSIMMUNE;
			setunitdata .@mobgid, UMOB_MAXHP, .@hp;
			setunitdata .@mobgid, UMOB_ATKMIN, 80000;
			setunitdata .@mobgid, UMOB_ATKMAX, 100000;
			setunitdata .@mobgid, UMOB_HIT, 2000;
			setunitdata .@mobgid, UMOB_AMOTION, 200;
			setunitdata .@mobgid, UMOB_ADELAY, 200;
			setunitdata .@mobgid, UMOB_SPEED, 50;
		}
		return .@hp;
	}
	return getmonsterinfo(.@mobid, MOB_MAXHP);
}

function	script	sleephm	{
	return round(getarg(1) / getarg(0), 1);
}

function	script	mobhm	{
	.@hardmode = getarg(0,1);
	.@map$ = getarg(2,"region_8");
	.@x = getarg(3,0);
	.@y = getarg(4,0);
	if( getarg(1) == 1 ) { // monsterarea
		.@x_ = getarg(5,0);
		.@y_ = getarg(6,0);
		.@name$ = getarg(7,"--ja--");
		.@mobid = getarg(8,1001);
		.@amount = getarg(9,1);
		.@label$ = getarg(10,"");
		.@size = getarg(11,0);
	}
	else { // monster
		.@name$ = getarg(5,"--ja--");
		.@mobid = getarg(6,1002);
		.@amount = getarg(7,1);
		.@label$ = getarg(8,"");
		.@size = getarg(9,0);
	}

	.@hardmode = cap_value(.@hardmode,1,20);

	if( .@hardmode >= 10 && getmonsterinfo(.@mobid, MOB_MVPEXP) )
		.@size = 2;

	if( getmonsterinfo(.@mobid, MOB_MAXHP) < 1 )
		return 0;
	
	.@mobuid = 0;
	
	if( getarg(1) == 1 ) // monsterarea
		areamonster .@map$,.@x,.@y,.@x_,.@y_,.@name$,.@mobid,.@amount,.@label$,.@size;
	else // monster
		monster .@map$,.@x,.@y,.@name$,.@mobid,.@amount,.@label$,.@size;

	copyarray .@mobarray[0],$@mobid[0],.@amount;
	.@count = .@amount;

	if( .@amount == 1 )
		.@mobuid = .@mobarray[0];

	if( .@hardmode > 1 ) {
		for( .@i = 0; .@i < .@count; .@i++) {
			.@mobgid = .@mobarray[.@i];
			sleep 5;
			if( unitexists(.@mobgid) ) {
				getunitdata .@mobgid, .@data;
				setunitdata .@mobgid, UMOB_LEVEL, .@data[UMOB_LEVEL]*.@hardmode;
				setunitdata .@mobgid, UMOB_MAXHP, (.@data[UMOB_MAXHP] < 5000*.@hardmode?5000*.@hardmode:.@data[UMOB_MAXHP])*.@hardmode*3;
				setunitdata .@mobgid, UMOB_HP,    (.@data[UMOB_HP]    < 5000*.@hardmode?5000*.@hardmode:.@data[UMOB_HP])*.@hardmode*3;
				if( .@hardmode >= 5 )
					setunitdata .@mobgid, UMOB_MODE, MD_CANMOVE|MD_AGGRESSIVE|MD_ASSIST|MD_CANATTACK|MD_CHANGECHASE|MD_ANGRY|MD_CHANGETARGETMELEE|MD_KNOCKBACKIMMUNE|MD_STATUSIMMUNE;
				else if( .@hardmode > 1 )
					setunitdata .@mobgid, UMOB_MODE, MD_CANMOVE|MD_AGGRESSIVE|MD_ASSIST|MD_CANATTACK|MD_CHANGECHASE|MD_ANGRY|MD_CHANGETARGETMELEE;
				if( .@hardmode >= 15 ) {
						setunitdata .@mobgid, UMOB_ATKMIN,  (.@data[UMOB_ATKMIN]  < 2000 *.@hardmode?2000*.@hardmode:.@data[UMOB_ATKMIN])*(.@hardmode*2)*.@hardmode/2;
						setunitdata .@mobgid, UMOB_ATKMAX,  (.@data[UMOB_ATKMAX]  < 10000*.@hardmode?10000*.@hardmode:.@data[UMOB_ATKMAX])*(.@hardmode*2)*.@hardmode/2;
						setunitdata .@mobgid, UMOB_MATKMIN, (.@data[UMOB_MATKMIN] < 2000 *.@hardmode?2000*.@hardmode:.@data[UMOB_MATKMIN])*(.@hardmode*2)*.@hardmode;
						setunitdata .@mobgid, UMOB_MATKMAX, (.@data[UMOB_MATKMAX] < 10000*.@hardmode?10000*.@hardmode:.@data[UMOB_MATKMAX])*(.@hardmode*2)*.@hardmode;
					}
					else {
						setunitdata .@mobgid, UMOB_ATKMIN,  (.@data[UMOB_ATKMIN]  < 1000*.@hardmode?1000*.@hardmode:.@data[UMOB_ATKMIN])*30*.@hardmode/2;
						setunitdata .@mobgid, UMOB_ATKMAX,  (.@data[UMOB_ATKMAX]  < 5000*.@hardmode?5000*.@hardmode:.@data[UMOB_ATKMAX])*30*.@hardmode/2;
						setunitdata .@mobgid, UMOB_MATKMIN, (.@data[UMOB_MATKMIN] < 1000*.@hardmode?1000*.@hardmode:.@data[UMOB_MATKMIN])*30*.@hardmode;
						setunitdata .@mobgid, UMOB_MATKMAX, (.@data[UMOB_MATKMAX] < 5000*.@hardmode?5000*.@hardmode:.@data[UMOB_MATKMAX])*30*.@hardmode;
					}
				setunitdata .@mobgid, UMOB_DEF,  (.@data[UMOB_DEF]  < 5?5:.@data[UMOB_DEF])+cap_value(.@hardmode,1,15);
				setunitdata .@mobgid, UMOB_MDEF, (.@data[UMOB_MDEF] < 5?5:.@data[UMOB_MDEF])+cap_value(.@hardmode,1,15);
				setunitdata .@mobgid, UMOB_HIT,  (.@data[UMOB_HIT]  < 300?300:.@data[UMOB_HIT])*cap_value(.@hardmode,1,15);
				setunitdata .@mobgid, UMOB_FLEE, (.@data[UMOB_FLEE] > 60?60:.@data[UMOB_FLEE])*cap_value(.@hardmode,1,15);
				if( .@hardmode >= 3 )
					setunitdata .@mobgid, UMOB_DEX, 300;
				setunitdata .@mobgid, UMOB_CRIT, (.@data[UMOB_CRIT] < 25?25:.@data[UMOB_CRIT])+.@hardmode*30;
				setunitdata .@mobgid, UMOB_AMOTION, cap_value(.@data[UMOB_AMOTION] / .@hardmode*2,50,1200);
				setunitdata .@mobgid, UMOB_ADELAY, cap_value(.@data[UMOB_ADELAY] / .@hardmode*2,50,1200);
				setunitdata .@mobgid, UMOB_SPEED, cap_value(.@data[UMOB_SPEED] / .@hardmode*2,40,400);
			}
		}
	}
	if( .@mobuid != 0 )
		return .@mobuid;
	else
		return 0;
}

// FONCTION WARP AGENT // ARG0 = MAP | ARG1 = COORDS X | ARG2 = COORDS Y
function	script	warp_fct	{
	lastm_warpa$ = getarg(0);
	lastx_warpa = getarg(1,0);
	lasty_warpa = getarg(2,0);
	if( getarg(0) == "thana_boss" && $@thana_summon >= 6 && $@thana_summon_name$ == "" ) {
		clear;
		mes "[ ^1F81D4"+strnpcinfo(0)+"^000000 ]";
		mes "Thanatos est dÈjý mort.";
		mes $@thana_summon_name_$+" l'a tuÈ ý "+gettimestr("%H:%M:%S",21,$@thana_summon_time);
		close;
	}
	query_sql("UPDATE `char` SET `cur_map` = '"+lastm_warpa$+"' WHERE `char_id` = '"+getcharid(0)+"'");
	warp lastm_warpa$, lastx_warpa, lasty_warpa;
	end;
}

// FONCTION WARP AGENT // GET MAP NAME
function	script	getmapname	{
	.@name$ = getmapdisplayname(getarg(0));
	if( .@name$ != "" ) return .@name$;
	return "Map inconnue";
}

// FONCTION ADD/REMOVE VOTE
function	script	moonlight_vote	{
	.@nombrevote = getarg(0);
	.@uniqueid = callfunc("getuniqueid",getarg(1));
	if( !.@nombrevote || !.@uniqueid ) {
		mes "["+strnpcinfo(0)+"]";
		mes "Une erreur est survenue lors du traitement de l'opÈration.";
		mes "Merci de contacter l'Administrateur.";
		close;
	}
	.@vote = callfunc("getvote",callfunc("getuniqueid",getcharid(3)));
	if( .@vote < .@nombrevote ) {
		mes "["+strnpcinfo(0)+"]";
		mes "Vous n'avez pas assez de Votes pour cette opÈration.";
		logmes "Hack Vote ??? - "+strnpcinfo(3);
		close;
	}
	else {
		.@vote -= .@nombrevote;
		query_sql("UPDATE `vote` SET `vote` = '"+.@vote+"' WHERE `user_id` = '"+.@uniqueid+"'");
	}
	.@vote = 0;
	.@nombrevote = 0;
	.@uniqueid = 0;
	return;
}

// Met en forme un log d'item
function	script	logequip	{
	.@part = getarg(0);
	if( getequipcardcnt(.@part) > 0 ) {
		.@card0$ = ((getequipcardid(.@part,0))?getitemname(getequipcardid(.@part,0)):"");
		.@card1$ = ((getequipcardid(.@part,1))?getitemname(getequipcardid(.@part,1)):"");
		.@card2$ = ((getequipcardid(.@part,2))?getitemname(getequipcardid(.@part,2)):"");
		.@card3$ = ((getequipcardid(.@part,3))?getitemname(getequipcardid(.@part,3)):"");
		setarray .@cards$[0], .@card0$, .@card1$, .@card2$, .@card3$;
		.@cards$ = " -> " + implode(.@cards$, " ");
	}
	else
		.@cards$ = "";

	if( getequiprefinerycnt(.@part) > 0 ) {
		.@refine$ = "+" + getequiprefinerycnt(.@part) + " ";
	}
	else
		.@refine$ = "";

	return .@refine$ + "" + getequipname(.@part)+" ("+getequipuniqueid(.@part)+")"+.@cards$;
}

// Met en forme un log d'item avec UID
function	script	logequipuid	{
	.@uid$ = getarg(0);
	getuidlist(.@uid$);
	.@cards$ = "";
	if( .@itembyuid_slot > 0 ) {
		if( .@itembyuid_card1 ) arraypush .@cards$, getitemname(.@itembyuid_card1);
		if( .@itembyuid_card2 ) arraypush .@cards$, getitemname(.@itembyuid_card2);
		if( .@itembyuid_card3 ) arraypush .@cards$, getitemname(.@itembyuid_card3);
		if( .@itembyuid_card4 ) arraypush .@cards$, getitemname(.@itembyuid_card4);
		if( size(.@cards$) )
			.@cards$ = " -> " + implode(.@cards$, " ");
	}

	.@refine$ = (.@itembyuid_refine > 0 ? "+" + .@itembyuid_refine + " " : "");

	return sprintf("%s%s%s [UID:%s]", .@refine$, getitemname(.@itembyuid_nameid), .@cards$, .@uid$);
}

function	script	mesitemlinkuid	{
	.@uid$ = getarg(0);
	getuidlist(.@uid$);
	.@cards$ = "";
	if( .@itembyuid_slot > 0 ) {
		if( .@itembyuid_card1 ) arraypush .@cards$, getitemname(.@itembyuid_card1);
		if( .@itembyuid_card2 ) arraypush .@cards$, getitemname(.@itembyuid_card2);
		if( .@itembyuid_card3 ) arraypush .@cards$, getitemname(.@itembyuid_card3);
		if( .@itembyuid_card4 ) arraypush .@cards$, getitemname(.@itembyuid_card4);
		if( size(.@cards$) )
			.@cards$ = " -> " + implode(.@cards$, " ");
	}

	.@refine$ = (.@itembyuid_refine > 0 ? "+" + .@itembyuid_refine + " " : "");

	return mesitemlink(.@itembyuid_nameid, 1, sprintf("%s%s%s", .@refine$, getitemname(.@itembyuid_nameid), .@cards$));
}
